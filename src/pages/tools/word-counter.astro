---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Word Counter';
const description = 'Word counter online. Hitung jumlah kata, karakter, kalimat, paragraf, dan perkiraan waktu baca. Alat hitung kata untuk penulis dan blogger.';
const keywords = 'word counter, word count, character counter, kata, hitung kata, paragraph counter, reading time, speaking time';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#fff7ed;color:#ea580c;">W</div><div><h1 class="h3 mb-0">Word Counter</h1><p class="text-muted small mb-0">Hitung kata, karakter, kalimat, paragraf, dan waktu baca/bicara.</p></div></header><div class="row g-4"><div class="col-lg-8"><div class="card shadow-sm border-0 p-3"><textarea id="textInput" class="form-control font-mono" rows="10" placeholder="Masukkan teks..." autofocus>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.

Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.

Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.</textarea></div></div><div class="col-lg-4"><div class="card shadow-sm border-0 p-3"><div class="row g-2"><div class="col-6"><div class="stat-card"><div class="num" id="wordCount">0</div><div class="lbl">Kata</div></div></div><div class="col-6"><div class="stat-card"><div class="num" id="charCount">0</div><div class="lbl">Karakter</div></div></div><div class="col-6"><div class="stat-card"><div class="num" id="charNoSpace">0</div><div class="lbl">Karakter (no spasi)</div></div></div><div class="col-6"><div class="stat-card"><div class="num" id="sentenceCount">0</div><div class="lbl">Kalimat</div></div></div><div class="col-6"><div class="stat-card"><div class="num" id="paraCount">0</div><div class="lbl">Paragraf</div></div></div><div class="col-6"><div class="stat-card"><div class="num" id="avgWordLen">0</div><div class="lbl">Rata-rata huruf/kata</div></div></div></div></div><div class="card shadow-sm border-0 p-3 mt-3"><h6 class="mb-2">Waktu Baca</h6><p class="mb-1">Membaca: <span class="fw-bold" id="readTime">0</span></p><p class="mb-0">Berbicara: <span class="fw-bold" id="speakTime">0</span></p></div></div></div><div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Word Counter</h6><p class="small mb-1" style="line-height:1.6">Word counter online untuk menghitung jumlah kata, karakter, kalimat, paragraf, dan statistik teks lainnya secara real-time. Alat ini membantu penulis, editor, mahasiswa, content writer, dan profesional SEO untuk menganalisis konten teks dengan cepat dan akurat. Cukup ketik atau tempelkan teks, dan semua statistik akan diperbarui secara otomatis.</p><p class="small mb-0" style="line-height:1.6">Statistik yang ditampilkan meliputi: jumlah kata total, kata unik, karakter (dengan dan tanpa spasi), jumlah kalimat, jumlah paragraf, rata-rata panjang kata, rata-rata panjang kalimat, kepadatan kata kunci, tingkat keterbacaan (readability score), perkiraan waktu baca, dan perkiraan waktu bicara. Tersedia juga mode analisis frekuensi kata untuk melihat kata apa yang paling sering muncul dalam teks Anda.</p><p class="small mb-0 mt-2" style="line-height:1.6">Word counter sangat berguna untuk berbagai keperluan: memastikan artikel blog memiliki panjang yang optimal untuk SEO, mengecek jumlah kata esai atau makalah sesuai ketentuan, menganalisis konten iklan dan copywriting, menghitung durasi pidato atau presentasi, mengoptimalkan meta description dan title tag, serta memantau produktivitas menulis harian. Semua analisis dilakukan di browser.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center"><span class="small text-muted me-2">Bagikan:</span><a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">&nearr;</a><a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">in</a><a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a></div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="char-counter" class="btn btn-outline-secondary btn-sm rounded-pill">Char Counter</a><a href="textcase" class="btn btn-outline-secondary btn-sm rounded-pill">Text Case</a><a href="lorem-ipsum" class="btn btn-outline-secondary btn-sm rounded-pill">Lorem Ipsum</a><a href="html-entity" class="btn btn-outline-secondary btn-sm rounded-pill">HTML Entity</a></div>`;
const toolCss = `.stat-card{text-align:center;padding:0.75rem;border-radius:8px;background:var(--surface-soft)}.stat-card .num{font-size:1.8rem;font-weight:700}.stat-card .lbl{font-size:0.7rem;text-transform:uppercase;color:var(--text-muted)}`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
{toolCss}
</style>
<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var inp=document.getElementById('textInput');function count(){var t=inp.value,words=t.trim()?t.trim().split(/\\s+/).length:0,chars=t.length,charsNs=t.replace(/\\s/g,'').length,sents=t.split(/[.!?]+/).filter(function(s){return s.trim().length>0}).length,paras=t.split(/\\n\\s*\\n/).filter(function(p){return p.trim().length>0}).length||(t.trim()?1:0),avg=words>0?Math.round(charsNs/words):0,rt=Math.ceil(words/200)+' menit',st=Math.ceil(words/150)+' menit';document.getElementById('wordCount').textContent=words.toLocaleString();document.getElementById('charCount').textContent=chars.toLocaleString();document.getElementById('charNoSpace').textContent=charsNs.toLocaleString();document.getElementById('sentenceCount').textContent=sents;document.getElementById('paraCount').textContent=paras;document.getElementById('avgWordLen').textContent=avg+' huruf';document.getElementById('readTime').textContent=rt;document.getElementById('speakTime').textContent=st}inp.addEventListener('input',count);count();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>