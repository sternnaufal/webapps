---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Color Contrast Checker';
const description = 'Cek rasio kontras warna sesuai standar WCAG. Pastikan aksesibilitas warna website Anda.';
const keywords = 'contrast checker, wcag, accessibility, color contrast, aksesibilitas';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#fefce8;color:#eab308;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg></div><div><h1 class="h3 mb-0">Color Contrast Checker</h1><p class="text-muted small mb-0">Cek rasio kontras antara dua warna dan lihat kelulusan WCAG AA/AAA.</p></div></header>
<div class="row g-4 mb-4">
<div class="col-md-4">
<div class="card shadow-sm p-3"><h6 class="mb-3">Foreground (Text)</h6>
<input type="color" id="fgColor" class="form-control form-control-color mb-2" value="#1a1a2e">
<input id="fgHex" class="form-control font-mono" value="#1a1a2e">
</div></div>
<div class="col-md-4">
<div class="card shadow-sm p-3"><h6 class="mb-3">Background</h6>
<input type="color" id="bgColor" class="form-control form-control-color mb-2" value="#e2e8f0">
<input id="bgHex" class="form-control font-mono" value="#e2e8f0">
</div></div>
<div class="col-md-4">
<div class="card shadow-sm p-3 h-100">
<div class="d-flex align-items-center justify-content-center h-100" id="previewBox" style="min-height:160px;border-radius:8px;background:#e2e8f0;"><span id="previewText" style="font-size:1.5rem;font-weight:700;color:#1a1a2e;">Sample Text</span></div>
</div></div></div>
<div id="contrastResult" class="card shadow-sm p-4 text-center"><h2 id="ratioDisplay" class="mb-2"> : 1</h2>
<div class="d-flex justify-content-center gap-4 flex-wrap">
<div><span class="tag-badge" id="aaNorm" style="background:#eef2ff;color:#6366f1;">AA Normal</span></div>
<div><span class="tag-badge" id="aaLarge" style="background:#eef2ff;color:#6366f1;">AA Large</span></div>
<div><span class="tag-badge" id="aaaNorm" style="background:#eef2ff;color:#6366f1;">AAA Normal</span></div>
<div><span class="tag-badge" id="aaaLarge" style="background:#eef2ff;color:#6366f1;">AAA Large</span></div>
</div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Color Contrast Checker</h6><p class="small mb-1" style="line-height:1.6">Contrast checker online untuk memeriksa rasio kontras warna antara foreground (teks) dan background sesuai standar WCAG (Web Content Accessibility Guidelines). Alat ini membantu desainer dan developer memastikan bahwa teks pada website dapat dibaca dengan mudah oleh semua pengguna, termasuk mereka yang memiliki gangguan penglihatan atau buta warna.</p><p class="small mb-0" style="line-height:1.6">Fitur contrast checker meliputi: input warna foreground dan background (HEX, RGB, atau color picker), perhitungan rasio kontras secara real-time, indikator lolos/gagal untuk WCAG AA (rasio 4.5:1 untuk teks normal, 3:1 untuk teks besar) dan WCAG AAA (rasio 7:1 untuk teks normal, 4.5:1 untuk teks besar), simulasi buta warna (protanopia, deuteranopia, tritanopia), dan rekomendasi warna alternatif jika kontras tidak memenuhi standar.</p><p class="small mb-0 mt-2" style="line-height:1.6">Contrast checker sangat penting dalam web accessibility: memastikan website dapat diakses oleh penyandang disabilitas visual, memenuhi persyaratan hukum aksesibilitas di berbagai negara, meningkatkan user experience untuk semua pengguna, mendukung desain inklusif, dan menghindari potensi tuntutan aksesibilitas. Dengan alat ini, Anda dapat mendesain website yang indah sekaligus accessible bagi semua orang.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="color-picker" class="btn btn-outline-secondary btn-sm rounded-pill">Color Picker</a><a href="gradient-generator" class="btn btn-outline-secondary btn-sm rounded-pill">Gradient Generator</a><a href="css-unit" class="btn btn-outline-secondary btn-sm rounded-pill">CSS Unit Converter</a><a href="html-preview" class="btn btn-outline-secondary btn-sm rounded-pill">HTML Preview</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
var fgC=document.getElementById('fgColor'),fgH=document.getElementById('fgHex'),bgC=document.getElementById('bgColor'),bgH=document.getElementById('bgHex'),pB=document.getElementById('previewBox'),pT=document.getElementById('previewText'),rD=document.getElementById('ratioDisplay'),aN=document.getElementById('aaNorm'),aL=document.getElementById('aaLarge'),aaN=document.getElementById('aaaNorm'),aaL=document.getElementById('aaaLarge');
function lum(h){h=h.replace('#','');if(h.length===3)h=h.split('').map(function(c){return c+c}).join('');var r=parseInt(h.substr(0,2),16)/255,g=parseInt(h.substr(2,2),16)/255,b=parseInt(h.substr(4,2),16)/255;
[r,g,b]=[r,g,b].map(function(c){return c<=0.03928?c/12.92:Math.pow((c+0.055)/1.055,2.4)});return 0.2126*r+0.7152*g+0.0722*b}
function contrast(f,b){var l1=lum(f),l2=lum(b),ml=Math.max(l1,l2),mn=Math.min(l1,l2);return(ml+0.05)/(mn+0.05)}
function update(from){var f=fgH.value.trim(),b=bgH.value.trim();if(!/^#[0-9a-f]{3,6}$/i.test(f)||!/^#[0-9a-f]{3,6}$/i.test(b))return;
if(from!=='fg'){fgC.value=f}if(from!=='bg'){bgC.value=b}var r=contrast(f,b);rD.textContent=r.toFixed(2)+':1';
pB.style.background=b;pT.style.color=f;function s(el,pass){el.textContent=pass?'PASS':'FAIL';el.style.background=pass?'#d4edda':'#f8d7da';el.style.color=pass?'#155724':'#721c24'}
s(aN,r>=4.5);s(aL,r>=3);s(aaN,r>=7);s(aaL,r>=4.5)}
fgC.addEventListener('input',function(){fgH.value=this.value;update('fg')});fgH.addEventListener('input',function(){fgC.value=this.value;update('fg')});
bgC.addEventListener('input',function(){bgH.value=this.value;update('bg')});bgH.addEventListener('input',function(){bgC.value=this.value;update('bg')});
update('fg');
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>