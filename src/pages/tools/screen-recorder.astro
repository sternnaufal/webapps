---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Screen Recorder';
const description = 'Rekam layar browser online gratis. Screen recorder langsung dari browser tanpa install software.';
const keywords = 'screen recorder, record screen, screen capture, rekam layar';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#fef2f2;color:#dc2626;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="2"/><path d="M12 2a10 10 0 100 20 10 10 0 000-20z"/></svg></div><div><h1 class="h3 mb-0">Screen Recorder</h1><p class="text-muted small mb-0">Rekam layar, tab, atau kamera langsung dari browser. Download sebagai WebM.</p></div></header>
<div class="row g-4 mb-4">
<div class="col-md-4">
<div class="card shadow-sm p-3"><h6 class="mb-3">Source</h6>
<select id="recSource" class="form-select mb-3"><option value="screen">Screen (tab/window)</option><option value="camera">Camera</option></select>
<div class="d-flex gap-2 flex-wrap">
<button id="btnStart" class="btn btn-danger"><svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6"/></svg> Start</button>
<button id="btnStop" class="btn btn-secondary" disabled><svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><rect x="4" y="4" width="8" height="8"/></svg> Stop</button>
</div>
<div id="recStatus" class="small text-muted mt-2">Ready</div>
</div></div>
<div class="col-md-8"><div class="card shadow-sm p-2"><video id="preview" autoplay muted playsinline style="width:100%;border-radius:6px;max-height:400px;background:#000;"></video>
<div id="downloadSection" style="display:none;" class="mt-2"><a id="downloadLink" class="btn btn-success btn-sm">Download Recording (WebM)</a></div></div></div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Screen Recorder</h6><p class="small mb-1" style="line-height:1.6">Screen recorder online untuk merekam layar komputer langsung dari browser tanpa perlu menginstal software tambahan. Alat ini memanfaatkan Web API Screen Capture modern yang didukung oleh browser terkini. Anda dapat merekam seluruh layar, jendela aplikasi tertentu, atau tab browser. Mendukung perekaman dengan audio dari mikrofon untuk menambahkan narasi atau komentar suara.</p><p class="small mb-0" style="line-height:1.6">Cara penggunaan: klik tombol Mulai Rekam, pilih sumber yang ingin direkam (seluruh layar, jendela, atau tab), dan rekaman akan berjalan. Anda bisa menghentikan rekaman kapan saja, dan hasilnya akan langsung dapat diputar kembali atau di-download dalam format WebM. Screen recorder ini juga menampilkan durasi rekaman secara real-time. Kualitas rekaman dapat disesuaikan dengan kebutuhan.</p><p class="small mb-0 mt-2" style="line-height:1.6">Screen recorder online sangat berguna untuk: membuat video tutorial atau panduan penggunaan software, merekam presentasi atau webinar, demo produk untuk klien, merekam bug report untuk tim developer, membuat konten edukasi, dan mendokumentasikan alur kerja. Semua proses perekaman dan encoding dilakukan di browser Anda. Rekaman tidak dikirim ke server mana pun, sehingga privasi dan keamanan data Anda terjamin.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="timer" class="btn btn-outline-secondary btn-sm rounded-pill">Timer</a><a href="countdown" class="btn btn-outline-secondary btn-sm rounded-pill">Countdown</a><a href="pomodoro" class="btn btn-outline-secondary btn-sm rounded-pill">Pomodoro</a><a href="qr-generator" class="btn btn-outline-secondary btn-sm rounded-pill">QR Generator</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
var preview=document.getElementById('preview'),btnStart=document.getElementById('btnStart'),btnStop=document.getElementById('btnStop'),status=document.getElementById('recStatus'),dlSection=document.getElementById('downloadSection'),dlLink=document.getElementById('downloadLink'),source=document.getElementById('recSource');
var mediaStream=null,mediaRecorder=null,chunks=[];

async function startRec(){try{
var src=source.value,constraints=src==='camera'?{video:true,audio:true}:{video:{mediaSource:'screen'},audio:false};
mediaStream=src==='camera'?await navigator.mediaDevices.getUserMedia(constraints):await navigator.mediaDevices.getDisplayMedia(constraints);
preview.srcObject=mediaStream;mediaRecorder=new MediaRecorder(mediaStream,{mimeType:'video/webm'});
chunks=[];mediaRecorder.ondataavailable=function(e){if(e.data.size>0)chunks.push(e.data)};
mediaRecorder.onstop=function(){var blob=new Blob(chunks,{type:'video/webm'}),url=URL.createObjectURL(blob);
dlLink.href=url;dlLink.download='recording.webm';dlSection.style.display='block';
mediaStream.getTracks().forEach(function(t){t.stop()});preview.srcObject=null};
mediaRecorder.start();btnStart.disabled=true;btnStop.disabled=false;source.disabled=true;
status.textContent='Recording...';status.className='mt-2 text-danger small fw-semibold';
}catch(e){status.textContent='Error: '+e.message;status.className='mt-2 text-danger small'}}

function stopRec(){if(mediaRecorder&&mediaRecorder.state!=='inactive'){mediaRecorder.stop();btnStart.disabled=false;btnStop.disabled=true;source.disabled=false;status.textContent='Stopped. Download below.';status.className='mt-2 text-success small'}}
btnStart.addEventListener('click',startRec);btnStop.addEventListener('click',stopRec);
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>