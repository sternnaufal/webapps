---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Timer & Stopwatch';
const description = 'Timer dan stopwatch online gratis. Hitung mundur dan penghitung waktu dengan alarm.';
const keywords = 'timer, stopwatch, countdown, online timer, penghitung waktu';
const bodyHtml = `<ul class="nav nav-tabs mb-4" id="tabNav">
        <li class="nav-item"><a class="nav-link active" href="#" data-tab="stopwatch">Stopwatch</a></li>
        <li class="nav-item"><a class="nav-link" href="#" data-tab="timer">Timer</a></li>
      </ul>

      <!-- Stopwatch -->
      <div id="tabStopwatch">
        <div class="card p-4 shadow-sm text-center">
          <div class="time-display mb-3" id="swDisplay">00:00:00.00</div>
          <div class="d-flex justify-content-center gap-2 mb-3 flex-wrap">
            <button id="swStart" class="btn btn-success btn-lg">Start</button>
            <button id="swPause" class="btn btn-warning btn-lg" disabled>Pause</button>
            <button id="swReset" class="btn btn-outline-danger btn-lg">Reset</button>
            <button id="swLap" class="btn btn-outline-primary btn-lg" disabled>Lap</button>
          </div>
          <div id="lapList" class="text-start" style="max-height: 250px; overflow-y: auto;"></div>
        </div>
      </div>

      <!-- Timer -->
      <div id="tabTimer" style="display:none;">
        <div class="card p-4 shadow-sm text-center">
          <div class="time-display mb-3" id="tmDisplay">05:00</div>
          <div class="row g-2 mb-3 justify-content-center">
            <div class="col-auto">
              <label class="form-label small">Jam</label>
              <select id="tmHours" class="form-select" style="width:80px;">
                <option value="0" selected>0</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
              </select>
            </div>
            <div class="col-auto">
              <label class="form-label small">Menit</label>
              <select id="tmMinutes" class="form-select" style="width:80px;">
                <option value="0">0</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="15">15</option>
                <option value="30">30</option>
                <option value="45">45</option>
              </select>
            </div>
            <div class="col-auto">
              <label class="form-label small">Detik</label>
              <select id="tmSeconds" class="form-select" style="width:80px;">
                <option value="0">0</option>
                <option value="15">15</option>
                <option value="30">30</option>
                <option value="45">45</option>
                <option value="60" selected>60</option>
              </select>
            </div>
          </div>
          <div class="d-flex justify-content-center gap-2 flex-wrap">
            <button id="tmStart" class="btn btn-success btn-lg">Start</button>
            <button id="tmPause" class="btn btn-warning btn-lg" disabled>Pause</button>
            <button id="tmReset" class="btn btn-outline-danger btn-lg">Reset</button>
          </div>
          <div id="tmAlert" class="mt-3" style="display:none;">
            <div class="alert alert-success mb-0">Time's up! <button id="tmDismiss" class="btn btn-sm btn-outline-success ms-2">Dismiss</button></div>
          </div>
        </div>
      </div>
    <div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Timer & Stopwatch</h6><p class="small mb-1" style="line-height:1.6">Timer dan stopwatch online dengan fitur lengkap untuk mengukur waktu dengan presisi. Stopwatch mendukung penghitungan waktu maju dengan fitur lap times / split times, sedangkan timer memungkinkan Anda mengatur hitung mundur dari durasi tertentu. Kedua alat ini berguna untuk berbagai kebutuhan: olahraga, memasak, belajar (teknik Pomodoro), presentasi, dan produktivitas sehari-hari.</p><p class="small mb-0" style="line-height:1.6">Fitur stopwatch meliputi: start, stop, dan reset; pencatatan lap times dengan timestamp; tampilan waktu dalam format jam:menit:detik.milidetik; dan daftar riwayat lap yang bisa diekspor. Fitur timer meliputi: pengaturan durasi manual atau preset cepat (1, 3, 5, 10, 15, 30 menit); alarm suara saat waktu habis; dan tampilan visual progress bar. Kedua mode dapat diakses dari tab yang berbeda dalam satu halaman.</p><p class="small mb-0 mt-2" style="line-height:1.6">Timer dan stopwatch online ini sangat praktis karena tidak perlu menginstal aplikasi tambahan. Gunakan stopwatch untuk: mengukur waktu lari atau olahraga, mencatat waktu pengerjaan tugas, timing presentasi, dan eksperimen laboratorium. Gunakan timer untuk: teknik Pomodoro (25 menit fokus, 5 menit istirahat), memasak, waktu istirahat, dan pengingat aktivitas. Semua fungsi berjalan di browser, bahkan saat berpindah tab.</p></div>\`n`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="countdown" class="btn btn-outline-secondary btn-sm rounded-pill">Countdown</a><a href="pomodoro" class="btn btn-outline-secondary btn-sm rounded-pill">Pomodoro</a><a href="world-clock" class="btn btn-outline-secondary btn-sm rounded-pill">World Clock</a><a href="screen-recorder" class="btn btn-outline-secondary btn-sm rounded-pill">Screen Recorder</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent = new Date().getFullYear();
</script>

<script is:inline>
// Tab switching
document.querySelectorAll('#tabNav .nav-link').forEach(function(tab) {
  tab.addEventListener('click', function(e) {
    e.preventDefault();
    document.querySelectorAll('#tabNav .nav-link').forEach(function(t) { t.classList.remove('active'); });
    this.classList.add('active');
    var target = this.getAttribute('data-tab');
    document.getElementById('tabStopwatch').style.display = target === 'stopwatch' ? 'block' : 'none';
    document.getElementById('tabTimer').style.display = target === 'timer' ? 'block' : 'none';
  });
});

// ============= STOPWATCH =============
var swInterval = null;
var swRunning = false;
var swTime = 0; // milliseconds
var swLaps = [];
var swDisplay = document.getElementById('swDisplay');

function swFormat(ms) {
  var totalSec = ms / 1000;
  var h = Math.floor(totalSec / 3600);
  var m = Math.floor((totalSec % 3600) / 60);
  var s = Math.floor(totalSec % 60);
  var cs = Math.floor((ms % 1000) / 10);
  return (h < 10 ? '0' + h : h) + ':' + (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s) + '.' + (cs < 10 ? '0' + cs : cs);
}

function swTick() {
  swTime += 10;
  swDisplay.textContent = swFormat(swTime);
}

function swStart() {
  if (swRunning) return;
  swRunning = true;
  swInterval = setInterval(swTick, 10);
  document.getElementById('swStart').disabled = true;
  document.getElementById('swPause').disabled = false;
  document.getElementById('swLap').disabled = false;
}

function swPause() {
  if (!swRunning) return;
  swRunning = false;
  clearInterval(swInterval);
  document.getElementById('swStart').disabled = false;
  document.getElementById('swStart').textContent = 'Resume';
  document.getElementById('swPause').disabled = true;
  document.getElementById('swLap').disabled = true;
}

function swReset() {
  swRunning = false;
  clearInterval(swInterval);
  swTime = 0;
  swLaps = [];
  swDisplay.textContent = '00:00:00.00';
  document.getElementById('swStart').disabled = false;
  document.getElementById('swStart').textContent = 'Start';
  document.getElementById('swPause').disabled = true;
  document.getElementById('swLap').disabled = true;
  document.getElementById('lapList').innerHTML = '';
}

function swLap() {
  if (!swRunning) return;
  swLaps.push(swTime);
  var lapNum = swLaps.length;
  var lapTime = swLaps[lapNum - 1] - (lapNum > 1 ? swLaps[lapNum - 2] : 0);
  var container = document.getElementById('lapList');
  var div = document.createElement('div');
  div.className = 'lap-item d-flex justify-content-between border-bottom py-1';
  div.innerHTML = '<span>Lap ' + lapNum + '</span><span class="lap-time">' + swFormat(lapTime) + ' <span class="text-muted">(' + swFormat(swLaps[lapNum - 1]) + ')</span></span>';
  container.insertBefore(div, container.firstChild);
}

document.getElementById('swStart').addEventListener('click', swStart);
document.getElementById('swPause').addEventListener('click', swPause);
document.getElementById('swReset').addEventListener('click', swReset);
document.getElementById('swLap').addEventListener('click', swLap);

// ============= TIMER =============
var tmInterval = null;
var tmRunning = false;
var tmRemaining = 0; // seconds
var tmDisplay = document.getElementById('tmDisplay');

function tmFormat(sec) {
  if (sec <= 0) return '00:00';
  var h = Math.floor(sec / 3600);
  var m = Math.floor((sec % 3600) / 60);
  var s = sec % 60;
  if (h > 0) return (h < 10 ? '0' + h : h) + ':' + (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s);
  return (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s);
}

function tmTick() {
  tmRemaining--;
  tmDisplay.textContent = tmFormat(tmRemaining);
  if (tmRemaining <= 0) {
    clearInterval(tmInterval);
    tmRunning = false;
    document.getElementById('tmAlert').style.display = 'block';
    document.getElementById('tmStart').disabled = false;
    document.getElementById('tmPause').disabled = true;
  }
}

function tmGetDuration() {
  var h = parseInt(document.getElementById('tmHours').value, 10) || 0;
  var m = parseInt(document.getElementById('tmMinutes').value, 10) || 0;
  var s = parseInt(document.getElementById('tmSeconds').value, 10) || 0;
  return h * 3600 + m * 60 + s;
}

function tmStart() {
  if (tmRunning) return;
  var total = tmGetDuration();
  if (total <= 0) { alert('Set timer duration first'); return; }
  tmRemaining = total;
  tmDisplay.textContent = tmFormat(tmRemaining);
  tmRunning = true;
  tmInterval = setInterval(tmTick, 1000);
  document.getElementById('tmStart').disabled = true;
  document.getElementById('tmPause').disabled = false;
  document.getElementById('tmAlert').style.display = 'none';
}

function tmPause() {
  if (!tmRunning) return;
  tmRunning = false;
  clearInterval(tmInterval);
  document.getElementById('tmStart').disabled = false;
  document.getElementById('tmStart').textContent = 'Resume';
  document.getElementById('tmPause').disabled = true;
}

function tmReset() {
  tmRunning = false;
  clearInterval(tmInterval);
  tmRemaining = 0;
  tmDisplay.textContent = '00:00';
  document.getElementById('tmStart').disabled = false;
  document.getElementById('tmStart').textContent = 'Start';
  document.getElementById('tmPause').disabled = true;
  document.getElementById('tmAlert').style.display = 'none';
}

document.getElementById('tmStart').addEventListener('click', tmStart);
document.getElementById('tmPause').addEventListener('click', tmPause);
document.getElementById('tmReset').addEventListener('click', tmReset);
document.getElementById('tmDismiss').addEventListener('click', function() { document.getElementById('tmAlert').style.display = 'none'; });
</script>

