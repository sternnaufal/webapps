---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'IP Calculator';
const description = 'Kalkulator IP address: hitung subnet, CIDR, wildcard mask, network range online gratis.';
const keywords = 'ip calculator, subnet calculator, cidr, ip address, network calculator';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0fdf4;color:#10b981;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div><div><h1 class="h3 mb-0">IP Calculator</h1><p class="text-muted small mb-0">Informasi detail IP Address  representasi biner, kelas, range, dan reverse lookup.</p></div></header>
<div class="row g-3 mb-4"><div class="col-md-6"><label class="form-label">IP Address</label><input id="ipInput" class="form-control font-mono" value="192.168.1.1"><button id="btnCalc" class="btn btn-primary mt-2">Hitung</button></div></div>
<div id="ipResult" style="display:none;"><div class="card shadow-sm p-3"><div id="ipInfo" class="row g-3"></div></div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang IP Calculator</h6><p class="small mb-1" style="line-height:1.6">IP calculator online untuk menghitung informasi subnet dari alamat IP dan CIDR notation. Alat ini membantu network engineer, administrator jaringan, dan mahasiswa IT untuk menghitung network address, broadcast address, subnet mask, wildcard mask, jumlah host, dan range IP yang valid. Mendukung perhitungan untuk semua prefix length dari /0 hingga /32.</p><p class="small mb-0" style="line-height:1.6">Fitur IP calculator ini meliputi: input alamat IP dalam format dotted decimal (192.168.1.0), input prefix length (/24), hasil lengkap meliputi network address, broadcast address, subnet mask, wildcard mask, first dan last host, jumlah total host, dan jumlah usable host. Informasi tambahan seperti kelas IP dan tipe (private/public) juga ditampilkan. Hasil dapat disalin dengan mudah.</p><p class="small mb-0 mt-2" style="line-height:1.6">IP address calculator sangat berguna untuk: merencanakan skema IP untuk jaringan kantor atau rumah, menghitung kebutuhan subnet untuk segmen jaringan berbeda, troubleshooting konektivitas jaringan, belajar konsep TCP/IP dan subnetting, mempersiapkan sertifikasi jaringan seperti CCNA, dan mengoptimalkan alokasi IP address. Semua perhitungan dilakukan secara client-side di browser.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="subnetting" class="btn btn-outline-secondary btn-sm rounded-pill">Subnetting</a><a href="konverter-bilangan" class="btn btn-outline-secondary btn-sm rounded-pill">Konverter Bilangan</a><a href="http-status" class="btn btn-outline-secondary btn-sm rounded-pill">HTTP Status</a><a href="cron-builder" class="btn btn-outline-secondary btn-sm rounded-pill">Cron Builder</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
function calc(){var ip=document.getElementById('ipInput').value.trim(),parts=ip.split('.');if(parts.length!==4||parts.some(function(p){var n=parseInt(p,10);return isNaN(n)||n<0||n>255})){document.getElementById('ipResult').innerHTML='<div class="alert alert-danger">IP tidak valid</div>';document.getElementById('ipResult').style.display='block';return}
var nums=parts.map(function(p){return parseInt(p,10)}),long=((nums[0]<<24)+(nums[1]<<16)+(nums[2]<<8)+nums[3])>>>0,binary=nums.map(function(n){return n.toString(2).padStart(8,'0')}).join('.');
var oct1=nums[0],cls,defMask;if(oct1>=1&&oct1<=126){cls='A';defMask='255.0.0.0'}else if(oct1>=128&&oct1<=191){cls='B';defMask='255.255.0.0'}else if(oct1>=192&&oct1<=223){cls='C';defMask='255.255.255.0'}else if(oct1>=224&&oct1<=239){cls='D (Multicast)';defMask='N/A'}else{cls='E (Experimental)';defMask='N/A'}
var range=cls==='A'?nums[0]+'.0.0.0 - '+nums[0]+'.255.255.255':cls==='B'?nums[0]+'.'+nums[1]+'.0.0 - '+nums[0]+'.'+nums[1]+'.255.255':cls==='C'?nums[0]+'.'+nums[1]+'.'+nums[2]+'.0 - '+nums[0]+'.'+nums[1]+'.'+nums[2]+'.255':'-';
var hex='0x'+nums.map(function(n){return n.toString(16).padStart(2,'0')}).join(''),rev='';if(cls==='A'||cls==='B'||cls==='C'){var r=nums.slice().reverse();rev=r.join('.')+'.in-addr.arpa'}
var h='';function r(l,v){h+='<div class="col-md-6 col-lg-4"><div class="p-3 rounded" style="background:var(--surface-soft)"><small class="text-muted">'+l+'</small><div class="fw-semibold font-mono mt-1">'+v+'</div></div></div>'}
r('IP Address',ip);r('Decimal',long);r('Binary',binary);r('Hex',hex);r('Class',cls);r('Default Mask',defMask);r('Network Range',range);r('Reverse DNS',rev);r('Octets',nums.join(' . '));
document.getElementById('ipInfo').innerHTML=h;document.getElementById('ipResult').style.display='block'}
document.getElementById('btnCalc').addEventListener('click',calc);calc();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>