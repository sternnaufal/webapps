---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'BMI Calculator';
const description = 'Kalkulator BMI online. Hitung Indeks Massa Tubuh dan cek kategori berat badan.';
const keywords = 'bmi calculator, bmi kalkulator, indeks massa tubuh, berat badan ideal, health calculator';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0fdf4;color:#16a34a;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg></div><div><h1 class="h3 mb-0">BMI Calculator</h1><p class="text-muted small mb-0">Hitung Indeks Massa Tubuh (BMI) dan cek kategori berat badan.</p></div></header>
<div class="row g-4"><div class="col-lg-5">
<div class="card shadow-sm border-0 p-3">
<div class="mb-3"><label class="form-label fw-semibold">Jenis Kelamin</label><div><div class="form-check form-check-inline"><input type="radio" name="gender" id="genderMale" class="form-check-input" checked><label class="form-check-label" for="genderMale">Laki-laki</label></div><div class="form-check form-check-inline"><input type="radio" name="gender" id="genderFemale" class="form-check-input"><label class="form-check-label" for="genderFemale">Perempuan</label></div></div></div>
<div class="row g-2 mb-3"><div class="col-6"><label class="form-label small">Tinggi Badan (cm)</label><input type="number" id="heightInput" class="form-control" value="170" min="50" max="300"></div><div class="col-6"><label class="form-label small">Berat Badan (kg)</label><input type="number" id="weightInput" class="form-control" value="65" min="10" max="500"></div></div>
<button id="btnCalc" class="btn btn-primary w-100">Hitung BMI</button>
</div></div>
<div class="col-lg-7">
<div class="card shadow-sm border-0 p-3">
<div class="text-center mb-3"><div class="display-3 fw-bold" id="bmiValue">22.5</div><div class="fw-semibold" id="bmiCategory" style="color:#22c55e">Normal</div></div>
<div class="position-relative" style="height:12px;margin:20px 0"><div class="bmi-scale"><span style="background:#3b82f6"></span><span style="background:#22c55e"></span><span style="background:#f59e0b"></span><span style="background:#f97316"></span><span style="background:#ef4444"></span></div><div class="bmi-arrow" id="bmiArrow" style="left:45%"></div></div>
<div class="row text-center small g-2"><div class="col"><span class="text-primary">Kurus<br>&lt;18.5</span></div><div class="col"><span class="text-success">Normal<br>18.524.9</span></div><div class="col"><span class="text-warning">Overweight<br>2529.9</span></div><div class="col"><span class="text-orange">Obesitas I<br>3034.9</span></div><div class="col"><span class="text-danger">Obesitas II<br>=35</span></div></div>
<div id="bmiDetail" class="mt-3 p-3 bg-light rounded small"></div>
</div></div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang BMI Calculator</h6><p class="small mb-1" style="line-height:1.6">BMI (Body Mass Index) calculator online untuk menghitung Indeks Massa Tubuh berdasarkan tinggi dan berat badan. BMI adalah metode pengukuran yang digunakan secara luas untuk menilai apakah berat badan seseorang termasuk dalam kategori kurus, normal, overweight (kelebihan berat badan), atau obesitas. Kalkulator BMI ini membantu Anda memantau kesehatan berat badan secara mandiri dan instan.</p><p class="small mb-0" style="line-height:1.6">Cara penggunaan: masukkan tinggi badan dalam sentimeter (cm) dan berat badan dalam kilogram (kg), lalu klik Hitung BMI. Hasil akan menampilkan skor BMI dengan satu angka desimal, kategori berat badan (kekurangan berat badan, normal, kelebihan berat badan, atau obesitas tingkat I/II/III), dan rentang berat badan ideal untuk tinggi Anda. Kalkulator ini juga menampilkan grafik visual posisi BMI Anda dalam skala.</p><p class="small mb-0 mt-2" style="line-height:1.6">BMI adalah indikator sederhana namun berguna untuk screening kesehatan. Meskipun BMI tidak mengukur persentase lemak tubuh secara langsung, BMI berkorelasi dengan risiko penyakit terkait obesitas seperti diabetes tipe 2, hipertensi, dan penyakit jantung. Kalkulator BMI ini cocok untuk pria dan wanita dewasa usia 18-65 tahun. Penting untuk diingat bahwa BMI hanyalah salah satu indikator dan tidak menggantikan konsultasi dengan tenaga kesehatan profesional.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="calorie-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Calorie Calculator</a><a href="percentage-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Percentage Calculator</a><a href="tip-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Tip Calculator</a><a href="age-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Age Calculator</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var hInp=document.getElementById('heightInput'),wInp=document.getElementById('weightInput'),bmiV=document.getElementById('bmiValue'),bmiC=document.getElementById('bmiCategory'),bmiA=document.getElementById('bmiArrow'),bmiD=document.getElementById('bmiDetail');
function calc(){
  var h=parseFloat(hInp.value)||0,w=parseFloat(wInp.value)||0;
  if(h<=0||w<=0){bmiV.textContent='0';bmiC.textContent='Masukkan data';return}
  var bmi=w/((h/100)*(h/100));
  bmiV.textContent=bmi.toFixed(1);
  var cat,color,advice;
  if(bmi<18.5){cat='Kurus';color='#3b82f6';advice='Anda memiliki berat badan di bawah normal. Disarankan untuk meningkatkan asupan nutrisi dan konsultasi dengan ahli gizi.';bmiA.style.left=''+(bmi/18.5*20)+'%'}
  else if(bmi<25){cat='Normal';color='#22c55e';advice='Berat badan Anda ideal. Pertahankan pola makan sehat dan olahraga teratur!';bmiA.style.left=''+(20+(bmi-18.5)/6.4*20)+'%'}
  else if(bmi<30){cat='Overweight';color='#f59e0b';advice='Anda memiliki kelebihan berat badan. Disarankan untuk meningkatkan aktivitas fisik dan mengatur pola makan.';bmiA.style.left=''+(40+(bmi-25)/4.9*20)+'%'}
  else if(bmi<35){cat='Obesitas I';color='#f97316';advice='Anda berada dalam kategori obesitas tingkat I. Sangat disarankan untuk berkonsultasi dengan dokter.';bmiA.style.left=''+(60+(bmi-30)/4.9*20)+'%'}
  else{cat='Obesitas II';color='#ef4444';advice='Anda berada dalam kategori obesitas tingkat II. Segera konsultasi dengan dokter untuk penanganan lebih lanjut.';bmiA.style.left='80%'}
  bmiC.textContent=cat;bmiC.style.color=color;
  bmiD.innerHTML='<div class="fw-bold mb-1">Informasi BMI</div><table class="table table-sm small mb-0"><tr><td>BMI</td><td class="fw-bold">'+bmi.toFixed(1)+'</td></tr><tr><td>Kategori</td><td style="color:'+color+';font-weight:600">'+cat+'</td></tr><tr><td>Keterangan</td><td>'+advice+'</td></tr></table>';
}
document.getElementById('btnCalc').addEventListener('click',calc);
[hInp,wInp].forEach(function(el){el.addEventListener('input',calc)});
calc();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>