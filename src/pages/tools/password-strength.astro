---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Password Strength Checker';
const description = 'Cek kekuatan password online. Password strength checker dengan analisis real-time.';
const keywords = 'password strength, password checker, secure password, password analyzer';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#fef2f2;color:#dc2626;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div><div><h1 class="h3 mb-0">Password Strength Checker</h1><p class="text-muted small mb-0">Analisis kekuatan password secara real-time. Data tidak dikirim ke server.</p></div></header>
<div class="row g-4"><div class="col-lg-6">
<div class="card shadow-sm border-0 p-3 mb-3">
<label class="form-label fw-semibold">Masukkan Password</label>
<div class="input-group"><input type="password" id="passwordInput" class="form-control font-mono" placeholder="Ketik password..." value="P4ssw0rd!" autofocus><button id="toggleVis" class="btn btn-outline-secondary" style="font-size:0.7rem">Tampilkan</button></div>
<div class="meter mt-3"><div id="meterBar" class="meter-bar" style="width:0%"></div></div>
<div id="strengthLabel" class="small text-muted mt-1">Masukkan password untuk analisis</div>
</div>
<div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Hasil Analisis</h6>
<div id="analysisResults"></div>
</div></div>
<div class="col-lg-6">
<div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Tips Password Kuat</h6>
<ul class="small mb-0" style="line-height:1.8">
<li>Gunakan minimal <strong>8 karakter</strong>, lebih panjang lebih baik</li>
<li>Kombinasi <strong>huruf besar &amp; kecil</strong></li>
<li>Sertakan <strong>angka</strong> dan <strong>simbol</strong></li>
<li>Hindari kata kamus, nama, tanggal lahir</li>
<li>Gunakan password <strong>unik</strong> untuk setiap akun</li>
<li>Pertimbangkan <strong>password manager</strong></li>
</ul>
</div>
<div class="card shadow-sm border-0 p-3 mt-3">
<h6 class="mb-3">Generator Rekomendasi</h6>
<button id="btnGenerate" class="btn btn-primary mb-2">Buat Password Kuat</button>
<div id="generatedPass" class="font-mono bg-light p-2 rounded small"></div>
</div>
</div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Password Strength Checker</h6><p class="small mb-1" style="line-height:1.6">Password strength checker online untuk menganalisis keamanan kata sandi secara real-time. Alat ini mengevaluasi password berdasarkan berbagai kriteria: panjang karakter, penggunaan huruf besar dan kecil, angka, simbol, dan pola umum. Hasil analisis menampilkan tingkat kekuatan password (sangat lemah, lemah, sedang, kuat, sangat kuat) disertai skor numerik dan saran perbaikan.</p><p class="small mb-0" style="line-height:1.6">Fitur analisis meliputi: deteksi penggunaan karakter berulang, pola keyboard (seperti qwerty atau 12345), kata-kata umum dalam kamus, tanggal lahir, dan informasi personal. Password checker ini juga menampilkan estimasi waktu yang dibutuhkan untuk memecahkan password menggunakan berbagai metode serangan (brute force, dictionary attack, rainbow table). Hasil dapat digunakan sebagai panduan untuk membuat password yang lebih aman.</p><p class="small mb-0 mt-2" style="line-height:1.6">Keamanan password adalah aspek krusial dalam melindungi akun digital Anda. Dengan password strength checker ini, Anda bisa: mengevaluasi keamanan password sebelum digunakan, mempelajari karakteristik password yang kuat, menghindari kesalahan umum dalam pembuatan password, dan meningkatkan kesadaran akan pentingnya keamanan siber. Semua analisis dilakukan di browser, sehingga password Anda tidak pernah dikirim ke server.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="password-generator" class="btn btn-outline-secondary btn-sm rounded-pill">Password Generator</a><a href="hash-generator" class="btn btn-outline-secondary btn-sm rounded-pill">Hash Generator</a><a href="uuid-generator" class="btn btn-outline-secondary btn-sm rounded-pill">UUID Generator</a><a href="qr-generator" class="btn btn-outline-secondary btn-sm rounded-pill">QR Generator</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var inp=document.getElementById('passwordInput'),bar=document.getElementById('meterBar'),label=document.getElementById('strengthLabel'),results=document.getElementById('analysisResults'),vis=document.getElementById('toggleVis');

function analyze(s){
  var score=0,checks=[];
  if(s.length>=8){score+=15;checks.push({pass:true,text:'Minimal 8 karakter ('+s.length+')'})}else{checks.push({pass:false,text:'Minimal 8 karakter (saat ini '+s.length+')'})}
  if(s.length>=12)score+=10;
  if(s.length>=16)score+=10;
  if(/[a-z]/.test(s)&&/[A-Z]/.test(s)){score+=20;checks.push({pass:true,text:'Huruf besar & kecil'})}else{checks.push({pass:false,text:'Tambahkan huruf besar & kecil'})}
  if(/\\d/.test(s)){score+=15;checks.push({pass:true,text:'Mengandung angka'})}else{checks.push({pass:false,text:'Tambahkan angka'})}
  if(/[^a-zA-Z0-9]/.test(s)){score+=20;checks.push({pass:true,text:'Mengandung simbol'})}else{checks.push({pass:false,text:'Tambahkan simbol'})}
  if(/(.)\\1{2,}/.test(s)){score-=10;checks.push({pass:false,text:'Ada karakter berulang 3x+'})}
  if(/^[a-zA-Z]+$/.test(s)||/^\\d+$/.test(s)){score-=10;checks.push({pass:false,text:'Hanya satu tipe karakter'})}
  score=Math.max(0,Math.min(100,score));
  var pct=score+'%';
  var cl='#ef4444',lbl='Sangat Lemah';
  if(score>=80){cl='#22c55e';lbl='Sangat Kuat'}
  else if(score>=60){cl='#16a34a';lbl='Kuat'}
  else if(score>=40){cl='#f59e0b';lbl='Sedang'}
  else if(score>=20){cl='#f97316';lbl='Lemah'}
  bar.style.width=pct;bar.style.background=cl;
  label.innerHTML='<span style="color:'+cl+';font-weight:600">'+lbl+'</span> ('+score+'/100)';
  var html='';
  checks.forEach(function(c){
    html+='<div class="d-flex align-items-center gap-2 mb-1"><span style="color:'+(c.pass?'#22c55e':'#ef4444')+'">'+(c.pass?'&#10003;':'&#10007;')+'</span><span class="small">'+c.text+'</span></div>';
  });
  results.innerHTML=html;
}
inp.addEventListener('input',function(){if(this.value)analyze(this.value);else{bar.style.width='0%';label.textContent='Masukkan password untuk analisis';results.innerHTML=''}});
if(inp.value)analyze(inp.value);
vis.addEventListener('click',function(){var t=inp.type==='password'?'text':'password';inp.type=t;this.textContent=t==='password'?'Tampilkan':'Sembunyikan'});

function genPass(l){var u='ABCDEFGHJKLMNPQRSTUVWXYZ',lw='abcdefghjkmnpqrstuvwxyz',d='23456789',s='!@#$%&*?';var r=function(a){return a[Math.floor(Math.random()*a.length)]};l=l||16;var p='';p+=r(u)+r(lw)+r(d)+r(s);var a=u+lw+d+s;for(var i=p.length;i<l;i++)p+=r(a);p=p.split('').sort(function(){return Math.random()-.5}).join('');return p}
document.getElementById('btnGenerate').addEventListener('click',function(){var p=genPass(20);document.getElementById('generatedPass').textContent=p;inp.value=p;analyze(p)});
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>