---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'CSS Gradient Generator';
const description = 'Buat CSS gradient kustom online. Pilih warna, arah, dan tipe gradient. Preview live & copy CSS.';
const keywords = 'css gradient generator, gradient css, linear gradient, radial gradient, color picker';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0fdf4;color:#16a34a;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 3v18M3 12h18"/></svg></div><div><h1 class="h3 mb-0">CSS Gradient Generator</h1><p class="text-muted small mb-0">Buat gradient CSS kustom dengan preview langsung.</p></div></header>

<div class="row g-4">
<div class="col-lg-4">
  <div class="card shadow-sm border-0 p-3">
    <div class="mb-3">
      <label class="form-label fw-semibold">Tipe</label>
      <select id="gradType" class="form-select">
        <option value="linear">Linear</option>
        <option value="radial">Radial</option>
      </select>
    </div>
    <div class="mb-3" id="directionGroup">
      <label class="form-label fw-semibold">Arah</label>
      <select id="gradDirection" class="form-select">
        <option value="to bottom">Atas ke Bawah</option>
        <option value="to top">Bawah ke Atas</option>
        <option value="to right">Kiri ke Kanan</option>
        <option value="to left">Kanan ke Kiri</option>
        <option value="to bottom right">Diagonal ?</option>
        <option value="to bottom left">Diagonal ?</option>
        <option value="to top right">Diagonal ?</option>
        <option value="to top left">Diagonal ?</option>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Warna 1</label>
      <div class="d-flex align-items-center gap-2">
        <input type="color" id="color1" class="form-control form-control-color" value="#3b82f6">
        <input type="text" id="hex1" class="form-control font-mono" value="#3b82f6" style="max-width:100px;font-size:0.8rem;">
      </div>
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Warna 2</label>
      <div class="d-flex align-items-center gap-2">
        <input type="color" id="color2" class="form-control form-control-color" value="#8b5cf6">
        <input type="text" id="hex2" class="form-control font-mono" value="#8b5cf6" style="max-width:100px;font-size:0.8rem;">
      </div>
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Warna 3 <small class="text-muted">(opsional)</small></label>
      <div class="d-flex align-items-center gap-2">
        <input type="color" id="color3" class="form-control form-control-color" value="#ec4899">
        <input type="text" id="hex3" class="form-control font-mono" value="#ec4899" style="max-width:100px;font-size:0.8rem;">
      </div>
      <div class="form-check mt-1">
        <input type="checkbox" id="useColor3" class="form-check-input" checked>
        <label class="form-check-label" for="useColor3">Gunakan warna ke-3</label>
      </div>
    </div>
  </div>
</div>
<div class="col-lg-8">
  <div class="card shadow-sm border-0 p-3">
    <div id="preview" class="mb-3 rounded" style="height:200px;border:1px solid #ddd;"></div>
    <div class="d-flex justify-content-between align-items-center mb-1">
      <label class="form-label fw-semibold mb-0">CSS Code</label>
      <button id="btnCopy" class="btn btn-sm btn-outline-secondary">Copy</button>
    </div>
    <textarea id="cssOutput" class="form-control font-mono" rows="4" readonly></textarea>
  </div>
</div>
</div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang CSS Gradient Generator</h6><p class="small mb-1" style="line-height:1.6">CSS gradient generator online untuk membuat gradien warna kustom untuk website dan aplikasi. Alat ini memungkinkan Anda membuat linear gradient dan radial gradient dengan antarmuka visual yang intuitif. Anda dapat menambahkan beberapa warna (color stop), mengatur arah gradien, dan melihat preview secara real-time. Kode CSS siap pakai akan dihasilkan secara otomatis.</p><p class="small mb-0" style="line-height:1.6">Fitur gradient generator meliputi: mode linear dan radial gradient, multiple color stops dengan pengaturan posisi, berbagai arah/angle gradien (0-360 derajat, preset: top, bottom, left, right, diagonal), color picker untuk setiap color stop, urutan warna yang bisa di-drag, opsi untuk menambahkan warna intermediate, preview full-size, dan kode CSS yang dapat langsung disalin. Terdapat juga koleksi gradient preset untuk inspirasi cepat.</p><p class="small mb-0 mt-2" style="line-height:1.6">CSS gradient generator sangat berguna bagi frontend developer dan web desainer: membuat background website yang menarik, mendesain tombol dengan efek gradien, membuat banner dan header yang eye-catching, menghasilkan tekstur visual tanpa gambar (mengurangi HTTP request), dan menambahkan kedalaman pada elemen UI. Gradient yang dihasilkan kompatibel dengan semua browser modern dan siap digunakan di production.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="color-picker" class="btn btn-outline-secondary btn-sm rounded-pill">Color Picker</a><a href="contrast-checker" class="btn btn-outline-secondary btn-sm rounded-pill">Contrast Checker</a><a href="css-unit" class="btn btn-outline-secondary btn-sm rounded-pill">CSS Unit Converter</a><a href="html-preview" class="btn btn-outline-secondary btn-sm rounded-pill">HTML Preview</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var color1=document.getElementById('color1'),hex1=document.getElementById('hex1');
var color2=document.getElementById('color2'),hex2=document.getElementById('hex2');
var color3=document.getElementById('color3'),hex3=document.getElementById('hex3');
var use3=document.getElementById('useColor3');
var type=document.getElementById('gradType'),dir=document.getElementById('gradDirection');
var preview=document.getElementById('preview'),output=document.getElementById('cssOutput');

function syncHex(picker,hex){hex.value=picker.value}
function syncPicker(hex,picker){picker.value=hex.value}
color1.addEventListener('input',function(){syncHex(color1,hex1);update();});
color2.addEventListener('input',function(){syncHex(color2,hex2);update();});
color3.addEventListener('input',function(){syncHex(color3,hex3);update();});
hex1.addEventListener('input',function(){syncPicker(hex1,color1);update();});
hex2.addEventListener('input',function(){syncPicker(hex2,color2);update();});
hex3.addEventListener('input',function(){syncPicker(hex3,color3);update();});
use3.addEventListener('change',update);
type.addEventListener('change',function(){document.getElementById('directionGroup').style.display=this.value==='linear'?'block':'none';update();});
dir.addEventListener('change',update);

function update(){
  var c1=color1.value,c2=color2.value,c3=color3.value;
  var css;
  if(type.value==='linear'){
    var d=dir.value;
    if(use3.checked) css='linear-gradient('+d+', '+c1+', '+c2+', '+c3+')';
    else css='linear-gradient('+d+', '+c1+', '+c2+')';
  } else {
    if(use3.checked) css='radial-gradient(circle, '+c1+', '+c2+', '+c3+')';
    else css='radial-gradient(circle, '+c1+', '+c2+')';
  }
  preview.style.background=css;
  output.value='background: '+css+';';
}
update();

document.getElementById('btnCopy').addEventListener('click',function(){
  var b=this;navigator.clipboard.writeText(output.value).then(function(){b.textContent='Copied!';setTimeout(function(){b.textContent='Copy'},1500)});
});
</script>

