---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'QR Code Generator';
const description = 'Buat QR code online gratis. QR code generator untuk URL, teks, dan lainnya. Download PNG.';
const keywords = 'qr code generator, qr generator, buat qr code, qr online';
const bodyHtml = `<div class="row g-4">
        <div class="col-lg-7">
          <div class="card shadow-sm">
            <div class="card-body">
              <form id="qrForm" class="row g-3" onsubmit="return false;">
                <div class="col-12">
                  <label for="qrText" class="form-label">Teks / URL</label>
                  <textarea id="qrText" class="form-control" rows="4" placeholder="https://naufalrakha.my.id atau teks biasa..."></textarea>
                  <div class="form-text">Tip: kamu juga bisa prefill via URL parameter <code>?t=...</code></div>
                </div>

                <div class="col-6 col-md-4">
                  <label for="qrSize" class="form-label">Ukuran</label>
                  <select id="qrSize" class="form-select">
                    <option value="128">128 px</option>
                    <option value="192">192 px</option>
                    <option value="256" selected>256 px</option>
                    <option value="320">320 px</option>
                    <option value="384">384 px</option>
                    <option value="512">512 px</option>
                    <option value="640">640 px</option>
                    <option value="768">768 px</option>
                    <option value="896">896 px</option>
                    <option value="1024">1024 px</option>
                  </select>
                </div>

                <div class="col-6 col-md-4">
                  <label for="qrEcc" class="form-label">Error Correction</label>
                  <select id="qrEcc" class="form-select">
                    <option value="L">L (7%)</option>
                    <option value="M" selected>M (15%)</option>
                    <option value="Q">Q (25%)</option>
                    <option value="H">H (30%)</option>
                  </select>
                </div>

                <div class="col-6 col-md-4">
                  <label for="qrMargin" class="form-label">Margin</label>
                  <select id="qrMargin" class="form-select">
                    <option value="0">0 px</option>
                    <option value="1">1 px</option>
                    <option value="2" selected>2 px</option>
                    <option value="3">3 px</option>
                    <option value="4">4 px</option>
                    <option value="5">5 px</option>
                    <option value="6">6 px</option>
                    <option value="7">7 px</option>
                    <option value="8">8 px</option>
                  </select>
                </div>

                <div class="col-6 col-md-4">
                  <label for="qrFg" class="form-label">Warna Foreground</label>
                  <input type="color" id="qrFg" class="form-control form-control-color" value="#000000" title="Pilih warna kode">
                </div>

                <div class="col-6 col-md-4">
                  <label for="qrBg" class="form-label">Warna Background</label>
                  <input type="color" id="qrBg" class="form-control form-control-color" value="#ffffff" title="Pilih warna latar">
                </div>

                <div class="col-12 d-flex gap-2">
                  <button type="button" id="btnGenerate" class="btn btn-primary">Generate</button>
                  <button type="button" id="btnDownload" class="btn btn-outline-secondary" disabled>Download PNG</button>
                  <button type="button" id="btnSample" class="btn btn-outline-info">Sample</button>
                  <button type="button" id="btnClear" class="btn btn-outline-danger">Clear</button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="col-lg-5">
          <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title">Preview</h5>
              <div id="qrWrap" class="border rounded d-flex align-items-center justify-content-center p-3 bg-white" style="min-height:320px;">
                <div id="qrcode" class="user-select-none"></div>
              </div>
              <div class="small text-muted mt-3">
                Ukuran preview dibatasi max 320px. Unduhan akan sesuai ukuran pilihan kamu.
              </div>
            </div>
          </div>
        </div>
      </div>

      <p class="text-muted small mt-4">
        Catatan: QR code dibuat sepenuhnya di sisi klien (browser). Tidak ada data yang dikirim ke server.
      </p>
    <div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang QR Code Generator</h6><p class="small mb-1" style="line-height:1.6">QR code generator online untuk membuat QR code dari teks, URL, atau data apa pun secara instan. Cukup masukkan teks atau URL, pilih ukuran, level error correction, warna foreground dan background, lalu klik Generate. QR code yang dihasilkan dapat langsung di-download sebagai file PNG dengan resolusi tinggi sesuai ukuran yang dipilih (dari 128px hingga 1024px). QR generator ini berjalan sepenuhnya di sisi klien tanpa mengirim data ke server.</p><p class="small mb-0" style="line-height:1.6">Fitur kustomisasi meliputi pengaturan ukuran QR code (128px hingga 1024px), level error correction (L 7%, M 15%, Q 25%, H 30%), margin, serta warna foreground dan background yang bisa disesuaikan. Level error correction yang lebih tinggi memungkinkan QR code tetap terbaca meskipun sebagian rusak atau tertutup logo. Anda juga bisa me-refresh halaman dengan parameter URL ?t=... untuk prefill teks secara otomatis.</p><p class="small mb-0 mt-2" style="line-height:1.6">QR code memiliki banyak kegunaan praktis dalam kehidupan sehari-hari: membagikan link website, alamat kontak (vCard), koneksi WiFi, pembayaran digital (QRIS), menu restoran digital, tiket event, undangan pernikahan, dan informasi produk. QR code yang dihasilkan bisa di-scan dengan kamera smartphone atau aplikasi QR reader apa pun. Generator ini gratis, tanpa batasan jumlah generate, dan bisa digunakan untuk keperluan pribadi maupun komersial.</p></div>\`n`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="password-generator" class="btn btn-outline-secondary btn-sm rounded-pill">Password Generator</a><a href="uuid-generator" class="btn btn-outline-secondary btn-sm rounded-pill">UUID Generator</a><a href="image-to-base64" class="btn btn-outline-secondary btn-sm rounded-pill">Image to Base64</a><a href="base64-coded" class="btn btn-outline-secondary btn-sm rounded-pill">Base64 Encoder</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent = new Date().getFullYear();
</script>

<script is:inline>
(function(){
  var elText   = document.getElementById('qrText');
  var elSize   = document.getElementById('qrSize');
  var elEcc    = document.getElementById('qrEcc');
  var elMargin = document.getElementById('qrMargin');
  var elFg     = document.getElementById('qrFg');
  var elBg     = document.getElementById('qrBg');
  var elGen    = document.getElementById('btnGenerate');
  var elDl     = document.getElementById('btnDownload');
  var elSample = document.getElementById('btnSample');
  var elClear  = document.getElementById('btnClear');
  var wrap     = document.getElementById('qrcode');
  var wrapOuter= document.getElementById('qrWrap');

  var lastCanvasDataURL = null;

  function clearQR(){
    wrap.innerHTML = '';
    lastCanvasDataURL = null;
    elDl.disabled = true;
  }

  function gen(previewOnly){
    if (previewOnly === undefined) previewOnly = true;
    var text = elText.value.trim();
    if (!text) return;

    clearQR();

    var LEVEL = QRCode.CorrectLevel;
    var chosenLevel = LEVEL[elEcc.value] || LEVEL.M;
    var size = parseInt(elSize.value, 10);
    var previewSize = Math.min(size, 320);

    new QRCode(wrap, {
      text: text,
      width: previewOnly ? previewSize : size,
      height: previewOnly ? previewSize : size,
      colorDark: elFg.value,
      colorLight: elBg.value,
      correctLevel: chosenLevel
    });

    wrapOuter.style.padding = Math.max(0, parseInt(elMargin.value, 10)) + 'px';

    setTimeout(function() {
      var canvas = wrap.querySelector('canvas');
      if (canvas) {
        lastCanvasDataURL = canvas.toDataURL('image/png');
        elDl.disabled = false;
      }
    }, 80);
  }

  function downloadPNG(){
    var text = elText.value.trim();
    if (!text) return;

    var LEVEL = QRCode.CorrectLevel;
    var chosenLevel = LEVEL[elEcc.value] || LEVEL.M;
    var size = parseInt(elSize.value, 10);

    var tempDiv = document.createElement('div');
    new QRCode(tempDiv, {
      text: text,
      width: size,
      height: size,
      colorDark: elFg.value,
      colorLight: elBg.value,
      correctLevel: chosenLevel
    });

    setTimeout(function() {
      var canvas = tempDiv.querySelector('canvas');
      if (canvas) {
        var a = document.createElement('a');
        a.href = canvas.toDataURL('image/png');
        a.download = 'qrcode.png';
        document.body.appendChild(a);
        a.click();
        a.remove();
      }
    }, 100);
  }

  function sample(){
    elText.value = 'https://webapps.naufalrakha.my.id/?ref=qr';
    elSize.value = '320';
    elEcc.value  = 'M';
    elMargin.value = '2';
    elFg.value = '#000000';
    elBg.value = '#ffffff';
    gen();
  }

  function clearAll(){
    elText.value = '';
    clearQR();
    elText.focus();
  }

  (function() {
    var params = new URLSearchParams(location.search);
    var t = params.get('t');
    if (t) {
      elText.value = decodeURIComponent(t);
      gen();
    }
  })();

  elGen.addEventListener('click', function() { gen(true); });
  elDl.addEventListener('click', downloadPNG);
  elSample.addEventListener('click', sample);
  elClear.addEventListener('click', clearAll);

  [elSize, elEcc, elMargin, elFg, elBg].forEach(function(el) {
    el.addEventListener('change', function() { if (elText.value.trim()) gen(); });
  });
})();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
