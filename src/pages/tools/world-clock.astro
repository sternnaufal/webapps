---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'World Clock';
const description = 'World clock online. Lihat waktu saat ini di berbagai zona waktu dunia. WIB, WITA, WIT, UTC, dan lainnya.';
const keywords = 'world clock, timezone converter, waktu dunia, zona waktu, WIB, WITA, WIT';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#fef2f2;color:#dc2626;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div><div><h1 class="h3 mb-0">World Clock</h1><p class="text-muted small mb-0">Lihat waktu saat ini di berbagai zona waktu. Update real-time.</p></div></header>

<div class="row g-4" id="clockGrid">
</div>

<div class="card shadow-sm border-0 p-3 mt-4">
  <div class="row g-2 align-items-end">
    <div class="col-md-4">
      <label class="form-label fw-semibold small">Nama Kota/Zona</label>
      <input type="text" id="newName" class="form-control" placeholder="Contoh: Tokyo" list="tzSuggest">
      <datalist id="tzSuggest">
        <option value="Tokyo"><option value="London"><option value="New York"><option value="Dubai"><option value="Singapore"><option value="Sydney"><option value="Paris"><option value="Seoul"><option value="Mumbai"><option value="Moscow">
      </datalist>
    </div>
    <div class="col-md-3">
      <label class="form-label fw-semibold small">Timezone (IANA)</label>
      <input type="text" id="newTz" class="form-control font-mono" placeholder="Asia/Tokyo" list="tzList">
      <datalist id="tzList">
        <option value="Asia/Jakarta"><option value="Asia/Makassar"><option value="Asia/Jayapura"><option value="Asia/Tokyo"><option value="Asia/Singapore"><option value="Asia/Shanghai"><option value="Asia/Dubai"><option value="Asia/Kolkata"><option value="Europe/London"><option value="Europe/Paris"><option value="Europe/Moscow"><option value="America/New_York"><option value="America/Chicago"><option value="America/Denver"><option value="America/Los_Angeles"><option value="Australia/Sydney"><option value="Pacific/Auckland"><option value="UTC">
      </datalist>
    </div>
    <div class="col-md-3 col-6">
      <label class="form-label fw-semibold small">Offset UTC</label>
      <select id="newOffset" class="form-select">
        <option value="-12">UTC-12</option><option value="-11">UTC-11</option><option value="-10">UTC-10</option><option value="-9">UTC-9</option><option value="-8">UTC-8</option><option value="-7">UTC-7</option><option value="-6">UTC-6</option><option value="-5">UTC-5</option><option value="-4">UTC-4</option><option value="-3">UTC-3</option><option value="-2">UTC-2</option><option value="-1">UTC-1</option><option value="0" selected>UTC+0</option><option value="1">UTC+1</option><option value="2">UTC+2</option><option value="3">UTC+3</option><option value="4">UTC+4</option><option value="5">UTC+5</option><option value="6">UTC+6</option><option value="7">UTC+7</option><option value="8">UTC+8</option><option value="9">UTC+9</option><option value="10">UTC+10</option><option value="11">UTC+11</option><option value="12">UTC+12</option>
      </select>
    </div>
    <div class="col-md-2 col-6">
      <label class="form-label fw-semibold small">&nbsp;</label>
      <button id="btnAdd" class="btn btn-primary w-100">Tambah</button>
    </div>
  </div>
</div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang World Clock</h6><p class="small mb-1" style="line-height:1.6">World clock online untuk menampilkan waktu saat ini dari berbagai zona waktu di seluruh dunia secara real-time. Alat ini menampilkan jam digital untuk kota-kota besar di berbagai benua: Asia (Jakarta, Tokyo, Shanghai, Dubai), Eropa (London, Paris, Berlin, Moskow), Amerika (New York, Los Angeles, Chicago), Australia (Sydney), dan Afrika. Sangat berguna untuk koordinasi meeting internasional, perjalanan, dan komunikasi global.</p><p class="small mb-0" style="line-height:1.6">Setiap zona waktu menampilkan informasi lengkap: nama kota, waktu saat ini (jam:menit:detik), perbedaan waktu relatif terhadap WIB (UTC+7), dan status siang/malam dengan indikator visual. World clock ini juga dilengkapi fitur pencarian kota dan konversi waktu antar zona waktu. Anda bisa menambahkan kota favorit ke daftar yang selalu tampil di atas.</p><p class="small mb-0 mt-2" style="line-height:1.6">World clock sangat membantu dalam berbagai situasi: merencanakan meeting online dengan tim lintas negara, menelepon keluarga atau relasi di luar negeri pada jam yang tepat, merencanakan perjalanan internasional, mengikuti event global seperti webinar atau conference, dan bekerja sebagai freelancer atau remote worker dengan klien dari berbagai negara. Semua data waktu dihitung berdasarkan waktu sistem komputer Anda.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="time-converter" class="btn btn-outline-secondary btn-sm rounded-pill">Time Converter</a><a href="date-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Date Calculator</a><a href="countdown" class="btn btn-outline-secondary btn-sm rounded-pill">Countdown</a><a href="sleep-cycle" class="btn btn-outline-secondary btn-sm rounded-pill">Sleep Cycle</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var defaultClocks=[
  {name:'Jakarta (WIB)',tz:'Asia/Jakarta',offset:7},
  {name:'Makassar (WITA)',tz:'Asia/Makassar',offset:8},
  {name:'Jayapura (WIT)',tz:'Asia/Jayapura',offset:9},
  {name:'UTC',tz:'UTC',offset:0},
  {name:'Tokyo',tz:'Asia/Tokyo',offset:9},
  {name:'London',tz:'Europe/London',offset:1},
  {name:'New York',tz:'America/New_York',offset:-4},
  {name:'Dubai',tz:'Asia/Dubai',offset:4},
];

var clocks=[];

function loadClocks(){
  try{var d=JSON.parse(localStorage.getItem('wc_clocks'));if(d&&d.length)clocks=d;else clocks=defaultClocks;}
  catch(e){clocks=defaultClocks;}
}
function saveClocks(){try{localStorage.setItem('wc_clocks',JSON.stringify(clocks))}catch(e){}}

function formatTime(offset){
  var now=new Date();
  var utc=now.getTime()+now.getTimezoneOffset()*60000;
  var d=new Date(utc+offset*3600000);
  return d.toLocaleString('id-ID',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
}
function formatDate(offset){
  var now=new Date();
  var utc=now.getTime()+now.getTimezoneOffset()*60000;
  var d=new Date(utc+offset*3600000);
  return d.toLocaleDateString('id-ID',{weekday:'long',day:'numeric',month:'short',year:'numeric'});
}

function render(){
  var g=document.getElementById('clockGrid');g.innerHTML='';
  clocks.forEach(function(c,i){
    var col=document.createElement('div');col.className='col-md-3 col-sm-6';
    col.innerHTML='<div class="card shadow-sm border-0 h-100"><div class="card-body text-center d-flex flex-column justify-content-center" style="min-height:140px">'+
      '<div class="fw-bold small text-muted mb-1">'+c.name+'</div>'+
      '<div class="display-6 fw-semibold mb-0" style="font-size:1.8rem;letter-spacing:1px">'+formatTime(c.offset)+'</div>'+
      '<div class="small text-muted mt-1">'+formatDate(c.offset)+'</div>'+
      '<div class="small text-muted">UTC'+(c.offset>=0?'+':'')+c.offset+'</div>'+
      '<button class="btn btn-sm btn-outline-danger mt-2 remove-btn" data-idx="'+i+'" style="font-size:0.7rem">Hapus</button>'+
    '</div></div>';
    g.appendChild(col);
  });
  document.querySelectorAll('.remove-btn').forEach(function(b){
    b.addEventListener('click',function(){
      var idx=parseInt(this.dataset.idx);
      clocks.splice(idx,1);saveClocks();render();
    });
  });
}

loadClocks();render();
setInterval(function(){render()},1000);

document.getElementById('btnAdd').addEventListener('click',function(){
  var name=document.getElementById('newName').value.trim();
  var tz=document.getElementById('newTz').value.trim();
  var offset=parseInt(document.getElementById('newOffset').value);
  if(!name){alert('Nama kota tidak boleh kosong');return;}
  if(!tz){alert('Timezone tidak boleh kosong');return;}
  clocks.push({name:name,tz:tz,offset:offset});
  saveClocks();render();
  document.getElementById('newName').value='';document.getElementById('newTz').value='';
});
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
