---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Sleep Cycle Calculator';
const description = 'Sleep cycle calculator online. Hitung waktu tidur optimal berdasarkan siklus 90 menit. Bangun segar tanpa alarm shock.';
const keywords = 'sleep cycle, sleep calculator, kalkulator tidur, sleep cycle calculator, sleep time, optimal sleep';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#eef2ff;color:#4f46e5;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></div><div><h1 class="h3 mb-0">Sleep Cycle Calculator</h1><p class="text-muted small mb-0">Hitung waktu tidur optimal berdasarkan siklus tidur 90 menit. Bangun di akhir siklus agar segar.</p></div></header>
<div class="row g-4"><div class="col-lg-5">
<div class="card shadow-sm border-0 p-3 mb-3">
<ul class="nav nav-tabs mb-3"><li class="nav-item"><button class="nav-link active" id="tabWake" data-mode="wake">Saya mau bangun jam...</button></li><li class="nav-item"><button class="nav-link" id="tabSleep" data-mode="sleep">Saya mau tidur jam...</button></li></ul>
<div id="wakePane"><label class="form-label fw-semibold">Waktu Bangun</label><input type="time" id="wakeTime" class="form-control" value="06:00">
<small class="text-muted">Kalkulator akan menyarankan waktu tidur optimal</small></div>
<div id="sleepPane" style="display:none"><label class="form-label fw-semibold">Waktu Tidur</label><input type="time" id="sleepTime" class="form-control" value="23:00">
<small class="text-muted">Kalkulator akan menyarankan waktu bangun optimal</small></div>
</div>
<div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Tips Tidur</h6>
<div class="small" style="line-height:1.7">
<p class="mb-1">? Siklus tidur rata-rata 90 menit</p>
<p class="mb-1">? Idealnya tidur 5-6 siklus (7.5-9 jam)</p>
<p class="mb-1">? Bangun di tengah siklus = masih ngantuk</p>
<p class="mb-0">? Butuh ~14 menit untuk tertidur</p>
</div></div>
</div>
<div class="col-lg-7">
<div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Waktu Optimal</h6>
<div id="results" class="small"></div></div>
</div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Sleep Cycle Calculator</h6><p class="small mb-1" style="line-height:1.6">Sleep cycle calculator online untuk menghitung waktu tidur optimal berdasarkan siklus tidur manusia. Siklus tidur berlangsung sekitar 90 menit, dan bangun di tengah siklus (bukan di akhir) dapat menyebabkan rasa lelah dan pusing. Alat ini membantu Anda menentukan waktu tidur atau waktu bangun yang ideal agar bangun dalam keadaan segar di akhir siklus tidur.</p><p class="small mb-0" style="line-height:1.6">Fitur sleep calculator meliputi: dua mode perhitungan -- 'Saya mau bangun jam...' (merekomendasikan waktu tidur) dan 'Saya mau tidur jam...' (merekomendasikan waktu bangun), perhitungan berdasarkan siklus tidur 90 menit dengan 5-6 siklus per malam, waktu yang direkomendasikan untuk mulai tidur (termasuk estimasi 14 menit untuk tertidur), dan penjelasan tentang kualitas tidur berdasarkan jumlah siklus yang dicapai.</p><p class="small mb-0 mt-2" style="line-height:1.6">Sleep cycle calculator membantu Anda: bangun dengan lebih segar dan berenergi, mengurangi efek groggy setelah bangun tidur, mengoptimalkan kualitas istirahat malam, merencanakan jadwal tidur yang konsisten, memahami pentingnya siklus tidur untuk kesehatan, dan meningkatkan produktivitas harian melalui kualitas tidur yang lebih baik. Kalkulator siklus tidur ini didasarkan pada riset ilmiah tentang pola tidur manusia.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="calorie-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Calorie Calculator</a><a href="age-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Age Calculator</a><a href="countdown" class="btn btn-outline-secondary btn-sm rounded-pill">Countdown</a><a href="world-clock" class="btn btn-outline-secondary btn-sm rounded-pill">World Clock</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var wakePane=document.getElementById('wakePane'),sleepPane=document.getElementById('sleepPane'),wakeInp=document.getElementById('wakeTime'),sleepInp=document.getElementById('sleepTime'),res=document.getElementById('results');
document.getElementById('tabWake').addEventListener('click',function(){wakePane.style.display='block';sleepPane.style.display='none';this.classList.add('active');document.getElementById('tabSleep').classList.remove('active');calc();});
document.getElementById('tabSleep').addEventListener('click',function(){wakePane.style.display='none';sleepPane.style.display='block';this.classList.add('active');document.getElementById('tabWake').classList.remove('active');calc();});

function fmt(t){
  var h=t.getHours(),m=t.getMinutes();
  return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0');
}
function fmtLong(t){
  var days=['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
  return days[t.getDay()]+', '+fmt(t);
}

function calc(){
  var mode=wakePane.style.display!=='none'?'wake':'sleep',now=new Date();
  if(mode==='wake'){
    var wp=wakeInp.value.split(':'),wh=parseInt(wp[0]),wm=parseInt(wp[1]);
    var wake=new Date(now);wake.setHours(wh,wm,0,0);if(wake<=now)wake.setDate(wake.getDate()+1);
    var html='<div class="fw-bold mb-3">Jika bangun '+fmt(wake)+':</div><table class="table table-sm small mb-0"><tr class="table-primary"><th>Waktu Tidur</th><th>Siklus</th><th>Keterangan</th></tr>';
    for(var c=6;c>=3;c--){
      var sleep=new Date(wake);sleep.setMinutes(sleep.getMinutes()-c*90-14);
      var desc=c+' siklus ('+(c*90+14)+' menit)';
      var label=c>=5?'? Optimal':c===4?'? Cukup':'? Minimal';
      html+='<tr><td class="fw-bold">'+fmt(sleep)+'</td><td>'+desc+'</td><td>'+label+'</td></tr>';
    }
    html+='</table><div class="small text-muted mt-2">* Termasuk 14 menit untuk tertidur</div>';
    res.innerHTML=html;
  }else{
    var sp=sleepInp.value.split(':'),sh=parseInt(sp[0]),sm=parseInt(sp[1]);
    var sleep=new Date(now);sleep.setHours(sh,sm,0,0);
    var html='<div class="fw-bold mb-3">Jika tidur '+fmt(sleep)+':</div><table class="table table-sm small mb-0"><tr class="table-primary"><th>Waktu Bangun</th><th>Siklus</th><th>Keterangan</th></tr>';
    for(var c=3;c<=6;c++){
      var wake=new Date(sleep);wake.setMinutes(wake.getMinutes()+c*90+14);
      var desc=c+' siklus ('+(c*90+14)+' menit)';
      var label=c>=5?'? Optimal':c===4?'? Cukup':'? Minimal';
      html+='<tr><td class="fw-bold">'+fmt(wake)+' ('+(wake<=now?'besok':'hari ini')+')</td><td>'+desc+'</td><td>'+label+'</td></tr>';
    }
    html+='</table><div class="small text-muted mt-2">* Termasuk 14 menit untuk tertidur</div>';
    res.innerHTML=html;
  }
}
[wakeInp,sleepInp].forEach(function(el){el.addEventListener('input',calc);el.addEventListener('change',calc)});
calc();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>