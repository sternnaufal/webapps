---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'CSS Unit Converter';
const description = 'CSS unit converter online. Konversi px, rem, em, vw, vh, persen, pt, pc, cm, mm, inci.';
const keywords = 'css unit converter, px to rem, px to em, rem to px, css units, responsive design';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0f9ff;color:#0284c7;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg></div><div><h1 class="h3 mb-0">CSS Unit Converter</h1><p class="text-muted small mb-0">Konversi antar unit CSS. Atur basis rem (root) dan viewport untuk hasil akurat.</p></div></header>
<div class="row g-4">
<div class="col-lg-5">
<div class="card shadow-sm border-0 p-3 mb-3">
<div class="mb-3"><label class="form-label fw-semibold">Nilai</label><input type="number" id="inputValue" class="form-control" value="16" step="any"></div>
<div class="mb-3"><label class="form-label fw-semibold">Dari unit</label>
<select id="fromUnit" class="form-select">
<option value="px">px</option><option value="rem" selected>rem</option><option value="em">em</option><option value="vw">vw</option><option value="vh">vh</option><option value="%">%</option><option value="pt">pt</option><option value="pc">pc</option><option value="cm">cm</option><option value="mm">mm</option><option value="in">in</option>
</select></div>
<div class="mb-3"><label class="form-label fw-semibold">Ke unit</label>
<select id="toUnit" class="form-select">
<option value="px" selected>px</option><option value="rem">rem</option><option value="em">em</option><option value="vw">vw</option><option value="vh">vh</option><option value="%">%</option><option value="pt">pt</option><option value="pc">pc</option><option value="cm">cm</option><option value="mm">mm</option><option value="in">in</option>
</select></div>
<hr>
<div class="row g-2">
<div class="col-6"><label class="form-label small">Basis rem (px)</label><input type="number" id="baseRem" class="form-control" value="16" step="any"></div>
<div class="col-6"><label class="form-label small">Viewport width (px)</label><input type="number" id="vpWidth" class="form-control" value="1920" step="any"></div>
<div class="col-6"><label class="form-label small">Viewport height (px)</label><input type="number" id="vpHeight" class="form-control" value="1080" step="any"></div>
<div class="col-6"><label class="form-label small">DPI</label><input type="number" id="dpi" class="form-control" value="96" step="any"></div>
</div>
</div>
</div>
<div class="col-lg-7">
<div class="card shadow-sm border-0 p-3">
<h5 class="fw-semibold mb-3">Hasil Konversi</h5>
<div class="h2 fw-bold mb-3" id="resultValue">1 rem</div>
<div class="table-responsive"><table class="table table-sm small mb-0">
<thead><tr><th>Unit</th><th>Nilai</th></tr></thead>
<tbody id="allResults"></tbody>
</table></div>
</div>
</div>
</div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang CSS Unit Converter</h6><p class="small mb-1" style="line-height:1.6">CSS unit converter online untuk mengkonversi antara berbagai satuan CSS yang umum digunakan dalam web development. Mendukung konversi antara px, rem, em, vw, vh, %, pt, pc, cm, mm, dan in. Alat ini sangat berguna bagi frontend developer dan web desainer yang perlu memastikan konsistensi ukuran dalam desain responsif.</p><p class="small mb-0" style="line-height:1.6">Cara penggunaan: masukkan nilai pada satuan asal, pilih satuan target, dan hasil konversi akan ditampilkan secara real-time. Untuk konversi yang melibatkan rem dan em, Anda dapat mengatur ukuran font dasar (biasanya 16px untuk rem) dan ukuran font parent (untuk em). Untuk satuan viewport (vw, vh), Anda dapat mengatur ukuran viewport referensi. Hasil konversi dapat langsung disalin.</p><p class="small mb-0 mt-2" style="line-height:1.6">CSS unit converter sangat membantu dalam workflow pengembangan web: mengkonversi desain dari Figma/Sketch (px) ke unit relatif (rem, em) untuk aksesibilitas, memastikan ukuran font konsisten di seluruh halaman, menghitung ukuran elemen responsif berbasis viewport, mengkonversi satuan cetak (pt, cm) ke satuan layar (px), dan mengoptimalkan CSS untuk berbagai ukuran layar. Semua perhitungan dilakukan di browser.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="color-picker" class="btn btn-outline-secondary btn-sm rounded-pill">Color Picker</a><a href="gradient-generator" class="btn btn-outline-secondary btn-sm rounded-pill">Gradient Generator</a><a href="html-preview" class="btn btn-outline-secondary btn-sm rounded-pill">HTML Preview</a><a href="contrast-checker" class="btn btn-outline-secondary btn-sm rounded-pill">Contrast Checker</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var inpVal=document.getElementById('inputValue'),fromU=document.getElementById('fromUnit'),toU=document.getElementById('toUnit');
var baseRem=document.getElementById('baseRem'),vpW=document.getElementById('vpWidth'),vpH=document.getElementById('vpHeight'),dpi=document.getElementById('dpi');
var resVal=document.getElementById('resultValue'),allRes=document.getElementById('allResults');

function toPx(val,unit){
  var br=parseFloat(baseRem.value)||16,vw=parseFloat(vpW.value)||1920,vh=parseFloat(vpH.value)||1080,d=parseFloat(dpi.value)||96;
  switch(unit){
    case'px':return val;
    case'rem':case'em':return val*br;
    case'vw':return val*vw/100;
    case'vh':return val*vh/100;
    case'%':return val*vw/100;
    case'pt':return val*d/72;
    case'pc':return val*d/6;
    case'cm':return val*d/2.54;
    case'mm':return val*d/25.4;
    case'in':return val*d;
    default:return val;
  }
}
function fromPx(px,unit){
  var br=parseFloat(baseRem.value)||16,vw=parseFloat(vpW.value)||1920,vh=parseFloat(vpH.value)||1080,d=parseFloat(dpi.value)||96;
  switch(unit){
    case'px':return px;
    case'rem':case'em':return px/br;
    case'vw':return px*100/vw;
    case'vh':return px*100/vh;
    case'%':return px*100/vw;
    case'pt':return px*72/d;
    case'pc':return px*6/d;
    case'cm':return px*2.54/d;
    case'mm':return px*25.4/d;
    case'in':return px/d;
    default:return px;
  }
}

var units=['px','rem','em','vw','vh','%','pt','pc','cm','mm','in'];

function convert(){
  var val=parseFloat(inpVal.value)||0,fu=fromU.value,tu=toU.value;
  var px=toPx(val,fu);
  var result=fromPx(px,tu);
  resVal.textContent=val+' '+fu+' = '+result.toFixed(4)+' '+tu;
  allRes.innerHTML='';
  units.forEach(function(u){
    var v=fromPx(px,u);
    allRes.innerHTML+='<tr'+(u===tu?' class="table-active"':'')+'><td>'+u+'</td><td class="font-mono">'+v.toFixed(4)+'</td></tr>';
  });
}

[inpVal,fromU,toU,baseRem,vpW,vpH,dpi].forEach(function(el){el.addEventListener('input',convert)});
convert();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>