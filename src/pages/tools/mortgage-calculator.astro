---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Mortgage Calculator';
const description = 'Kalkulator KPR (mortgage) online. Hitung cicilan rumah per bulan, total bunga, dan total pembayaran. Mendukung simulasi KPR dengan bunga fixed dan floating.';
const keywords = 'mortgage calculator, kalkulator KPR, kalkulator rumah, cicilan rumah, kredit pemilikan rumah, simulasi KPR';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#ecfdf5;color:#059669;">$</div><div><h1 class="h3 mb-0">Mortgage Calculator</h1><p class="text-muted small mb-0">Hitung estimasi cicilan KPR rumah per bulan.</p></div></header>
<div class="row g-4"><div class="col-lg-7">
<div class="card shadow-sm border-0 p-3">
<div class="row g-3"><div class="col-6"><label class="form-label small fw-semibold">Harga Properti (Rp)</label><input type="number" id="homePrice" class="form-control" value="500000000" min="0" step="1000000"></div>
<div class="col-6"><label class="form-label small fw-semibold">Uang Muka / DP (Rp)</label><input type="number" id="downPayment" class="form-control" value="100000000" min="0" step="1000000"></div></div>
<div class="row g-3 mt-1"><div class="col-6"><label class="form-label small fw-semibold">Bunga (%) per tahun</label><input type="number" id="interestRate" class="form-control" value="8" min="0" max="50" step="0.1"></div>
<div class="col-6"><label class="form-label small fw-semibold">Tenor (tahun)</label><select id="loanTerm" class="form-select"><option>5</option><option>10</option><option selected>15</option><option>20</option><option>25</option><option>30</option></select></div></div>
<button id="btnCalc" class="btn btn-primary w-100 mt-3">Hitung Cicilan</button>
</div>
<div class="card shadow-sm border-0 p-3 mt-3">
<div class="row g-3 text-center"><div class="col-4"><div class="small text-muted">Pinjaman</div><div class="fw-bold" id="loanAmount">Rp 400.000.000</div></div>
<div class="col-4"><div class="small text-muted">Cicilan / Bulan</div><div class="fw-bold fs-5 text-primary" id="monthlyPayment">Rp 3.822.942</div></div>
<div class="col-4"><div class="small text-muted">Total Bunga</div><div class="fw-bold text-danger" id="totalInterest">Rp 288.129.640</div></div></div>
<hr class="my-2">
<div class="row text-center"><div class="col-12"><div class="small text-muted">Total Pembayaran</div><div class="fw-bold" id="totalPayment" style="font-size:1.1rem">Rp 688.129.640</div></div></div>
</div>
</div>
<div class="col-lg-5">
<div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Ringkasan</h6>
<table class="table table-sm small mb-0">
<tr><td>DP</td><td class="text-end fw-bold" id="dpDisplay">20%</td></tr>
<tr><td>Bunga Efektif</td><td class="text-end" id="effRateDisplay">8%</td></tr>
<tr><td>Jumlah Cicilan</td><td class="text-end" id="numPayDisplay">180x</td></tr>
<tr><td>Rasio Cicilan ke Pinjaman</td><td class="text-end" id="ratioDisplay">0.96%</td></tr>
</table>
</div>
</div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Mortgage Calculator</h6><p class="small mb-1" style="line-height:1.6">Mortgage calculator online untuk menghitung estimasi cicilan Kredit Pemilikan Rumah (KPR) atau pinjaman properti lainnya. Alat ini membantu calon pembeli rumah merencanakan keuangan dengan menghitung angsuran bulanan berdasarkan jumlah pinjaman, suku bunga, dan tenor pinjaman. Juga menampilkan rincian pembayaran bunga vs pokok selama masa pinjaman.</p><p class="small mb-0" style="line-height:1.6">Fitur kalkulator KPR ini meliputi: input jumlah pinjaman (Rp), suku bunga per tahun (%), dan tenor (tahun), perhitungan angsuran bulanan (fixed), tabel amortisasi lengkap yang menunjukkan rincian pembayaran pokok dan bunga setiap bulan hingga lunas, total bunga yang dibayarkan selama masa pinjaman, total pembayaran keseluruhan, dan grafik visual perbandingan porsi bunga vs pokok dari waktu ke waktu.</p><p class="small mb-0 mt-2" style="line-height:1.6">Mortgage calculator sangat membantu dalam perencanaan keuangan properti: membandingkan penawaran KPR dari berbagai bank, menentukan tenor yang paling sesuai dengan kemampuan finansial, memahami berapa besar bunga yang akan dibayarkan selama masa pinjaman, merencanakan strategi pelunasan dipercepat, dan menghitung dampak perubahan suku bunga terhadap angsuran bulanan. Kalkulator ini gratis dan informatif.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center"><span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="savings-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Savings Calculator</a><a href="percentage-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Percentage Calculator</a><a href="discount-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Discount Calculator</a><a href="calorie-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Calorie Calculator</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var hp=document.getElementById('homePrice'),dp=document.getElementById('downPayment'),ir=document.getElementById('interestRate'),lt=document.getElementById('loanTerm');
function fmt(x){if(x>=1e12)return'Rp '+(x/1e12).toFixed(1)+' T';return'Rp '+Math.round(x).toLocaleString('id-ID')}
function calc(){
  var h=Math.max(0,parseFloat(hp.value)||0),d=Math.max(0,parseFloat(dp.value)||0),i=Math.max(0,parseFloat(ir.value)||0)/100/12,t=Math.max(1,parseInt(lt.value)||1)*12;
  var loan=Math.max(0,h-d);
  var monthly=i>0?loan*i*Math.pow(1+i,t)/(Math.pow(1+i,t)-1):loan/t;
  var totalPay=monthly*t,totalInt=totalPay-loan;
  document.getElementById('loanAmount').textContent=fmt(loan);
  document.getElementById('monthlyPayment').textContent=fmt(monthly);
  document.getElementById('totalInterest').textContent=fmt(totalInt);
  document.getElementById('totalPayment').textContent=fmt(totalPay);
  document.getElementById('dpDisplay').textContent=h>0?Math.round(d/h*100)+'%':'-';
  document.getElementById('effRateDisplay').textContent=ir.value+'%';
  document.getElementById('numPayDisplay').textContent=t+'x';
  document.getElementById('ratioDisplay').textContent=loan>0?(monthly/loan*100).toFixed(2)+'%':'-';
}
document.getElementById('btnCalc').addEventListener('click',calc);
calc();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>