---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Hash Generator';
const description = 'Generate hash MD5, SHA1, SHA256, SHA512 online. Hash generator gratis untuk developer.';
const keywords = 'hash generator, md5, sha1, sha256, sha512, hash online';
const bodyHtml = `<!-- Navbar khusus mobile -->
      

      

      <!-- Form -->
      <div class="mb-4">
        <div class="mb-3">
          <label for="text" class="form-label">Input Text</label>
          <textarea id="text" rows="3" class="form-control" placeholder="Masukkan teks untuk di-hash"></textarea>
        </div>
        <button type="button" id="generateBtn" class="btn btn-primary">Generate</button>
      </div>

      <!-- Hasil -->
      <div id="results" style="display: none;">
        <div class="card shadow-sm p-3">
          <h5 class="mb-3">Hasil Hash</h5>
          <div class="table-responsive">
            <table class="table table-bordered table-sm align-middle">
              <thead>
                <tr>
                  <th>Algoritma</th>
                  <th>Hash</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody id="hashTable"></tbody>
            </table>
          </div>
        </div>
      </div>
    <div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Hash Generator</h6><p class="small mb-1" style="line-height:1.6">Hash generator online untuk menghasilkan nilai hash dari teks menggunakan berbagai algoritma kriptografi: MD5, SHA-1, SHA-224, SHA-256, SHA-384, SHA-512, SHA3-256, dan SHA3-512. Alat ini sangat berguna bagi developer, security engineer, dan siapa pun yang perlu memverifikasi integritas data, menyimpan password, membuat checksum file, atau bekerja dengan digital signature. Cukup masukkan teks pada kolom input, klik Generate, dan semua varian hash akan ditampilkan sekaligus.</p><p class="small mb-0" style="line-height:1.6">Setiap hasil hash dilengkapi tombol Copy untuk menyalin nilai hash ke clipboard dengan sekali klik. Tabel hasil menampilkan nama algoritma dan nilai hash dalam format heksadesimal yang siap digunakan. Hash generator ini menggunakan library CryptoJS yang terpercaya untuk memastikan akurasi dan kompatibilitas dengan standar industri. Proses hashing dilakukan sepenuhnya di browser menggunakan Web Crypto API, sehingga teks asli Anda tidak pernah dikirim atau disimpan di server mana pun.</p><p class="small mb-0 mt-2" style="line-height:1.6">Kegunaan hash dalam pengembangan perangkat lunak sangat luas: memverifikasi integritas file yang diunduh dari internet, menyimpan password dengan aman di database (setelah ditambahkan salt), membuat checksum untuk backup data, mendeteksi perubahan file, digital signature, dan berbagai aplikasi kriptografi lainnya. Hash generator ini juga mendukung input teks yang panjang dan menampilkan perbandingan panjang hash antar algoritma. Cocok digunakan kapan saja dan di mana saja langsung dari browser.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="uuid-generator" class="btn btn-outline-secondary btn-sm rounded-pill">UUID Generator</a><a href="base64-coded" class="btn btn-outline-secondary btn-sm rounded-pill">Base64 Encoder</a><a href="password-generator" class="btn btn-outline-secondary btn-sm rounded-pill">Password Generator</a><a href="jwt-decoder" class="btn btn-outline-secondary btn-sm rounded-pill">JWT Decoder</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent = new Date().getFullYear();

function generateHashes() {
  const text = document.getElementById('text').value;
  if (!text.trim()) {
    alert('Masukkan teks terlebih dahulu');
    return;
  }

  const hashes = {
    'MD5': CryptoJS.MD5(text).toString(),
    'SHA1': CryptoJS.SHA1(text).toString(),
    'SHA256': CryptoJS.SHA256(text).toString(),
    'SHA512': CryptoJS.SHA512(text).toString(),
  };

  const tbody = document.getElementById('hashTable');
  tbody.innerHTML = '';

  Object.entries(hashes).forEach(([algo, hash]) => {
    const row = document.createElement('tr');
    row.innerHTML = \`
      <td><strong>\${algo}</strong></td>
      <td><code id="hash_\${algo}" style="word-break: break-all;">\${escapeHtml(hash)}</code></td>
      <td>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copyHash('hash_\${algo}')">Copy</button>
      </td>
    \`;
    tbody.appendChild(row);
  });

  document.getElementById('results').style.display = 'block';
}

function copyHash(id) {
  const text = document.getElementById(id).innerText;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector(\`[onclick="copyHash('\${id}')"]\`);
    if (!btn) return;
    const oldText = btn.textContent;
    btn.textContent = '? Copied!';
    setTimeout(() => { btn.textContent = oldText; }, 2000);
  }).catch(() => {
    alert('Gagal menyalin');
  });
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

document.getElementById('generateBtn').addEventListener('click', generateHashes);
document.getElementById('text').addEventListener('keypress', (e) => {
  if (e.key === 'Enter' && e.ctrlKey) {
    generateHashes();
  }
});
</script>

