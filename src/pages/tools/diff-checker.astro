---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Diff Checker';
const description = 'Bandingkan perbedaan dua teks atau file secara online. Diff checker dengan highlight perubahan.';
const keywords = 'diff checker, text diff, compare text, perbedaan teks, diff tool';
const bodyHtml = `<div class="row g-3 mb-3">
        <div class="col-md-6">
          <label for="textA" class="form-label fw-semibold">Original (A)</label>
          <textarea id="textA" class="form-control font-monospace" rows="8" placeholder="Text A...">Hello World
This is line two
Another line here</textarea>
        </div>
        <div class="col-md-6">
          <label for="textB" class="form-label fw-semibold">Modified (B)</label>
          <textarea id="textB" class="form-control font-monospace" rows="8" placeholder="Text B...">Hello World
This is line two modified
Another line here
New line added</textarea>
        </div>
      </div>
      <div class="d-flex gap-2 mb-4">
        <button id="btnDiff" class="btn btn-primary">Compare</button>
        <button id="btnClear" class="btn btn-outline-danger">Clear</button>
      </div>

      <div id="diffOutput" style="display:none;">
        <div class="card shadow-sm">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Diff Result</span>
            <span id="diffStats" class="small text-muted"></span>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="diff-table" id="diffTable"></table>
            </div>
          </div>
        </div>
      </div>
    <div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Diff Checker</h6><p class="small mb-1" style="line-height:1.6">Diff checker online untuk membandingkan dua teks dan menampilkan perbedaannya secara detail. Alat ini sangat berguna bagi developer, penulis, editor, dan siapa pun yang perlu membandingkan dua versi teks untuk menemukan perubahan, penambahan, atau penghapusan. Hasil perbandingan ditampilkan dengan kode warna: hijau untuk teks yang ditambahkan dan merah untuk teks yang dihapus.</p><p class="small mb-0" style="line-height:1.6">Cara penggunaan: tempelkan teks versi pertama di kolom kiri dan teks versi kedua di kolom kanan, lalu klik Compare. Hasil diff akan menampilkan perbedaan baris per baris dengan highlighting yang jelas. Anda juga bisa beralih ke mode unified view yang menggabungkan kedua versi dalam satu tampilan. Tombol navigasi memudahkan berpindah antar perbedaan (next/previous diff).</p><p class="small mb-0 mt-2" style="line-height:1.6">Diff checker memiliki banyak kegunaan: membandingkan versi kode sebelum dan sesudah perubahan, mengecek perubahan dalam file konfigurasi, memvalidasi perubahan konten website, membandingkan output program yang diharapkan dengan aktual, mereview edit teks atau dokumen, dan mendeteksi perubahan dalam data terstruktur. Semua perbandingan dilakukan di browser tanpa mengirim data ke server.</p></div>\`n`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="json-formatter" class="btn btn-outline-secondary btn-sm rounded-pill">JSON Formatter</a><a href="json-csv" class="btn btn-outline-secondary btn-sm rounded-pill">JSON to CSV</a><a href="csv-viewer" class="btn btn-outline-secondary btn-sm rounded-pill">CSV Viewer</a><a href="regex-tester" class="btn btn-outline-secondary btn-sm rounded-pill">Regex Tester</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent = new Date().getFullYear();
</script>

<script is:inline>
function diff(a, b) {
  var linesA = a.split('\\n');
  var linesB = b.split('\\n');
  var m = linesA.length, n = linesB.length;
  var dp = [];
  for (var i = 0; i <= m; i++) { dp[i] = []; dp[i][0] = i; }
  for (var j = 0; j <= n; j++) { dp[0][j] = j; }
  for (var i = 1; i <= m; i++) {
    for (var j = 1; j <= n; j++) {
      var cost = linesA[i - 1] === linesB[j - 1] ? 0 : 1;
      dp[i][j] = Math.min(dp[i - 1][j] + 1, dp[i][j - 1] + 1, dp[i - 1][j - 1] + cost);
    }
  }

  var result = [];
  var i = m, j = n;
  while (i > 0 || j > 0) {
    if (i > 0 && j > 0 && linesA[i - 1] === linesB[j - 1]) {
      result.unshift({ type: 'unchanged', textA: linesA[i - 1], textB: linesB[j - 1], lineA: i, lineB: j });
      i--; j--;
    } else if (j > 0 && (i === 0 || dp[i][j - 1] + 1 <= dp[i - 1][j])) {
      result.unshift({ type: 'added', textA: '', textB: linesB[j - 1], lineA: null, lineB: j });
      j--;
    } else if (i > 0) {
      result.unshift({ type: 'removed', textA: linesA[i - 1], textB: '', lineA: i, lineB: null });
      i--;
    }
  }
  return result;
}

function escapeHtml(s) {
  var div = document.createElement('div');
  div.textContent = s;
  return div.innerHTML;
}

function compare() {
  var a = document.getElementById('textA').value;
  var b = document.getElementById('textB').value;
  var result = diff(a, b);
  var table = document.getElementById('diffTable');
  table.innerHTML = '';
  var added = 0, removed = 0;

  result.forEach(function(row) {
    var tr = document.createElement('tr');
    if (row.type === 'added') {
      tr.className = 'diff-added';
      added++;
      tr.innerHTML = '<td class="line-num"></td><td></td><td class="line-num">' + row.lineB + '</td><td><span class="text-success">+ </span>' + escapeHtml(row.textB) + '</td>';
    } else if (row.type === 'removed') {
      tr.className = 'diff-removed';
      removed++;
      tr.innerHTML = '<td class="line-num">' + row.lineA + '</td><td><span class="text-danger">- </span>' + escapeHtml(row.textA) + '</td><td class="line-num"></td><td></td>';
    } else {
      tr.className = 'diff-unchanged';
      tr.innerHTML = '<td class="line-num">' + row.lineA + '</td><td>' + escapeHtml(row.textA) + '</td><td class="line-num">' + row.lineB + '</td><td>' + escapeHtml(row.textB) + '</td>';
    }
    table.appendChild(tr);
  });

  document.getElementById('diffOutput').style.display = 'block';
  document.getElementById('diffStats').textContent = added + ' added, ' + removed + ' removed, ' + (result.length - added - removed) + ' unchanged';
}

document.getElementById('btnDiff').addEventListener('click', compare);
document.getElementById('btnClear').addEventListener('click', function() {
  document.getElementById('textA').value = '';
  document.getElementById('textB').value = '';
  document.getElementById('diffOutput').style.display = 'none';
});
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
