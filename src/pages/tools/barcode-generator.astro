---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Barcode Generator';
const description = 'Barcode generator online gratis. Buat barcode CODE128, EAN-13, EAN-8, UPC-A, CODE39, ITF-14, Codabar, Pharmacode. Download PNG/SVG.';
const keywords = 'barcode generator, generate barcode, barcode maker, code128, ean13, upc, barcode online gratis';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0f9ff;color:#0369a1;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="4" y1="5" x2="4" y2="19"/><line x1="7" y1="5" x2="7" y2="19"/><line x1="10" y1="5" x2="10" y2="19"/><line x1="13" y1="5" x2="13" y2="19"/><line x1="16" y1="5" x2="16" y2="19"/><line x1="19" y1="5" x2="19" y2="19"/></svg></div><div><h1 class="h3 mb-0">Barcode Generator</h1><p class="text-muted small mb-0">Generate barcode dengan berbagai format. Download PNG/SVG.</p></div></header>

<div class="row g-4">
<div class="col-lg-7">
<div class="card shadow-sm border-0 p-3">
<h6 class="fw-semibold mb-3">Input</h6>
<div class="row g-2 mb-3">
<div class="col-md-8"><label class="form-label small fw-semibold">Nilai</label><input type="text" id="barcodeValue" class="form-control" value="1234567890128" placeholder="Masukkan nilai barcode..."></div>
<div class="col-md-4"><label class="form-label small fw-semibold">Format</label><select id="barcodeFormat" class="form-select">
<option value="CODE128">CODE128 (auto)</option>
<option value="CODE128A">CODE128 A</option>
<option value="CODE128B">CODE128 B</option>
<option value="CODE128C">CODE128 C</option>
<option value="EAN13" selected>EAN-13</option>
<option value="EAN8">EAN-8</option>
<option value="UPC">UPC-A</option>
<option value="UPCE">UPC-E</option>
<option value="CODE39">CODE39</option>
<option value="ITF14">ITF-14</option>
<option value="ITF">ITF</option>
<option value="Codabar">Codabar</option>
<option value="CODE93">CODE93</option>
<option value="MSI">MSI</option>
<option value="pharmacode">Pharmacode</option>
</select></div>
</div>
<div class="opt-row mb-3">
<div><label class="form-label small">Width</label><input type="number" id="barWidth" class="form-control form-control-sm" value="2" min="1" max="10" step="0.5"></div>
<div><label class="form-label small">Height</label><input type="number" id="barHeight" class="form-control form-control-sm" value="80" min="10" max="500"></div>
<div><label class="form-label small">Margin</label><input type="number" id="barMargin" class="form-control form-control-sm" value="10" min="0" max="100"></div>
<div><label class="form-label small">Font Size</label><input type="number" id="barFontSize" class="form-control form-control-sm" value="16" min="6" max="80"></div>
</div>
<div class="opt-row mb-3">
<div><label class="form-label small">Line Color</label><input type="color" id="barLineColor" class="form-control form-control-color form-control-sm" value="#000000"></div>
<div><label class="form-label small">Background</label><input type="color" id="barBgColor" class="form-control form-control-color form-control-sm" value="#ffffff"></div>
<div class="d-flex align-items-end pb-1"><div class="form-check"><input type="checkbox" id="barShowVal" class="form-check-input" checked><label class="form-check-label small" for="barShowVal">Tampilkan teks</label></div></div>
</div>
<button id="btnGenerate" class="btn btn-primary w-100">Generate Barcode</button>
</div>
<div id="barcodeOutput" class="barcode-output card shadow-sm border-0 mt-3">
<svg id="barcodeSvg"></svg>
</div>
<div class="d-flex gap-2 mt-2 flex-wrap">
<button id="btnPng" class="btn btn-outline-primary btn-sm">Download PNG</button>
<button id="btnSvg" class="btn btn-outline-secondary btn-sm">Download SVG</button>
<button id="btnCopy" class="btn btn-outline-secondary btn-sm">Copy Gambar</button>
</div>
</div>
<div class="col-lg-5">
<div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Quick Presets</h6>
<div class="d-flex gap-2 flex-wrap mb-3">
<button class="btn btn-outline-primary btn-sm preset" data-val="9781234567897" data-fmt="EAN13">Buku (EAN-13)</button>
<button class="btn btn-outline-primary btn-sm preset" data-val="4901234567890" data-fmt="EAN13">Produk (EAN-13)</button>
<button class="btn btn-outline-primary btn-sm preset" data-val="12345678" data-fmt="EAN8">Kecil (EAN-8)</button>
<button class="btn btn-outline-primary btn-sm preset" data-val="72527273070" data-fmt="CODE39">CODE39</button>
<button class="btn btn-outline-primary btn-sm preset" data-val="Hello World" data-fmt="CODE128">Teks (CODE128)</button>
<button class="btn btn-outline-primary btn-sm preset" data-val="1234567890128" data-fmt="EAN13">EAN-13</button>
</div>
<div class="small text-muted">Tips: EAN-13 butuh 12-13 digit. CODE128 menerima teks dan angka. Pharmacode hanya angka.</div>
</div>
</div></div>

<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Barcode Generator</h6><p class="small mb-1" style="line-height:1.6">Barcode generator online gratis untuk membuat berbagai jenis barcode langsung di browser. Alat ini mendukung format populer seperti CODE128 (auto, A, B, C), EAN-13, EAN-8, UPC-A, UPC-E, CODE39, ITF-14, ITF, Codabar, CODE93, MSI, dan Pharmacode. Hasil bisa di-download sebagai PNG atau SVG.</p><p class="small mb-0" style="line-height:1.6">Cocok untuk kebutuhan product labeling, inventory management, publishing, retail, dan logistik. Semua proses berjalan di sisi klien — data Anda tidak dikirim ke server mana pun.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center"><span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="qr-generator" class="btn btn-outline-secondary btn-sm rounded-pill">QR Code Generator</a><a href="random-number-generator" class="btn btn-outline-secondary btn-sm rounded-pill">Random Number</a><a href="uuid-generator" class="btn btn-outline-secondary btn-sm rounded-pill">UUID Generator</a><a href="rsa-generator" class="btn btn-outline-secondary btn-sm rounded-pill">RSA Key</a></div>`;
const toolCss = `
    .barcode-output { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 20px; text-align: center; min-height: 160px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
    .barcode-output svg { max-width: 100%; height: auto; }
    .barcode-output .error-msg { color: #ef4444; font-weight: 600; }
    .opt-row { display: flex; flex-wrap: wrap; gap: 10px; }
    .opt-row > * { flex: 1; min-width: 100px; }
    @media (max-width: 576px) { .opt-row > * { min-width: 80px; } }
  `;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
{toolCss}
</style>
<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var valInp=document.getElementById('barcodeValue'),fmtInp=document.getElementById('barcodeFormat');
var wInp=document.getElementById('barWidth'),hInp=document.getElementById('barHeight'),mInp=document.getElementById('barMargin');
var fsInp=document.getElementById('barFontSize'),lcInp=document.getElementById('barLineColor'),bgInp=document.getElementById('barBgColor');
var svInp=document.getElementById('barShowVal'),svgEl=document.getElementById('barcodeSvg'),outDiv=document.getElementById('barcodeOutput');

function getOptions(){
  return {
    format: fmtInp.value,
    width: parseFloat(wInp.value)||2,
    height: parseInt(hInp.value)||80,
    margin: parseInt(mInp.value)||10,
    fontSize: parseInt(fsInp.value)||16,
    lineColor: lcInp.value,
    background: bgInp.value,
    displayValue: svInp.checked
  };
}

function validateInput(val,fmt){
  if(!val){return 'Nilai tidak boleh kosong';}
  if(fmt==='EAN13'||fmt==='EAN13'){if(!/^\\d{12,13}$/.test(val))return 'EAN-13 harus 12-13 digit angka'}
  if(fmt==='EAN8'){if(!/^\\d{7,8}$/.test(val))return 'EAN-8 harus 7-8 digit angka'}
  if(fmt==='UPC'){if(!/^\\d{11,12}$/.test(val))return 'UPC-A harus 11-12 digit angka'}
  if(fmt==='UPCE'){if(!/^\\d{7,8}$/.test(val))return 'UPC-E harus 7-8 digit angka'}
  if(fmt==='ITF14'){if(!/^\\d{13,14}$/.test(val))return 'ITF-14 harus 13-14 digit angka'}
  if(fmt==='pharmacode'){if(!/^\\d+$/.test(val))return 'Pharmacode hanya menerima angka'}
  return null;
}

function generate(){
  var val=valInp.value.trim(),fmt=fmtInp.value;
  var err=validateInput(val,fmt);
  if(err){
    outDiv.innerHTML='<div class="error-msg">'+err+'</div>';
    return;
  }
  outDiv.innerHTML='<svg id="barcodeSvg"></svg>';
  var svg=document.getElementById('barcodeSvg');
  try{
    JsBarcode(svg,val,getOptions());
  }catch(e){
    outDiv.innerHTML='<div class="error-msg">Error: '+e.message+'</div>';
  }
}

document.getElementById('btnGenerate').addEventListener('click',generate);

document.getElementById('btnPng').addEventListener('click',function(){
  var svg=document.getElementById('barcodeSvg');
  if(!svg||!svg.getBBox)return;
  var b=svg.getBBox(),pad=5;
  var c=document.createElement('canvas');
  c.width=b.width+pad*2;c.height=b.height+pad*2;
  var ctx=c.getContext('2d');
  ctx.fillStyle='#ffffff';ctx.fillRect(0,0,c.width,c.height);
  var img=new Image();
  var s=new XMLSerializer();
  var svgStr=s.serializeToString(svg);
  img.onload=function(){
    ctx.drawImage(img,pad,pad);
    c.toBlob(function(blob){
      var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='barcode.png';a.click();
    },'image/png');
  };
  img.src='data:image/svg+xml;base64,'+btoa(unescape(encodeURIComponent(svgStr)));
});

document.getElementById('btnSvg').addEventListener('click',function(){
  var svg=document.getElementById('barcodeSvg');
  if(!svg||!svg.getBBox)return;
  var s=new XMLSerializer(),svgStr=s.serializeToString(svg);
  var a=document.createElement('a');a.href='data:image/svg+xml;base64,'+btoa(unescape(encodeURIComponent(svgStr)));a.download='barcode.svg';a.click();
});

document.getElementById('btnCopy').addEventListener('click',function(){
  var svg=document.getElementById('barcodeSvg');
  if(!svg||!svg.getBBox)return;
  var s=new XMLSerializer(),svgStr=s.serializeToString(svg);
  navigator.clipboard.write([
    new ClipboardItem({'image/svg+xml':new Blob([svgStr],{type:'image/svg+xml'})})
  ]).then(function(){showToast('Gambar disalin ke clipboard');}).catch(function(){showToast('Gagal menyalin');});
});

document.querySelectorAll('.preset').forEach(function(el){el.addEventListener('click',function(){
  valInp.value=this.dataset.val;fmtInp.value=this.dataset.fmt;generate();
})});

function showToast(m){
  var t=document.createElement('div');t.className='toast align-items-center text-bg-light border p-2';
  t.style.position='fixed';t.style.right='20px';t.style.bottom='20px';t.style.zIndex=9999;
  t.innerHTML='<div class="d-flex"><div class="toast-body">'+m+'</div><button type="button" class="btn-close btn-close-white me-2 m-auto" aria-label="Close"></button></div>';
  document.body.appendChild(t);
  t.querySelector('.btn-close').addEventListener('click',function(){t.remove();});
  setTimeout(function(){t.remove();},2500);
}

valInp.addEventListener('keydown',function(e){if(e.key==='Enter')generate()});
generate();
</script>

