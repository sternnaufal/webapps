---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'UUID / GUID Generator';
const description = 'Generate UUID/GUID v4 online gratis. UUID generator dengan satu klik, copy ke clipboard.';
const keywords = 'uuid generator, guid generator, uuid v4, generate uuid, unique id';
const bodyHtml = `<!-- Navbar khusus mobile -->
      

      <header class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex gap-3 align-items-center">
          <div class="tool-icon" style="background:var(--accent-soft);color:var(--accent);"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg></div>
          <div>
            <h1 class="h3 mb-0">UUID / GUID Generator</h1>
            <p class="text-muted small mb-0">Generate UUID v1, v3, v4, v5  pilih quantity dan format (uppercase / braces).</p>
          </div>
        </div>
      </header>

      <form id="uuidForm" onsubmit="return generateUUIDs()" class="row g-3 mb-4">
        <div class="col-md-4">
          <label for="version" class="form-label">Versi UUID</label>
          <select id="version" class="form-select" required>
            <option value="v4" selected>v4 (Random)  direkomendasikan</option>
            <option value="v1">v1 (Time-based)</option>
            <option value="v3">v3 (MD5, namespace+name)</option>
            <option value="v5">v5 (SHA1, namespace+name)</option>
          </select>
        </div>

        <div class="col-md-2">
          <label for="count" class="form-label">Jumlah</label>
          <select id="count" class="form-select">
            <option value="1" selected>1</option>
            <option value="5">5</option>
            <option value="10">10</option>
            <option value="20">20</option>
          </select>
        </div>

        <div class="col-md-3">
          <label for="format" class="form-label">Format</label>
          <div class="d-flex gap-2">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="format_upper">
              <label class="form-check-label" for="format_upper">UPPERCASE</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="format_braces">
              <label class="form-check-label" for="format_braces">{braces}</label>
            </div>
          </div>
        </div>

        <div class="col-md-3" id="nsSection" style="display:none;">
          <label for="namespace" class="form-label">Namespace UUID</label>
          <input type="text" id="namespace" class="form-control" placeholder="6ba7b810-9dad-11d1-80b4-00c04fd430c8">
          <div class="form-text">Default DNS namespace</div>
        </div>

        <div class="col-12">
          <label for="name" class="form-label">Name (untuk v3/v5)</label>
          <input type="text" id="name" class="form-control" placeholder="Name string (mis: example.com)">
        </div>

        <div class="col-12">
          <button type="submit" class="btn btn-info">Generate</button>
          <button type="button" id="btnCopyAll" class="btn btn-outline-secondary ms-2" disabled>Copy All</button>
        </div>
      </form>

      <div id="results"></div>
    <div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang UUID / GUID Generator</h6><p class="small mb-1" style="line-height:1.6">UUID (Universally Unique Identifier) atau GUID (Globally Unique Identifier) generator online untuk membuat identifier unik secara instan. Alat ini mendukung pembuatan UUID versi 1 (berbasis waktu dan MAC address), versi 3 (berbasis namespace MD5), versi 4 (acak), dan versi 5 (berbasis namespace SHA-1). UUID banyak digunakan dalam pengembangan perangkat lunak untuk mengidentifikasi entity secara unik tanpa memerlukan koordinasi terpusat.</p><p class="small mb-0" style="line-height:1.6">Generator ini menyediakan beberapa format output: format standar dengan tanda hubung (xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx), tanpa tanda hubung, huruf besar/kecil, dan format array untuk berbagai bahasa pemrograman. Cukup pilih versi UUID yang diinginkan, atur jumlah yang akan digenerate (hingga 10 sekaligus), dan klik tombol Generate. Hasil dapat disalin satu per satu atau semua sekaligus dengan tombol Copy All.</p><p class="small mb-0 mt-2" style="line-height:1.6">UUID versi 4 berbasis angka acak kriptografis adalah yang paling umum digunakan karena sederhana dan cukup unik untuk hampir semua aplikasi praktis. UUID digunakan sebagai primary key di database, ID sesi pengguna, ID pesanan atau transaksi, ID file atau dokumen, ID perangkat dalam sistem IoT, dan identifier untuk resource dalam REST API. Dengan UUID, risiko tabrakan ID sangat kecil sehingga ideal untuk sistem terdistribusi dan aplikasi skala besar.</p></div>\`n`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="hash-generator" class="btn btn-outline-secondary btn-sm rounded-pill">Hash Generator</a><a href="password-generator" class="btn btn-outline-secondary btn-sm rounded-pill">Password Generator</a><a href="jwt-decoder" class="btn btn-outline-secondary btn-sm rounded-pill">JWT Decoder</a><a href="qr-generator" class="btn btn-outline-secondary btn-sm rounded-pill">QR Generator</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent = new Date().getFullYear();

const NAMESPACES = {
  'dns': '6ba7b810-9dad-11d1-80b4-00c04fd430c8',
  'url': '6ba7b811-9dad-11d1-80b4-00c04fd430c8',
  'oid': '6ba7b812-9dad-11d1-80b4-00c04fd430c8',
  'x500': '6ba7b814-9dad-11d1-80b4-00c04fd430c8'
};

let generatedUUIDs = [];

function uuidV1() {
  const now = Date.now();
  const time = (now + 12219292800000) * 10000 + Math.floor(Math.random() * 10000);
  const timeLow = (time >>> 0).toString(16).padStart(8, '0');
  const timeMid = ((time / 0x100000000) >>> 0).toString(16).padStart(4, '0');
  const timeHiVersion = (((time / 0x1000000000000) >>> 0) & 0x0fff | 0x1000).toString(16).padStart(4, '0');

  const clockSeq = Math.floor(Math.random() * 0x4000);
  const clockSeqHi = (((clockSeq >> 8) & 0x3f) | 0x80).toString(16).padStart(2, '0');
  const clockSeqLow = (clockSeq & 0xff).toString(16).padStart(2, '0');

  const node = Math.floor(Math.random() * 0xffffffffffff).toString(16).padStart(12, '0');

  return \`\${timeLow}-\${timeMid}-\${timeHiVersion}-\${clockSeqHi}\${clockSeqLow}-\${node}\`;
}

function uuidV4() {
  const bytes = new Uint8Array(16);
  crypto.getRandomValues(bytes);
  bytes[6] = (bytes[6] & 0x0f) | 0x40;
  bytes[8] = (bytes[8] & 0x3f) | 0x80;
  const h = Array.from(bytes).map(b => b.toString(16).padStart(2, '0')).join('');
  return \`\${h.slice(0,8)}-\${h.slice(8,12)}-\${h.slice(12,16)}-\${h.slice(16,20)}-\${h.slice(20)}\`;
}

function hexToBinary(hex) {
  const binary = [];
  for (let i = 0; i < hex.length; i += 2) {
    binary.push(parseInt(hex.substr(i, 2), 16));
  }
  return new Uint8Array(binary);
}

function binaryToHex(arr) {
  return Array.from(arr).map(b => b.toString(16).padStart(2, '0')).join('');
}

function uuidFromHash(name, namespace, version) {
  const nsClean = namespace.replace(/[-{}]/g, '');
  if (nsClean.length !== 32) return null;

  const nsBinary = hexToBinary(nsClean);
  const nameBytes = new TextEncoder().encode(name);
  const combined = new Uint8Array(nsBinary.length + nameBytes.length);
  combined.set(nsBinary);
  combined.set(nameBytes, nsBinary.length);

  let hash;
  if (version === 3) {
    hash = CryptoJS.MD5(binaryToHex(combined)).toString();
  } else {
    hash = CryptoJS.SHA1(binaryToHex(combined)).toString();
  }

  const timeLow = hash.substr(0, 8);
  const timeMid = hash.substr(8, 4);
  let timeHiVersion = hash.substr(12, 4);
  let clockSeqHi = hash.substr(16, 2);
  const clockSeqLow = hash.substr(18, 2);
  const node = hash.substr(20, 12);

  timeHiVersion = ((parseInt(timeHiVersion, 16) & 0x0fff) | (version << 12)).toString(16).padStart(4, '0');
  clockSeqHi = ((parseInt(clockSeqHi, 16) & 0x3f) | 0x80).toString(16).padStart(2, '0');

  return \`\${timeLow}-\${timeMid}-\${timeHiVersion}-\${clockSeqHi}\${clockSeqLow}-\${node}\`;
}

function formatUUID(uuid, uppercase, braces) {
  let result = uppercase ? uuid.toUpperCase() : uuid.toLowerCase();
  if (braces) result = '{' + result + '}';
  return result;
}

function generateUUIDs() {
  const version = document.getElementById('version').value;
  const count = Math.min(50, Math.max(1, parseInt(document.getElementById('count').value)));
  const upper = document.getElementById('format_upper').checked;
  const braces = document.getElementById('format_braces').checked;
  const name = document.getElementById('name').value;
  let namespace = document.getElementById('namespace').value.trim();

  if (!namespace) namespace = NAMESPACES.dns;

  generatedUUIDs = [];
  const results = [];

  if ((version === 'v3' || version === 'v5') && name && !isValidNamespace(namespace)) {
    document.getElementById('results').innerHTML = '<div class="alert alert-danger">Namespace tidak valid. Masukkan UUID namespace yang benar.</div>';
    return false;
  }

  for (let i = 0; i < count; i++) {
    let uuid;
    switch (version) {
      case 'v1': uuid = uuidV1(); break;
      case 'v3': uuid = uuidFromHash(name, namespace, 3); break;
      case 'v5': uuid = uuidFromHash(name, namespace, 5); break;
      default: uuid = uuidV4();
    }

    if (!uuid) {
      document.getElementById('results').innerHTML = '<div class="alert alert-danger">Gagal generate UUID. Periksa input Anda.</div>';
      return false;
    }

    const formatted = formatUUID(uuid, upper, braces);
    results.push(formatted);
    generatedUUIDs.push(formatted);
  }

  renderResults(results);
  document.getElementById('btnCopyAll').disabled = false;

  return false;
}

function isValidNamespace(ns) {
  const pattern = /^(\\{)?[0-9a-fA-F]{8}(-)?[0-9a-fA-F]{4}(-)?[0-9a-fA-F]{4}(-)?[0-9a-fA-F]{4}(-)?[0-9a-fA-F]{12}(\\})?$/;
  return pattern.test(ns);
}

function renderResults(uuids) {
  let html = '<div class="card shadow-sm p-3 mb-4"><h5 class="mb-3">Hasil UUID</h5><div class="table-responsive"><table class="table table-sm table-bordered align-middle"><thead class="table-light"><tr><th>#</th><th>UUID</th><th>Aksi</th></tr></thead><tbody>';

  uuids.forEach((uuid, idx) => {
    const id = \`uuid_\${idx}\`;
    html += \`<tr><td>\${idx + 1}</td><td class="uuid-code"><code id="\${id}">\${escapeHtml(uuid)}</code></td><td><button class="btn btn-sm btn-outline-secondary" onclick="copyText('\${id}')">Copy</button></td></tr>\`;
  });

  html += '</tbody></table></div></div>';
  document.getElementById('results').innerHTML = html;
}

function copyText(id) {
  const text = document.getElementById(id).innerText;
  navigator.clipboard.writeText(text).then(() => showToast('Copied to clipboard'));
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function showToast(message) {
  const toast = document.createElement('div');
  toast.className = 'toast align-items-center text-bg-light border p-2 toast-fixed';
  toast.innerHTML = \`<div class="d-flex"><div class="toast-body">\${message}</div><button type="button" class="btn-close btn-close-white me-2 m-auto" aria-label="Close"></button></div>\`;
  document.body.appendChild(toast);
  toast.querySelector('.btn-close').addEventListener('click', () => toast.remove());
  setTimeout(() => toast.remove(), 2200);
}

document.getElementById('version').addEventListener('change', () => {
  const v = document.getElementById('version').value;
  document.getElementById('nsSection').style.display = (v === 'v3' || v === 'v5') ? 'block' : 'none';
});

document.getElementById('btnCopyAll').addEventListener('click', () => {
  if (generatedUUIDs.length === 0) {
    showToast('Tidak ada data untuk disalin');
    return;
  }
  navigator.clipboard.writeText(generatedUUIDs.join('\\n')).then(() => showToast('All UUIDs copied'));
});
</script>

