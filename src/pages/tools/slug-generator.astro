---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Text to Slug Generator';
const description = 'Text to slug generator online. Ubah judul atau teks menjadi URL slug yang SEO friendly. Konversi teks ke slug untuk URL.';
const keywords = 'slug generator, url slug, text to slug, seo slug, slug maker, generate slug, slug converter';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#eff6ff;color:#2563eb;">/</div><div><h1 class="h3 mb-0">Text to Slug Generator</h1><p class="text-muted small mb-0">Ubah teks menjadi URL slug yang SEO friendly. Real-time, instant copy.</p></div></header><div class="row g-4"><div class="col-lg-8"><div class="card shadow-sm border-0 p-3"><div class="mb-3"><label class="form-label fw-semibold small">Masukkan Teks</label><input type="text" id="textInput" class="form-control" value="Cara Membuat Kue Bolu Enak dan Lembut" placeholder="Tulis judul di sini..."></div>
<button id="btnSlugify" class="btn btn-primary mb-3">Buat Slug</button>
<div class="mb-2"><div class="d-flex justify-content-between"><span class="small fw-semibold">Hasil Slug</span><button id="btnCopy" class="btn btn-outline-secondary btn-sm">Copy</button></div><div id="slugResult" class="slug-result mt-1">cara-membuat-kue-bolu-enak-dan-lembut</div></div></div><div class="card shadow-sm border-0 p-3 mt-3"><h6 class="mb-3">Opsi Tambahan</h6>
<div class="form-check mb-2"><input type="checkbox" id="removeStopWords" class="form-check-input"><label class="form-check-label small" for="removeStopWords">Hapus kata umum (dan, di, ke, dari, yang, ini, itu, dengan, untuk, pada, adalah)</label></div>
<div class="d-flex gap-2 flex-wrap"><button class="btn btn-outline-secondary btn-sm example" data-txt="Tips SEO Website 2026">Tips SEO Website 2026</button><button class="btn btn-outline-secondary btn-sm example" data-txt="Cara Memasak Nasi Goreng Spesial">Cara Memasak Nasi Goreng Spesial</button><button class="btn btn-outline-secondary btn-sm example" data-txt="Review: Produk Terbaik Bulan Ini!">Review Produk Terbaik Bulan Ini</button></div>
</div></div><div class="col-lg-4"><div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Contoh Penggunaan Slug</h6><div class="small" style="line-height:2"><p class="mb-1"><strong>Judul Artikel:</strong><br>Cara Membuat Kue Bolu</p><p class="mb-1"><strong>URL Slug:</strong><br><code>cara-membuat-kue-bolu</code></p><p class="mb-1"><strong>URL Lengkap:</strong><br><code>blog.com/cara-membuat-kue-bolu</code></p></div></div></div></div><div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Text to Slug Generator</h6><p class="small mb-1" style="line-height:1.6">Slug generator online untuk mengubah teks biasa menjadi URL slug yang ramah SEO. Slug adalah bagian dari URL yang mengidentifikasi halaman secara unik dan readable, biasanya menggunakan huruf kecil, angka, dan tanda hubung (misal: 'Cara Membuat Website' menjadi 'cara-membuat-website'). Alat ini penting bagi content writer, SEO specialist, dan web developer.</p><p class="small mb-0" style="line-height:1.6">Fitur slug generator meliputi: input teks dengan konversi real-time, pilihan delimiter (tanda hubung atau underscore), opsi lowercase/uppercase, transliterasi otomatis untuk karakter non-ASCII (seperti mengubah '' menjadi 'e' atau '' menjadi 'n'), penghapusan karakter khusus dan tanda baca, penanganan spasi berlebih, deteksi dan penghapusan duplikat delimiter, dan tombol copy untuk menyalin slug yang dihasilkan. Mendukung berbagai bahasa termasuk Indonesia.</p><p class="small mb-0 mt-2" style="line-height:1.6">Slug generator sangat berguna untuk: mengoptimalkan URL artikel blog atau halaman website untuk SEO, membuat URL yang mudah dibaca dan diingat pengguna, mengkonversi judul artikel menjadi slug secara konsisten, mempersiapkan URL untuk CMS atau framework web, dan memastikan format URL seragam di seluruh website. URL slug yang baik meningkatkan click-through rate di hasil pencarian dan membantu Google memahami konten halaman.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center"><span class="small text-muted me-2">Bagikan:</span><a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">&nearr;</a><a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">in</a><a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a></div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="url-encode" class="btn btn-outline-secondary btn-sm rounded-pill">URL Encode</a><a href="textcase" class="btn btn-outline-secondary btn-sm rounded-pill">Text Case</a><a href="html-entity" class="btn btn-outline-secondary btn-sm rounded-pill">HTML Entity</a><a href="regex-tester" class="btn btn-outline-secondary btn-sm rounded-pill">Regex Tester</a></div>`;
const toolCss = `.slug-result{font-family:monospace;font-size:1.4rem;font-weight:600;padding:1rem;border-radius:8px;background:#f0fdf4;color:#16a34a;word-break:break-all}`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
{toolCss}
</style>
<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var inp=document.getElementById('textInput'),sR=document.getElementById('slugResult'),rSW=document.getElementById('removeStopWords');var STOP=['dan','di','ke','dari','yang','ini','itu','dengan','untuk','pada','adalah','dalam','akan','telah','sudah','bisa','dapat','tidak','atau','serta'];function slugify(t,r){t=t.toLowerCase().trim();t=t.replace(/[]/g,'a').replace(/[]/g,'e').replace(/[]/g,'i').replace(/[]/g,'o').replace(/[]/g,'u').replace(/[]/g,'n').replace(/[]/g,'c').replace(/[^a-z0-9\\s-]/g,'').replace(/\\s+/g,' ').trim();if(r){var words=t.split(' ');t=words.filter(function(w){return STOP.indexOf(w)===-1}).join(' ')}t=t.replace(/\\s+/g,'-').replace(/-+/g,'-').replace(/^-|-$/g,'');return t}function makeSlug(){var t=inp.value;sR.textContent=slugify(t,rSW.checked)||'(kosong)'}document.getElementById('btnSlugify').addEventListener('click',makeSlug);document.getElementById('btnCopy').addEventListener('click',function(){navigator.clipboard.writeText(sR.textContent).catch(function(){})});inp.addEventListener('input',makeSlug);rSW.addEventListener('change',makeSlug);document.querySelectorAll('.example').forEach(function(el){el.addEventListener('click',function(){inp.value=this.dataset.txt;makeSlug()})});makeSlug();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>