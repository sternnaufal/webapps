---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Percentage Calculator';
const description = 'Kalkulator persentase online. Hitung persentase, kenaikan, diskon, dan perbandingan.';
const keywords = 'percentage calculator, kalkulator persen, persentase, diskon, kenaikan';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0f9ff;color:#0891b2;">%</div><div><h1 class="h3 mb-0">Percentage Calculator</h1><p class="text-muted small mb-0">Kalkulator persentase dengan 3 mode: hitung persen, cari persentase, dan hitung perubahan.</p></div></header>
<div class="row g-4">
<div class="col-lg-8">
<div class="card shadow-sm border-0 p-3">
<ul class="nav nav-tabs mb-3" id="pctTabs">
<li class="nav-item"><button class="nav-link active" data-mode="mode1">X% dari Y</button></li>
<li class="nav-item"><button class="nav-link" data-mode="mode2">X adalah ?% dari Y</button></li>
<li class="nav-item"><button class="nav-link" data-mode="mode3">Kenaikan/Penurunan</button></li>
</ul>
<div id="mode1" class="tab-pane">
<div class="row g-2 mb-3"><div class="col-4"><label class="form-label small">Persen (%)</label><input type="number" id="m1Pct" class="form-control" value="20"></div><div class="col-4"><label class="form-label small">Dari</label><input type="number" id="m1Val" class="form-control" value="500000"></div><div class="col-4 d-flex align-items-end"><button class="btn btn-primary w-100" data-calc="m1">Hitung</button></div></div>
<div id="m1Result" class="p-3 bg-light rounded small"></div>
</div>
<div id="mode2" class="tab-pane" style="display:none">
<div class="row g-2 mb-3"><div class="col-4"><label class="form-label small">Nilai X</label><input type="number" id="m2X" class="form-control" value="75000"></div><div class="col-4"><label class="form-label small">Dari Y</label><input type="number" id="m2Y" class="form-control" value="500000"></div><div class="col-4 d-flex align-items-end"><button class="btn btn-primary w-100" data-calc="m2">Hitung</button></div></div>
<div id="m2Result" class="p-3 bg-light rounded small"></div>
</div>
<div id="mode3" class="tab-pane" style="display:none">
<div class="row g-2 mb-3"><div class="col-4"><label class="form-label small">Nilai Awal</label><input type="number" id="m3Old" class="form-control" value="500000"></div><div class="col-4"><label class="form-label small">Nilai Akhir</label><input type="number" id="m3New" class="form-control" value="600000"></div><div class="col-4 d-flex align-items-end"><button class="btn btn-primary w-100" data-calc="m3">Hitung</button></div></div>
<div id="m3Result" class="p-3 bg-light rounded small"></div>
</div>
</div>
</div>
<div class="col-lg-4">
<div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Quick Reference</h6>
<div class="small">
<div class="d-flex justify-content-between py-1"><span>10%</span><span class="text-muted">1/10</span></div>
<div class="d-flex justify-content-between py-1"><span>12.5%</span><span class="text-muted">1/8</span></div>
<div class="d-flex justify-content-between py-1"><span>20%</span><span class="text-muted">1/5</span></div>
<div class="d-flex justify-content-between py-1"><span>25%</span><span class="text-muted">1/4</span></div>
<div class="d-flex justify-content-between py-1"><span>33.3%</span><span class="text-muted">1/3</span></div>
<div class="d-flex justify-content-between py-1"><span>50%</span><span class="text-muted">1/2</span></div>
<div class="d-flex justify-content-between py-1"><span>66.7%</span><span class="text-muted">2/3</span></div>
<div class="d-flex justify-content-between py-1"><span>75%</span><span class="text-muted">3/4</span></div>
<div class="d-flex justify-content-between py-1"><span>100%</span><span class="text-muted">1/1</span></div>
</div>
</div>
</div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Percentage Calculator</h6><p class="small mb-1" style="line-height:1.6">Percentage calculator online untuk berbagai perhitungan persentase. Alat ini mendukung tiga jenis perhitungan utama: berapa X% dari Y (misal: 15% dari 200), berapa persen X dari Y (misal: 30 dari 150 = 20%), dan perubahan persentase dari X ke Y (misal: kenaikan 50 ke 75 = 50%). Berguna untuk keperluan keuangan, akademik, dan bisnis sehari-hari.</p><p class="small mb-0" style="line-height:1.6">Fitur kalkulator persentase meliputi: tiga mode perhitungan dalam satu antarmuka yang mudah dipindah, input angka yang responsif, hasil ditampilkan berserta rumus perhitungannya, riwayat perhitungan, opsi pembulatan desimal, dan tombol copy hasil. Setiap mode memiliki label yang jelas sehingga Anda tidak bingung memilih rumus yang tepat. Hasil diperbarui secara real-time.</p><p class="small mb-0 mt-2" style="line-height:1.6">Kalkulator persentase sangat berguna dalam kehidupan sehari-hari: menghitung diskon belanja, menentukan nilai ujian atau tugas (skor yang diperoleh dari total), menghitung kenaikan gaji atau inflasi, menganalisis pertumbuhan bisnis atau penjualan, menghitung komisi atau bonus, menentukan proporsi anggaran, dan membandingkan data statistik. Alat ini sederhana, cepat, dan akurat.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="tip-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Tip Calculator</a><a href="bmi-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">BMI Calculator</a><a href="savings-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Savings Calculator</a><a href="date-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Date Calculator</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
function fmt(n){return n.toLocaleString('id-ID',{maximumFractionDigits:2,minimumFractionDigits:2})}

document.querySelectorAll('#pctTabs .nav-link').forEach(function(tab){
  tab.addEventListener('click',function(){
    document.querySelectorAll('#pctTabs .nav-link').forEach(function(t){t.classList.remove('active')});
    this.classList.add('active');
    document.querySelectorAll('.tab-pane').forEach(function(p){p.style.display='none'});
    document.getElementById(this.dataset.mode).style.display='block';
  });
});

document.querySelectorAll('[data-calc]').forEach(function(btn){
  btn.addEventListener('click',function(){
    var mode=this.dataset.calc,res=document.getElementById(mode+'Result');
    if(mode==='m1'){
      var p=parseFloat(document.getElementById('m1Pct').value)||0,v=parseFloat(document.getElementById('m1Val').value)||0;
      res.innerHTML='<table class="table table-sm small mb-0"><tr><td>'+fmt(p)+'% dari '+fmt(v)+'</td><td class="fw-bold">'+fmt(v*p/100)+'</td></tr><tr><td>Total</td><td class="fw-bold">'+fmt(v+v*p/100)+'</td></tr><tr><td>Diskon (jika diskon '+fmt(p)+'%)</td><td class="text-danger fw-bold">-'+fmt(v*p/100)+'</td></tr></table>';
    }else if(mode==='m2'){
      var x=parseFloat(document.getElementById('m2X').value)||0,y=parseFloat(document.getElementById('m2Y').value)||0;
      var pct=y?x/y*100:0;
      res.innerHTML='<table class="table table-sm small mb-0"><tr><td>'+fmt(x)+' adalah</td><td class="fw-bold">'+fmt(pct)+'%</td></tr><tr><td>dari '+fmt(y)+'</td><td></td></tr></table>';
    }else if(mode==='m3'){
      var o=parseFloat(document.getElementById('m3Old').value)||0,n=parseFloat(document.getElementById('m3New').value)||0;
      var diff=n-o,pct=o?diff/o*100:0;
      res.innerHTML='<table class="table table-sm small mb-0"><tr><td>Perubahan</td><td class="fw-bold'+(diff<0?' text-danger':' text-success')+'">'+(diff>=0?'+':'')+fmt(diff)+'</td></tr><tr><td>Persentase</td><td class="fw-bold'+(pct<0?' text-danger':' text-success')+'">'+(pct>=0?'+':'')+fmt(pct)+'%</td></tr><tr><td>Dari</td><td>'+fmt(o)+' &rarr; '+fmt(n)+'</td></tr></table>';
    }
  });
});
// Trigger initial calculation
document.querySelector('[data-calc="m1"]').click();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>