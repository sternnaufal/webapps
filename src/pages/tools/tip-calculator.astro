---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Tip Calculator';
const description = 'Kalkulator tip online. Hitung tip, bagi bill, dan conversion mata uang.';
const keywords = 'tip calculator, bill splitter, tip, kalkulator tip, bagi tagihan';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0fdf4;color:#16a34a;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div><div><h1 class="h3 mb-0">Tip Calculator</h1><p class="text-muted small mb-0">Hitung tip, bagi bill, dan lihat total per orang.</p></div></header>
<div class="row g-4">
<div class="col-lg-5"><div class="card shadow-sm border-0 p-3">
<div class="mb-3"><label class="form-label fw-semibold">Total Tagihan</label><div class="input-group"><span class="input-group-text">Rp</span><input type="number" id="billInput" class="form-control" value="500000" step="1000"></div></div>
<div class="mb-3"><label class="form-label fw-semibold">Persentase Tip</label>
<div class="d-flex gap-2 flex-wrap" id="tipPresets">
<button class="btn btn-outline-primary btn-sm" data-pct="5">5%</button>
<button class="btn btn-outline-primary btn-sm" data-pct="10">10%</button>
<button class="btn btn-primary btn-sm" data-pct="15">15%</button>
<button class="btn btn-outline-primary btn-sm" data-pct="20">20%</button>
<button class="btn btn-outline-primary btn-sm" data-pct="25">25%</button>
</div>
<div class="mt-2"><input type="range" id="tipRange" class="form-range" min="0" max="50" value="15"><div class="d-flex justify-content-between small text-muted"><span>0%</span><span id="tipLabel">15%</span><span>50%</span></div></div></div>
<div class="mb-3"><label class="form-label fw-semibold">Jumlah Orang</label><div class="input-group"><button id="decPeople" class="btn btn-outline-secondary">-</button><input type="number" id="peopleInput" class="form-control text-center" value="1" min="1" max="100"><button id="incPeople" class="btn btn-outline-secondary">+</button></div></div>
</div></div>
<div class="col-lg-7"><div class="card shadow-sm border-0 p-3">
<h6 class="mb-3">Ringkasan</h6>
<div class="row g-3"><div class="col-6"><div class="p-3 bg-light rounded text-center"><small class="text-muted">Tip</small><div class="h4 mb-0 fw-bold" id="tipAmount">Rp 75.000</div></div></div>
<div class="col-6"><div class="p-3 bg-light rounded text-center"><small class="text-muted">Total + Tip</small><div class="h4 mb-0 fw-bold" id="totalAmount">Rp 575.000</div></div></div>
<div class="col-6"><div class="p-3 bg-light rounded text-center"><small class="text-muted">Per Orang (tip)</small><div class="h4 mb-0 fw-bold" id="tipPerPerson">Rp 75.000</div></div></div>
<div class="col-6"><div class="p-3" style="background:#eef2ff;border-radius:8px;text-align:center"><small class="text-muted">Total Per Orang</small><div class="h4 mb-0 fw-bold" id="totalPerPerson" style="color:var(--accent)">Rp 575.000</div></div></div>
</div>
<div class="mt-3 p-3 bg-light rounded small">
<div id="breakdown"></div>
</div>
</div></div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Tip Calculator</h6><p class="small mb-1" style="line-height:1.6">Tip calculator online untuk menghitung tip (uang pelayanan) dan membagi tagihan secara adil di antara beberapa orang. Alat ini sangat berguna saat makan di restoran, menggunakan jasa layanan (salon, taksi, hotel), atau situasi lain di mana memberi tip adalah kebiasaan. Cukup masukkan total tagihan, persentase tip, dan jumlah orang yang membagi.</p><p class="small mb-0" style="line-height:1.6">Fitur tip calculator meliputi: input total tagihan, slider atau input persentase tip (10%, 15%, 18%, 20% atau kustom), jumlah orang yang membagi tagihan (1-20), perhitungan real-time yang menampilkan jumlah tip per orang dan total per orang, opsi untuk membulatkan ke atas atau ke bawah, dan tampilan ringkasan yang jelas: tagihan awal, total tip, total keseluruhan, jumlah per orang, dan tip per orang.</p><p class="small mb-0 mt-2" style="line-height:1.6">Tip calculator membantu Anda: menghindari kebingungan saat membagi tagihan dengan teman atau kolega, memastikan tip yang diberikan sesuai dengan kualitas layanan, merencanakan anggaran makan di luar, dan bersikap adil dalam pembayaran bersama. Kalkulator tip ini mendukung mata uang Rupiah dan bisa digunakan di restoran, kafe, tempat wisata, dan berbagai situasi sosial lainnya. Perhitungan dilakukan real-time di browser.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="percentage-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Percentage Calculator</a><a href="bmi-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">BMI Calculator</a><a href="savings-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Savings Calculator</a><a href="calorie-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Calorie Calculator</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var bill=document.getElementById('billInput'),tipRange=document.getElementById('tipRange'),tipLabel=document.getElementById('tipLabel'),people=document.getElementById('peopleInput');
function fmt(n){return 'Rp '+Math.round(n).toLocaleString('id-ID')}
function calc(){
  var b=parseFloat(bill.value)||0,p=parseInt(people.value)||1,t=parseFloat(tipRange.value);
  var tip=b*t/100,total=b+tip,tipPP=tip/p,totalPP=total/p;
  document.getElementById('tipAmount').textContent=fmt(tip);
  document.getElementById('totalAmount').textContent=fmt(total);
  document.getElementById('tipPerPerson').textContent=fmt(tipPP);
  document.getElementById('totalPerPerson').textContent=fmt(totalPP);
  document.getElementById('breakdown').innerHTML=
    '<table class="table table-sm small mb-0"><tr><td>Tagihan</td><td class="text-end">'+fmt(b)+'</td></tr>'+
    '<tr><td>Tip ('+t+'%)</td><td class="text-end">'+fmt(tip)+'</td></tr>'+
    '<tr class="fw-bold"><td>Total</td><td class="text-end">'+fmt(total)+'</td></tr>'+
    '<tr><td colspan="2"><hr class="my-1"></td></tr>'+
    '<tr><td>Dibagi '+p+' orang</td><td class="text-end">'+fmt(totalPP)+'/orang</td></tr></table>';
}
bill.addEventListener('input',calc);
tipRange.addEventListener('input',function(){tipLabel.textContent=this.value+'%';calc();});
people.addEventListener('input',calc);
document.getElementById('decPeople').addEventListener('click',function(){people.value=Math.max(1,parseInt(people.value)-1);calc();});
document.getElementById('incPeople').addEventListener('click',function(){people.value=Math.min(100,parseInt(people.value)+1);calc();});
document.querySelectorAll('#tipPresets .btn').forEach(function(b){
  b.addEventListener('click',function(){
    document.querySelectorAll('#tipPresets .btn').forEach(function(x){x.className='btn btn-outline-primary btn-sm'});
    this.className='btn btn-primary btn-sm';
    tipRange.value=this.dataset.pct;tipLabel.textContent=this.dataset.pct+'%';calc();
  });
});
calc();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>