---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'List Sorter';
const description = 'Sort list online. Urutkan daftar teks secara ascending, descending, random, atau by length.';
const keywords = 'list sorter, sort list, urutkan daftar, sort text, alphabetical sorter';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0f9ff;color:#0891b2;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg></div><div><h1 class="h3 mb-0">List Sorter</h1><p class="text-muted small mb-0">Urutkan daftar teks: A-Z, Z-A, acak, by length, hapus duplikat. Satu item per baris.</p></div></header>
<div class="row g-4"><div class="col-lg-6">
<div class="card shadow-sm border-0 p-3">
<div class="mb-3"><label class="form-label fw-semibold">Input (satu item per baris)</label><textarea id="textInput" class="form-control font-mono" rows="8" placeholder="Masukkan daftar, satu per baris..." autofocus>Pisang
Apel
Jeruk
Mangga
Anggur
Durian
Melon
Nanas</textarea></div>
<div class="row g-2 mb-3"><div class="col-6"><label class="form-label small">Mode</label>
<select id="modeSelect" class="form-select"><option value="asc">A-Z (Ascending)</option><option value="desc">Z-A (Descending)</option><option value="length">By Length (Pendek)</option><option value="lengthDesc">By Length (Panjang)</option><option value="random">Acak (Random)</option></select></div>
<div class="col-6"><label class="form-label small">&nbsp;</label>
<div><div class="form-check"><input type="checkbox" id="uniqueOnly" class="form-check-input"><label class="form-check-label small" for="uniqueOnly">Hapus duplikat</label></div>
<div class="form-check"><input type="checkbox" id="ignoreCase" class="form-check-input" checked><label class="form-check-label small" for="ignoreCase">Ignore case</label></div></div></div></div>
<button id="btnSort" class="btn btn-primary w-100">Urutkan</button>
</div></div>
<div class="col-lg-6">
<div class="card shadow-sm border-0 p-3">
<div class="d-flex justify-content-between align-items-center mb-2"><label class="form-label fw-semibold mb-0">Output</label><span id="stats" class="small text-muted"></span></div>
<textarea id="outputArea" class="form-control font-mono" rows="8" readonly></textarea>
<button id="btnCopy" class="btn btn-sm btn-outline-secondary mt-2">Copy</button>
</div></div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang List Sorter</h6><p class="small mb-1" style="line-height:1.6">List sorter online untuk mengurutkan daftar teks dengan cepat. Alat ini menerima daftar item (satu item per baris) dan mengurutkannya berdasarkan berbagai kriteria: ascending (A-Z), descending (Z-A), ascending numerik, descending numerik, berdasarkan panjang karakter, acak (randomize), dan reverse order. Sangat berguna untuk mengatur data dalam format list atau daftar.</p><p class="small mb-0" style="line-height:1.6">Fitur tambahan meliputi: hapus duplikat (remove duplicates), trim spasi berlebih pada setiap baris, ignore case saat sorting, filter baris yang mengandung kata kunci tertentu, dan opsi untuk mengubah delimiter output (baris baru, koma, titik koma, atau pipe). Hasil pengurutan dapat langsung disalin atau di-download sebagai file teks. Jumlah item yang diurutkan juga ditampilkan.</p><p class="small mb-0 mt-2" style="line-height:1.6">List sorter sangat membantu dalam berbagai situasi: mengurutkan daftar nama peserta atau siswa, merapikan daftar belanja, mengatur daftar tugas berdasarkan prioritas, mengurutkan kata kunci untuk SEO, merandomize urutan undian atau giveaway, mengurutkan data ekspor dari spreadsheet, dan mempersiapkan data untuk import ke sistem lain. Alat ini cepat, gratis, dan bekerja offline.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="anagram-finder" class="btn btn-outline-secondary btn-sm rounded-pill">Anagram Finder</a><a href="reverse-text" class="btn btn-outline-secondary btn-sm rounded-pill">Reverse Text</a><a href="json-csv" class="btn btn-outline-secondary btn-sm rounded-pill">JSON to CSV</a><a href="csv-viewer" class="btn btn-outline-secondary btn-sm rounded-pill">CSV Viewer</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var inp=document.getElementById('textInput'),mode=document.getElementById('modeSelect'),out=document.getElementById('outputArea'),stats=document.getElementById('stats'),unique=document.getElementById('uniqueOnly'),ic=document.getElementById('ignoreCase');
function sortList(){
  var lines=inp.value.split('\\n'),origCount=lines.length;
  if(ic.checked){lines=lines.filter(function(l,i,a){return a.findIndex(function(x){return x.toLowerCase()===l.toLowerCase()})===i})}
  else if(unique.checked)lines=lines.filter(function(l,i,a){return a.indexOf(l)===i});
  else lines=lines.filter(function(l){return l!==undefined});
  var m=mode.value;
  if(m==='asc')lines.sort(function(a,b){var x=a.toLowerCase(),y=b.toLowerCase();return x<y?-1:x>y?1:0});
  else if(m==='desc')lines.sort(function(a,b){var x=a.toLowerCase(),y=b.toLowerCase();return x<y?1:x>y?-1:0});
  else if(m==='length')lines.sort(function(a,b){return a.length-b.length});
  else if(m==='lengthDesc')lines.sort(function(a,b){return b.length-a.length});
  else if(m==='random')for(var i=lines.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=lines[i];lines[i]=lines[j];lines[j]=t;}
  out.value=lines.join('\\n');
  stats.textContent=origCount+' item ? '+lines.length+' item';
}
document.getElementById('btnSort').addEventListener('click',sortList);
document.getElementById('btnCopy').addEventListener('click',function(){
  if(!out.value)return;var b=this;
  navigator.clipboard.writeText(out.value).then(function(){b.textContent='Copied!';setTimeout(function(){b.textContent='Copy'},1500)});
});
[inp,mode,unique,ic].forEach(function(el){el.addEventListener('input',sortList);el.addEventListener('change',sortList)});
sortList();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>