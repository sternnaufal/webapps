---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Compound Interest Calculator';
const description = 'Kalkulator bunga majemuk online. Hitung investasi dengan compound interest, proyeksi pertumbuhan, dan tabel tahunan. Simulasi tabungan jangka panjang.';
const keywords = 'compound interest calculator, bunga majemuk, kalkulator investasi, compound interest, proyeksi investasi, future value';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#ecfdf5;color:#059669;">$</div><div><h1 class="h3 mb-0">Compound Interest Calculator</h1><p class="text-muted small mb-0">Hitung pertumbuhan investasi dengan efek bunga majemuk (compound interest).</p></div></header><div class="row g-4"><div class="col-lg-5"><div class="card shadow-sm border-0 p-3"><div class="mb-2"><label class="form-label small fw-semibold">Investasi Awal (Rp)</label><input type="number" id="principal" class="form-control" value="10000000" min="0"></div><div class="mb-2"><label class="form-label small fw-semibold">Setoran Bulanan (Rp)</label><input type="number" id="monthly" class="form-control" value="500000" min="0"></div><div class="row g-2 mb-2"><div class="col-6"><label class="form-label small">Bunga (%/tahun)</label><input type="number" id="rate" class="form-control" value="12" min="0" max="100" step="0.1"></div><div class="col-6"><label class="form-label small">Jangka Waktu (tahun)</label><input type="number" id="years" class="form-control" value="10" min="1" max="100"></div></div><div class="mb-2"><label class="form-label small">Frekuensi Bunga</label><select id="compoundFreq" class="form-select"><option value="1">Tahunan</option><option value="4">Triwulan</option><option value="12" selected>Bulanan</option><option value="365">Harian</option></select></div><button id="btnCalc" class="btn btn-primary w-100">Hitung</button></div></div><div class="col-lg-7"><div class="card shadow-sm border-0 p-3"><div class="row g-2 text-center"><div class="col-4"><div class="small text-muted">Nilai Akhir</div><div class="fw-bold fs-5 text-success" id="futureValue">Rp 0</div></div><div class="col-4"><div class="small text-muted">Total Setoran</div><div class="fw-bold" id="totalDeposits">Rp 0</div></div><div class="col-4"><div class="small text-muted">Total Bunga</div><div class="fw-bold text-primary" id="totalInterest">Rp 0</div></div></div></div><div class="card shadow-sm border-0 p-3 mt-3"><h6 class="mb-2">Tabel Pertumbuhan Tahunan</h6><div id="growthTable" style="max-height:300px;overflow-y:auto;font-size:0.8rem"><table class="table table-sm mb-0"><thead><tr><th>Tahun</th><th>Saldo Awal</th><th>Setoran</th><th>Bunga</th><th>Saldo Akhir</th></tr></thead><tbody id="tableBody"></tbody></table></div></div></div></div><div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Compound Interest Calculator</h6><p class="small mb-1" style="line-height:1.6">Compound interest calculator online untuk menghitung pertumbuhan investasi dengan bunga majemuk. Compound interest (bunga berbunga) adalah konsep di mana bunga yang diperoleh ditambahkan kembali ke pokok investasi, sehingga bunga berikutnya dihitung dari jumlah yang lebih besar. Inilah yang disebut sebagai 'keajaiban bunga majemuk' yang sangat powerful untuk investasi jangka panjang.</p><p class="small mb-0" style="line-height:1.6">Fitur kalkulator ini meliputi: input pokok awal, kontribusi periodik (bulanan/tahunan), suku bunga tahunan, periode investasi, dan frekuensi compounding (tahunan, semesteran, triwulanan, bulanan, atau harian). Hasil menampilkan nilai akhir investasi, total kontribusi, total bunga yang diperoleh, grafik pertumbuhan, dan tabel amortisasi tahunan. Terdapat juga perbandingan dengan simple interest (bunga tunggal) untuk menunjukkan keunggulan compound interest.</p><p class="small mb-0 mt-2" style="line-height:1.6">Compound interest calculator sangat berguna untuk: perencanaan investasi jangka panjang (saham, reksa dana, deposito), perencanaan dana pensiun, simulasi target dana pendidikan anak, memahami efek waktu terhadap pertumbuhan investasi, membandingkan berbagai skenario investasi, dan edukasi keuangan pribadi. Semakin awal Anda mulai berinvestasi, semakin besar efek compound interest yang bisa Anda nikmati.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center"><span class="small text-muted me-2">Bagikan:</span><a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">&nearr;</a><a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">in</a><a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a></div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="savings-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Savings Calculator</a><a href="mortgage-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Mortgage Calculator</a><a href="percentage-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Percentage Calculator</a><a href="discount-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Discount Calculator</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var pInp=document.getElementById('principal'),mInp=document.getElementById('monthly'),rInp=document.getElementById('rate'),yInp=document.getElementById('years'),cF=document.getElementById('compoundFreq'),fV=document.getElementById('futureValue'),tD=document.getElementById('totalDeposits'),tI=document.getElementById('totalInterest'),tB=document.getElementById('tableBody');function fmt(x){return'Rp '+Math.round(x).toLocaleString('id-ID')}function calc(){var p=parseFloat(pInp.value)||0,m=parseFloat(mInp.value)||0,r=parseFloat(rInp.value)||0/100,y=parseInt(yInp.value)||1,n=parseInt(cF.value);var rate=r/n,periods=y*n,future=p*Math.pow(1+rate,periods);if(m>0)future+=m*(Math.pow(1+rate,periods)-1)/rate;var totalDep=p+m*periods,totalInt=future-totalDep;fV.textContent=fmt(future);tD.textContent=fmt(totalDep);tI.textContent=fmt(totalInt);var html='',bal=p;for(var i=1;i<=y;i++){var startBal=bal,yearlyDep=m*12;for(var j=0;j<12;j++)bal=(bal+m)*Math.pow(1+rate,1/12);var yearlyInt=bal-startBal-yearlyDep;html+='<tr><td>'+i+'</td><td>'+fmt(startBal)+'</td><td>'+fmt(yearlyDep)+'</td><td>'+fmt(yearlyInt)+'</td><td class="fw-bold">'+fmt(bal)+'</td></tr>'}tB.innerHTML=html}document.getElementById('btnCalc').addEventListener('click',calc);calc();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>