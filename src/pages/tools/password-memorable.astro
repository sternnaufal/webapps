---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Memorable Password Generator';
const desc = 'Buat password kuat yang mudah diingat. Gabungkan kata-kata acak jadi frasa yang aman tapi mudah diingat.';
const keywords = 'memorable password, password phrase, easy password, word password, xkcd password';
const bodyHtml = '<div class="row g-4">\n  <div class="col-12"><div class="card p-4 text-center mb-3"><div id="mpOut" class="display-5 fw-bold mb-2 font-mono" style="word-break:break-word;font-size:clamp(1.2rem,4vw,2.5rem)">correcthorsebatterystaple</div><div class="d-flex justify-content-center gap-2"><button id="mpGen" class="btn btn-warning rounded-pill px-4">Generate</button><button id="mpCopy" class="btn btn-outline-secondary rounded-pill px-3">Copy</button></div></div></div>\n  <div class="col-md-4"><div class="card p-3 small">\n    <h6 class="fw-semibold mb-2">Settings</h6>\n    <div class="mb-2"><label class="form-label">Words</label><input type="range" id="mpCnt" class="form-range" min="2" max="8" value="4"><div class="d-flex justify-content-between"><span>2</span><span id="mpCntVal">4</span><span>8</span></div></div>\n    <div class="mb-2"><select id="mpSep" class="form-select form-select-sm"><option value="-">Hyphen (-)</option><option value="." selected>Dot (.)</option><option value="_">Underscore (_)</option><option value="">None</option></select></div>\n    <div class="form-check"><input class="form-check-input" type="checkbox" id="mpCap" checked><label class="form-check-label" for="mpCap">Capitalize</label></div>\n    <div class="form-check"><input class="form-check-input" type="checkbox" id="mpNum" checked><label class="form-check-label" for="mpNum">Add number</label></div>\n  </div></div>\n  <div class="col-md-8"><div class="card p-3 small">\n    <h6 class="fw-semibold mb-2">Password Strength</h6>\n    <table class="table table-sm mb-0"><tbody>\n      <tr><td class="text-muted">Panjang</td><td id="mpLen" class="fw-semibold">25</td><td>karakter</td></tr>\n      <tr><td class="text-muted">Entropy</td><td id="mpEnt" class="fw-semibold">44</td><td>bits</td></tr>\n      <tr><td class="text-muted">Kekuatan</td><td id="mpStr" class="fw-semibold text-success">Strong</td><td><span id="mpTime" class="small text-muted">~years</span></td></tr>\n    </tbody></table>\n  </div></div>\n</div>';
---

<ToolLayout title={title} description={desc} keywords={keywords}>
<Fragment set:html={bodyHtml} />
</ToolLayout>

<style is:inline>
.saweria-float{position:fixed;bottom:24px;right:24px;z-index:9999;background:#ff6b6b;color:#fff;border-radius:50px;padding:10px 20px 10px 16px;text-decoration:none;font-size:14px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:0 4px 15px rgba(255,107,107,0.4);transition:all .3s ease;font-family:"Inter",sans-serif}
.saweria-float:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(255,107,107,0.6);color:#fff}
.saweria-float svg{animation:pulse 1.5s ease infinite}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
@media(max-width:576px){.saweria-float{bottom:16px;right:16px;padding:8px 14px 8px 10px;font-size:12px}}
</style>

<script is:inline>
const MPW=["correct","horse","battery","staple","apple","banana","cherry","dragon","eagle","forest","garden","hunter","island","jungle","knight","lemon","mountain","noble","ocean","piano","queen","river","silver","tiger","umbrella","velvet","winter","yellow","zebra","abstract","balance","crystal","diamond","emerald","flame","goblin","horizon","jasmine","kettle","lantern","marble","nebula","orbit","pepper","shadow","thunder","unique","violet","walnut","cactus","dawn","ember","frost","garnet","helix","iris","jade","koala","lunar","mango","nectar","onyx","polar","quest","ruby","solar","topaz","ultra","venus","aurora","bloom","comet","drift","echo","flair","glide","haven","ivory","joker","karma","lime","mellow","novel","olive","prism","rapid","sable","tango","ulna","vivid","wisp","amber","birch","coral","dusk","elm","fawn","gale","haze","kiwi","lark","mint","nova","oak","pine","reed","sage","tide","vale","wren","yarn","zest","acorn","blaze","creek","dune","edge","fern","grove","hollow","kelp","loom","meadow","nook","palm","ridge","spark","thaw","whisper","cedar","delta","ember","flint","gully","harbor","ivy","knoll","lilac","marsh","pearl","rye","shale","tarn","umbra","vine","warp","azure","basin","cove","fjord","geode","haven","isle","knot","loam","musk","nave","opal","slate","talc","vale"];
function mpGen(){const cnt=parseInt(document.getElementById("mpCnt").value);const sep=document.getElementById("mpSep").value;const cap=document.getElementById("mpCap").checked;const num=document.getElementById("mpNum").checked;const sel=[];const used=new Set();while(sel.length<cnt){const w=MPW[Math.floor(Math.random()*MPW.length)];if(!used.has(w)){used.add(w);sel.push(cap?w.charAt(0).toUpperCase()+w.slice(1):w)}}let pwd=sel.join(sep);if(num)pwd+=Math.floor(Math.random()*999);document.getElementById("mpOut").textContent=pwd;document.getElementById("mpLen").textContent=pwd.length;const bits=cnt*Math.log2(MPW.length);document.getElementById("mpEnt").textContent=bits.toFixed(0);const s=document.getElementById("mpStr");if(bits<30){s.textContent="Weak";s.style.color="#ef4444";document.getElementById("mpTime").textContent="instant"}else if(bits<45){s.textContent="Fair";s.style.color="#f59e0b";document.getElementById("mpTime").textContent="~hours"}else if(bits<60){s.textContent="Strong";s.style.color="#10b981";document.getElementById("mpTime").textContent="~years"}else{s.textContent="Very Strong";s.style.color="#059669";document.getElementById("mpTime").textContent="~centuries"}}
document.getElementById("mpGen").onclick=mpGen;document.getElementById("mpCopy").onclick=()=>navigator.clipboard.writeText(document.getElementById("mpOut").textContent);
document.getElementById("mpCnt").oninput=function(){document.getElementById("mpCntVal").textContent=this.value;mpGen()};
document.getElementById("mpSep").onchange=mpGen;document.getElementById("mpCap").onchange=mpGen;document.getElementById("mpNum").onchange=mpGen;mpGen();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all .3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>
