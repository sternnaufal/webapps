---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'JSON ? CSV Converter';
const description = 'Konversi JSON ke CSV dan CSV ke JSON online. Upload file atau paste data.';
const keywords = 'json to csv, csv to json, json converter, csv converter, data converter';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#fefce8;color:#ca8a04;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h12"/></svg></div><div><h1 class="h3 mb-0">JSON ? CSV Converter</h1><p class="text-muted small mb-0">Konversi data antara JSON dan CSV. Upload file atau paste langsung.</p></div></header>
<div class="row g-4 mb-3">
<div class="col-lg-6"><label class="form-label fw-semibold">Input</label>
<textarea id="inputArea" class="form-control font-mono" rows="10" placeholder="Paste JSON atau CSV...">[
  {"nama":"Naufal","usia":25,"kota":"Jakarta","pekerjaan":"Developer"},
  {"nama":"Rakha","usia":28,"kota":"Bandung","pekerjaan":"Designer"},
  {"nama":"Putra","usia":22,"kota":"Surabaya","pekerjaan":"Student"}
]</textarea>
<div class="d-flex gap-2 mt-2 flex-wrap">
<button id="btnToCsv" class="btn btn-primary">JSON ? CSV</button>
<button id="btnToJson" class="btn btn-success">CSV ? JSON</button>
<button id="btnClear" class="btn btn-outline-danger">Clear</button>
<label class="btn btn-outline-secondary mb-0"><input type="file" id="fileInput" accept=".json,.csv" style="display:none">Upload File</label>
</div></div>
<div class="col-lg-6"><div class="d-flex justify-content-between align-items-center mb-1"><label class="form-label fw-semibold mb-0">Output</label><button id="btnCopy" class="btn btn-sm btn-outline-secondary">Copy</button></div>
<textarea id="outputArea" class="form-control font-mono" rows="10" readonly></textarea>
<div class="mt-2"><button id="btnDownload" class="btn btn-sm btn-outline-primary">Download</button></div>
</div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang JSON ? CSV Converter</h6><p class="small mb-1" style="line-height:1.6">JSON to CSV dan CSV to JSON converter online untuk mengkonversi data antara dua format populer secara instan. JSON (JavaScript Object Notation) dan CSV (Comma-Separated Values) adalah dua format data yang banyak digunakan dalam pengembangan aplikasi, analisis data, dan pertukaran informasi antar sistem. Alat ini mendukung array of objects JSON dan berbagai varian CSV.</p><p class="small mb-0" style="line-height:1.6">Fitur konverter ini meliputi: konversi JSON ke CSV dengan header otomatis dari key object, konversi CSV ke JSON array of objects, preview hasil konversi dalam bentuk tabel, opsi delimiter CSV (koma, titik koma, tab), handling nilai null dan nested object, serta tombol copy dan download. Hasil konversi dapat langsung disalin atau di-download sebagai file.</p><p class="small mb-0 mt-2" style="line-height:1.6">JSON ? CSV converter sangat membantu dalam workflow data: mengekspor data API (JSON) ke spreadsheet untuk analisis, mengimpor data dari Excel/Spreadsheet (CSV) ke aplikasi web, migrasi data antar sistem, menyiapkan data untuk machine learning, dan mengolah data untuk reporting. Baik JSON dan CSV adalah format yang ringan, mudah dibaca, dan didukung oleh hampir semua bahasa pemrograman.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="json-formatter" class="btn btn-outline-secondary btn-sm rounded-pill">JSON Formatter</a><a href="yaml-json" class="btn btn-outline-secondary btn-sm rounded-pill">YAML to JSON</a><a href="csv-viewer" class="btn btn-outline-secondary btn-sm rounded-pill">CSV Viewer</a><a href="diff-checker" class="btn btn-outline-secondary btn-sm rounded-pill">Diff Checker</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var inp=document.getElementById('inputArea'),out=document.getElementById('outputArea');
function escapeCSV(v){if(v==null)return '';v=String(v);if(v.includes(',')||v.includes('"')||v.includes('\\n')){v=v.replace(/"/g,'""');v='"'+v+'"'}return v}
function toCSV(){
  try{
    var data=JSON.parse(inp.value);
    if(!Array.isArray(data)||!data.length){out.value='Error: Input harus array JSON';return}
    var headers=Object.keys(data[0]);
    var rows=[headers.join(',')];
    data.forEach(function(row){
      rows.push(headers.map(function(h){return escapeCSV(row[h])}).join(','));
    });
    out.value=rows.join('\\n');
  }catch(e){out.value='Error: '+e.message}
}
function toJSON(){
  try{
    var lines=inp.value.trim().split('\\n');
    if(lines.length<2){out.value='Error: CSV harus punya header + minimal 1 baris data';return}
    var headers=lines[0].split(',').map(function(h){return h.trim()});
    var result=[];
    for(var i=1;i<lines.length;i++){
      if(!lines[i].trim())continue;
      var vals=parseCSVLine(lines[i]);
      if(vals.length!==headers.length)continue;
      var obj={};
      headers.forEach(function(h,j){obj[h]=vals[j]});
      result.push(obj);
    }
    out.value=JSON.stringify(result,null,2);
  }catch(e){out.value='Error: '+e.message}
}
function parseCSVLine(line){
  var result=[],cur='',inQuotes=false;
  for(var i=0;i<line.length;i++){
    var c=line[i];
    if(inQuotes){
      if(c=='"'){if(line[i+1]=='"'){cur+='"';i++}else{inQuotes=false}}
      else cur+=c;
    }else{
      if(c=='"'){inQuotes=true}
      else if(c==','){result.push(cur.trim());cur=''}
      else cur+=c;
    }
  }
  result.push(cur.trim());
  return result;
}
document.getElementById('btnToCsv').addEventListener('click',toCSV);
document.getElementById('btnToJson').addEventListener('click',toJSON);
document.getElementById('btnClear').addEventListener('click',function(){inp.value='';out.value=''});
document.getElementById('btnCopy').addEventListener('click',function(){
  if(!out.value)return;var b=this;
  navigator.clipboard.writeText(out.value).then(function(){b.textContent='Copied!';setTimeout(function(){b.textContent='Copy'},1500)});
});
document.getElementById('fileInput').addEventListener('change',function(e){
  var f=e.target.files[0];if(!f)return;
  var r=new FileReader();
  r.onload=function(){inp.value=r.result};
  r.readAsText(f);
});
document.getElementById('btnDownload').addEventListener('click',function(){
  if(!out.value)return;
  var isCSV=out.value.startsWith('{')||out.value.startsWith('[');
  var blob=new Blob([out.value],{type:isCSV?'application/json':'text/csv'});
  var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='output.'+(isCSV?'json':'csv');a.click();
});
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
