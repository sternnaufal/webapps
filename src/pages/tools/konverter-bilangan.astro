---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Konverter Bilangan';
const description = 'Konversi bilangan biner, oktal, desimal, heksadesimal online gratis. Alat konversi angka lengkap.';
const keywords = 'konverter bilangan, biner, oktal, desimal, heksadesimal, number converter';
const bodyHtml = `<!-- Navbar khusus mobile -->
      

      

      <div class="row g-4">
        <!-- Desimal -->
        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h5 class="card-title">Desimal <span class="badge bg-primary">basis 10</span></h5>
              <div class="input-group mb-2">
                <input id="dec" class="form-control" inputmode="numeric" placeholder="Misal: 1337 atau -42" />
                <button class="btn btn-outline-secondary" data-copy="dec" title="Salin">??</button>
              </div>
              <div class="small text-muted">Karakter valid: 09, opsional tanda minus.</div>
              <div class="mt-2 d-flex justify-content-between">
                <span class="badge bg-secondary" id="decInfo"></span>
              </div>
              <div class="text-danger small mt-1" id="decErr"></div>
            </div>
          </div>
        </div>

        <!-- Hex -->
        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h5 class="card-title">Hexadesimal <span class="badge bg-primary">basis 16</span></h5>
              <div class="input-group mb-2">
                <input id="hex" class="form-control" placeholder="Misal: 1A3F atau -ff" />
                <button class="btn btn-outline-secondary" data-copy="hex" title="Salin">??</button>
              </div>
              <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" id="hexUpper">
                <label class="form-check-label" for="hexUpper">Uppercase</label>
              </div>
              <div class="small text-muted">Karakter valid: 09, af. Gunakan tanda minus untuk negatif.</div>
              <div class="mt-2 d-flex justify-content-between">
                <span class="badge bg-secondary" id="hexInfo"></span>
              </div>
              <div class="text-danger small mt-1" id="hexErr"></div>
            </div>
          </div>
        </div>

        <!-- Biner -->
        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h5 class="card-title">Biner <span class="badge bg-primary">basis 2</span></h5>
              <div class="input-group mb-2">
                <input id="bin" class="form-control" placeholder="Misal: 101010 atau -1111" />
                <button class="btn btn-outline-secondary" data-copy="bin" title="Salin">??</button>
              </div>
              <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" id="binGroup" checked>
                <label class="form-check-label" for="binGroup">Kelompok 4-bit</label>
              </div>
              <div class="small text-muted">Karakter valid: 0 atau 1. Min untuk negatif.</div>
              <div class="mt-2 d-flex justify-content-between">
                <span class="badge bg-secondary" id="binInfo"></span>
              </div>
              <div class="text-danger small mt-1" id="binErr"></div>
            </div>
          </div>
        </div>

        <!-- Oktal -->
        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h5 class="card-title">Oktal <span class="badge bg-primary">basis 8</span></h5>
              <div class="input-group mb-2">
                <input id="oct" class="form-control" placeholder="Misal: 755 atau -17" />
                <button class="btn btn-outline-secondary" data-copy="oct" title="Salin">??</button>
              </div>
              <div class="small text-muted">Karakter valid: 07. Min untuk negatif.</div>
              <div class="mt-2 d-flex justify-content-between">
                <span class="badge bg-secondary" id="octInfo"></span>
              </div>
              <div class="text-danger small mt-1" id="octErr"></div>
            </div>
          </div>
        </div>
      </div>

      <p class="text-muted small mt-4">
        ?? Tip: tekan <kbd>Tab</kbd> untuk berpindah bidang. Semua konversi dilakukan lokal di browser, tanpa internet.
      </p>
    <div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Konverter Bilangan</h6><p class="small mb-1" style="line-height:1.6">Konverter bilangan online untuk mengkonversi angka antar empat sistem bilangan sekaligus: desimal (basis 10), biner (basis 2), oktal (basis 8), dan heksadesimal (basis 16). Alat ini sangat berguna bagi mahasiswa teknik informatika, programmer, network engineer, dan siapa pun yang sedang mempelajari sistem bilangan komputer. Cukup masukkan angka pada salah satu field input, dan semua field lainnya akan terkonversi secara otomatis secara real-time tanpa perlu menekan tombol apa pun.</p><p class="small mb-0" style="line-height:1.6">Kalkulator bilangan ini mendukung bilangan positif dan negatif dengan presisi tinggi menggunakan BigInt, sehingga dapat menangani angka besar tanpa batasan. Fitur tambahan termasuk pengelompokan 4-bit pada bilangan biner untuk memudahkan pembacaan, opsi huruf besar/kecil pada output heksadesimal, serta informasi jumlah digit atau bit dari setiap bilangan yang dimasukkan. Setiap field juga dilengkapi tombol salin untuk menyalin hasil konversi dengan cepat.</p><p class="small mb-0 mt-2" style="line-height:1.6">Konversi bilangan memiliki banyak kegunaan praktis dalam dunia teknologi: membaca dan menulis alamat IPv4 dan IPv6, memahami representasi data dalam memori komputer, melakukan debugging pada level bit, menyelesaikan soal-soal mata kuliah arsitektur komputer dan jaringan, serta bekerja dengan permission file di sistem Linux (755, 644, dll.) yang menggunakan notasi oktal. Semua proses konversi dilakukan sepenuhnya di browser Anda tanpa mengirim data ke server mana pun, sehingga privasi data Anda tetap terjaga.</p></div>\`n`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="roman-numeral" class="btn btn-outline-secondary btn-sm rounded-pill">Roman Numeral</a><a href="unit-converter" class="btn btn-outline-secondary btn-sm rounded-pill">Unit Converter</a><a href="ip-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">IP Calculator</a><a href="subnetting" class="btn btn-outline-secondary btn-sm rounded-pill">Subnetting</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent = new Date().getFullYear();

const el = id => document.getElementById(id);

const RE = {
  dec: /^-?[0-9]+$/i,
  hex: /^-?[0-9a-f]+$/i,
  bin: /^-?[01]+$/,
  oct: /^-?[0-7]+$/
};

function stripGrouping(s){ return s.replace(/\\s+/g, ""); }

function parseToBigInt(str, base){
  let neg = false;
  let s = stripGrouping(String(str).trim());
  if (!s) return null;
  if (s[0] === '-') { neg = true; s = s.slice(1); }
  let bi;
  if (base === 10) {
    bi = BigInt(s);
  } else if (base === 16) {
    bi = BigInt('0x' + s);
  } else if (base === 2) {
    bi = BigInt('0b' + s);
  } else if (base === 8) {
    bi = BigInt('0o' + s);
  } else {
    bi = [...s].reduce((acc, ch)=>{
      const d = parseInt(ch, 36);
      if (Number.isNaN(d) || d >= base) throw new Error('invalid');
      return acc * BigInt(base) + BigInt(d);
    }, 0n);
  }
  return neg ? -bi : bi;
}

function toBaseString(bi, base, {uppercase=false}={}){
  let s = bi.toString(base);
  if (uppercase) s = s.toUpperCase();
  return s;
}

function groupBinary(s){
  const neg = s.startsWith('-');
  if (neg) s = s.slice(1);
  const pad = (4 - (s.length % 4)) % 4;
  s = '0'.repeat(pad) + s;
  const parts = s.match(/.{1,4}/g) || [s];
  const out = parts.join(' ');
  return (neg?'-':'') + out;
}

function setInfo(){
  const dec = el('dec').value.trim();
  const hex = el('hex').value.trim();
  const bin = el('bin').value.trim();
  const oct = el('oct').value.trim();
  el('decInfo').textContent = dec ? \`\${dec.length} digit\` : '';
  el('hexInfo').textContent = hex ? \`\${stripGrouping(hex).length} digit\` : '';
  el('binInfo').textContent = bin ? \`\${stripGrouping(bin).replace(/^-/, '').replace(/\\s+/g,'').length} bit\` : '';
  el('octInfo').textContent = oct ? \`\${stripGrouping(oct).length} digit\` : '';
}

function showError(which, msg){ el(which+'Err').textContent = msg || ''; }
function clearErrors(){ ['dec','hex','bin','oct'].forEach(x=>showError(x,'')); }

let editing = null;

function updateFrom(source){
  if (editing && editing !== source) return;
  editing = source;
  clearErrors();

  const optsUpper = el('hexUpper').checked;
  const optsGroup = el('binGroup').checked;

  const raw = el(source).value.trim();
  const valid = RE[source].test(stripGrouping(raw));

  if (!raw){
    ['dec','hex','bin','oct'].forEach(id=>{ el(id).value=''; });
    setInfo(); editing=null; return;
  }

  if (!valid){
    showError(source, 'Input tidak valid untuk basis ini.');
    editing=null; return;
  }

  try{
    const base = {dec:10, hex:16, bin:2, oct:8}[source];
    const bi = parseToBigInt(raw, base);

    el('dec').value = bi.toString(10);
    el('hex').value = toBaseString(bi, 16, {uppercase: optsUpper});
    let bin = toBaseString(bi, 2);
    el('bin').value = optsGroup ? groupBinary(bin) : bin;
    el('oct').value = toBaseString(bi, 8);
    setInfo();
  } catch(e){
    showError(source, 'Terjadi kesalahan saat konversi.');
  } finally{
    editing=null;
  }
}

['dec','hex','bin','oct'].forEach(id=>{
  el(id).addEventListener('input', ()=>updateFrom(id));
  el(id).addEventListener('blur', setInfo);
});

el('hexUpper').addEventListener('change', ()=>{
  if (el('hex').value.trim()) updateFrom('hex');
});
el('binGroup').addEventListener('change', ()=>{
  if (el('bin').value.trim()) updateFrom('bin');
  else if (el('dec').value.trim()) updateFrom('dec');
});

document.querySelectorAll('[data-copy]').forEach(btn=>{
  btn.addEventListener('click', async ()=>{
    const id = btn.getAttribute('data-copy');
    const val = el(id).value;
    if (!val) return;
    try{ await navigator.clipboard.writeText(val); btn.textContent='?'; setTimeout(()=>btn.textContent='??', 900); }
    catch{ btn.textContent='?'; setTimeout(()=>btn.textContent='??', 900); }
  });
});

el('btnClear').addEventListener('click', ()=>{
  ['dec','hex','bin','oct'].forEach(id=>el(id).value='');
  clearErrors(); setInfo(); el('dec').focus();
});

el('btnSample').addEventListener('click', ()=>{
  el('hexUpper').checked = true; el('binGroup').checked = true;
  el('dec').value = '2025'; updateFrom('dec');
});

setInfo();
</script>

