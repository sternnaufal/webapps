---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Image Resizer & Compressor';
const desc = 'Resize dan kompres gambar online. Ubah ukuran, kualitas, dan format gambar tanpa upload ke server.';
const keywords = 'image resizer, resize image, compress image, image optimizer, ubah ukuran gambar';
const bodyHtml = '<div class="row g-4">\n  <div class="col-12">\n    <div id="irDrop" class="card p-5 text-center" style="border:2px dashed #ccc;border-radius:12px;cursor:pointer"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5" class="mb-2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg><p class="mb-1 fw-semibold">Drop gambar di sini atau klik untuk upload</p><p class="small text-muted mb-0">JPG, PNG, WebP, GIF, BMP</p><input type="file" id="irFile" accept="image/*" style="display:none"></div>\n  </div>\n  <div id="irPanels" style="display:none" class="col-12">\n    <div class="row g-4">\n      <div class="col-md-4"><div class="card p-2 text-center"><label class="form-label small fw-semibold">Original</label><img id="irOrig" style="max-width:100%;max-height:150px" class="rounded"><div class="small text-muted mt-1"><span id="irOrigSize">0</span> KB</div></div></div>\n      <div class="col-md-4"><div class="card p-2 text-center"><label class="form-label small fw-semibold">Preview</label><img id="irPrev" style="max-width:100%;max-height:150px" class="rounded"><div class="small text-muted mt-1"><span id="irNewSize">0</span> KB <span id="irSaved" class="text-success ms-1"></span></div></div></div>\n      <div class="col-md-4"><div class="card p-3 small">\n        <h6 class="fw-semibold mb-2">Settings</h6>\n        <div class="mb-2"><label class="form-label">Width (px)</label><input type="number" id="irW" class="form-control form-control-sm" value="800" min="1"></div>\n        <div class="mb-2"><label class="form-label">Height (px, 0=auto)</label><input type="number" id="irH" class="form-control form-control-sm" value="0" min="0"></div>\n        <div class="mb-2"><label class="form-label">Quality <span id="irQVal">80%</span></label><input type="range" id="irQ" class="form-range" min="10" max="100" value="80"></div>\n        <div class="mb-2"><select id="irFmt" class="form-select form-select-sm"><option value="image/png">PNG</option><option value="image/jpeg" selected>JPEG</option><option value="image/webp">WebP</option></select></div>\n        <div class="form-check mb-2"><input class="form-check-input" type="checkbox" id="irRatio" checked><label class="form-check-label small" for="irRatio">Keep ratio</label></div>\n        <button id="irApply" class="btn btn-warning btn-sm w-100">Apply</button>\n        <a id="irDl" class="btn btn-outline-secondary btn-sm w-100 mt-1" download="resized.png">Download</a>\n      </div></div>\n    </div>\n  </div>\n</div>';
---

<ToolLayout title={title} description={desc} keywords={keywords}>
<Fragment set:html={bodyHtml} />
</ToolLayout>

<style is:inline>
.saweria-float{position:fixed;bottom:24px;right:24px;z-index:9999;background:#ff6b6b;color:#fff;border-radius:50px;padding:10px 20px 10px 16px;text-decoration:none;font-size:14px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:0 4px 15px rgba(255,107,107,0.4);transition:all .3s ease;font-family:"Inter",sans-serif}
.saweria-float:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(255,107,107,0.6);color:#fff}
.saweria-float svg{animation:pulse 1.5s ease infinite}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
@media(max-width:576px){.saweria-float{bottom:16px;right:16px;padding:8px 14px 8px 10px;font-size:12px}}
</style>

<script is:inline>
let irFileObj=null;const dz=document.getElementById("irDrop");dz.onclick=()=>document.getElementById("irFile").click();dz.ondragover=e=>{e.preventDefault();dz.style.borderColor="#6366f1";dz.style.background="rgba(99,102,241,.05)"};dz.ondragleave=()=>{dz.style.borderColor="#ccc";dz.style.background=""};dz.ondrop=e=>{e.preventDefault();dz.style.borderColor="#ccc";dz.style.background="";const f=e.dataTransfer.files[0];if(f&&f.type.startsWith("image/"))irLoad(f)};
document.getElementById("irFile").onchange=e=>{if(e.target.files[0])irLoad(e.target.files[0])};
document.getElementById("irQ").oninput=function(){document.getElementById("irQVal").textContent=this.value+"%"};
document.getElementById("irApply").onclick=irResize;
document.getElementById("irW").oninput=function(){if(document.getElementById("irRatio").checked&&irFileObj){const img=new Image();img.onload=()=>{document.getElementById("irH").value=Math.round(img.naturalHeight*(parseInt(document.getElementById("irW").value)||0)/img.naturalWidth)};img.src=URL.createObjectURL(irFileObj)}}
document.getElementById("irFmt").onchange=e=>{document.getElementById("irDl").download="resized."+e.target.value.split("/")[1]};
function irLoad(f){irFileObj=f;const r=new FileReader();r.onload=function(e){document.getElementById("irOrig").src=e.target.result;document.getElementById("irOrigSize").textContent=(f.size/1024).toFixed(1);document.getElementById("irPanels").style.display="";const img=new Image();img.onload=function(){document.getElementById("irW").value=img.naturalWidth;document.getElementById("irH").value=img.naturalHeight};img.src=e.target.result};r.readAsDataURL(f)}
function irResize(){if(!irFileObj)return;const w=parseInt(document.getElementById("irW").value)||0;const h=parseInt(document.getElementById("irH").value)||0;const q=parseInt(document.getElementById("irQ").value)/100;const fmt=document.getElementById("irFmt").value;const img=new Image();img.onload=function(){const c=document.createElement("canvas");c.width=w;c.height=h||Math.round(img.naturalHeight*(w/img.naturalWidth));const ctx=c.getContext("2d");ctx.imageSmoothingQuality="high";ctx.drawImage(img,0,0,c.width,c.height);c.toBlob(function(b){const url=URL.createObjectURL(b);document.getElementById("irPrev").src=url;document.getElementById("irNewSize").textContent=(b.size/1024).toFixed(1);const svd=((irFileObj.size-b.size)/irFileObj.size*100).toFixed(1);document.getElementById("irSaved").textContent=svd>0?"-"+svd+"%":"+"+svd+"%";const dl=document.getElementById("irDl");dl.href=url},fmt,q)};img.src=URL.createObjectURL(irFileObj)}
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all .3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>
