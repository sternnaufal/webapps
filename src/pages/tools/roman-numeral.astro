<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
function toRoman(n){
  if(n<1||n>3999)return '';
  var vals=[1000,900,500,400,100,90,50,40,10,9,5,4,1],nums=['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I'],r='';
  for(var i=0;i<vals.length;i++){while(n>=vals[i]){r+=nums[i];n-=vals[i]}}
  return r;
}
function fromRoman(r){
  var m={I:1,V:5,X:10,L:50,C:100,D:500,M:1000},total=0;
  for(var i=0;i<r.length;i++){
    var cur=m[r[i]]||0,next=m[r[i+1]]||0;
    if(cur<next){total-=cur}else{total+=cur}
  }
  return total;
}

var mode='roman';
document.getElementById('modeToRoman').addEventListener('click',function(){
  mode='roman';this.className='btn btn-primary w-50';
  document.getElementById('modeToDecimal').className='btn btn-outline-primary w-50';
  document.getElementById('toRomanPane').style.display='block';
  document.getElementById('toDecimalPane').style.display='none';
});
document.getElementById('modeToDecimal').addEventListener('click',function(){
  mode='decimal';this.className='btn btn-primary w-50';
  document.getElementById('modeToRoman').className='btn btn-outline-primary w-50';
  document.getElementById('toRomanPane').style.display='none';
  document.getElementById('toDecimalPane').style.display='block';
});

document.getElementById('btnToRoman').addEventListener('click',function(){
  var v=parseInt(document.getElementById('decimalInput').value)||0;
  document.getElementById('romanResult').innerHTML='<div class="display-5 fw-bold" style="color:#6366f1;letter-spacing:4px">'+(toRoman(v)||'<span class="text-danger">Invalid</span>')+'</div>';
});
document.getElementById('btnToDecimal').addEventListener('click',function(){
  var v=document.getElementById('romanInput').value.toUpperCase().replace(/[^IVXLCDM]/g,'');
  document.getElementById('decimalResult').innerHTML='<div class="display-5 fw-bold" style="color:#6366f1">'+fromRoman(v)+'</div>';
});
document.getElementById('decimalInput').addEventListener('input',function(){
  var v=parseInt(this.value)||0;
  document.getElementById('romanResult').innerHTML='<div class="display-5 fw-bold" style="color:#6366f1;letter-spacing:4px">'+(toRoman(v)||'')+'</div>';
});
document.getElementById('romanInput').addEventListener('input',function(){
  var v=this.value.toUpperCase().replace(/[^IVXLCDM]/g,'');
  document.getElementById('decimalResult').innerHTML='<div class="display-5 fw-bold" style="color:#6366f1">'+fromRoman(v)+'</div>';
});

document.querySelectorAll('[data-val]').forEach(function(b){
  b.addEventListener('click',function(){
    var v=parseInt(this.dataset.val),r=toRoman(v);
    if(mode==='roman'){document.getElementById('decimalInput').value=v;document.getElementById('romanResult').innerHTML='<div class="display-5 fw-bold" style="color:#6366f1;letter-spacing:4px">'+r+'</div>'}
    else{document.getElementById('romanInput').value=r;document.getElementById('decimalResult').innerHTML='<div class="display-5 fw-bold" style="color:#6366f1">'+v+'</div>'}
  });
});

var yearsHtml='';
[1990,2000,2010,2020,2024,2025,2026,2027,2045,2050].forEach(function(y){
  yearsHtml+='<span class="badge bg-light text-dark me-1 mb-1" style="cursor:pointer" data-yr="'+y+'">'+y+' = '+toRoman(y)+'</span> ';
});
document.getElementById('yearList').innerHTML=yearsHtml;
document.querySelectorAll('[data-yr]').forEach(function(el){
  el.addEventListener('click',function(){
    var y=parseInt(this.dataset.yr);
    document.getElementById('decimalInput').value=y;
    document.getElementById('romanResult').innerHTML='<div class="display-5 fw-bold" style="color:#6366f1;letter-spacing:4px">'+toRoman(y)+'</div>';
  });
});
</script>

