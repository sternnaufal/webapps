---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Savings Calculator';
const description = 'Kalkulator tabungan online. Hitung bunga majemuk, target tabungan, dan simulasi investasi.';
const keywords = 'savings calculator, kalkulator tabungan, bunga majemuk, compound interest, investasi';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0fdf4;color:#16a34a;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div><div><h1 class="h3 mb-0">Savings Calculator</h1><p class="text-muted small mb-0">Hitung tabungan dengan bunga majemuk. Lihat simulasi pertumbuhan uang Anda.</p></div></header>
<div class="row g-4"><div class="col-lg-5">
<div class="card shadow-sm border-0 p-3">
<div class="mb-3"><label class="form-label fw-semibold">Jumlah Awal (Rp)</label><input type="number" id="initialAmount" class="form-control" value="1000000" step="100000"></div>
<div class="mb-3"><label class="form-label fw-semibold">Setoran Bulanan (Rp)</label><input type="number" id="monthlyAmount" class="form-control" value="500000" step="50000"></div>
<div class="mb-3"><label class="form-label fw-semibold">Bunga per Tahun (%)</label><input type="number" id="interestRate" class="form-control" value="6" step="0.1"></div>
<div class="row g-2 mb-3"><div class="col-6"><label class="form-label small">Jangka Waktu</label><input type="number" id="years" class="form-control" value="5" min="1" max="50"></div>
<div class="col-6"><label class="form-label small">Frekuensi Bunga</label><select id="compoundFreq" class="form-select"><option value="12">Bulanan</option><option value="4">Kuartalan</option><option value="1" selected>Tahunan</option></select></div></div>
<button id="btnCalc" class="btn btn-primary w-100">Hitung</button>
</div></div>
<div class="col-lg-7">
<div class="card shadow-sm border-0 p-3 mb-3">
<h6 class="mb-3">Hasil Simulasi</h6>
<div class="row g-3"><div class="col-4"><div class="p-3 rounded text-center" style="background:#eef2ff"><small class="text-muted">Total Setoran</small><div class="h5 mb-0 fw-bold" id="totalContrib" style="color:#6366f1">Rp0</div></div></div>
<div class="col-4"><div class="p-3 rounded text-center" style="background:#f0fdf4"><small class="text-muted">Bunga</small><div class="h5 mb-0 fw-bold" id="totalInterest" style="color:#16a34a">Rp0</div></div></div>
<div class="col-4"><div class="p-3 rounded text-center" style="background:#fefce8"><small class="text-muted">Total Akhir</small><div class="h5 mb-0 fw-bold" id="totalFinal" style="color:#ca8a04">Rp0</div></div></div></div>
</div>
<div class="card shadow-sm border-0 p-3">
<h6 class="mb-3">Detail per Tahun</h6>
<div class="table-responsive" style="max-height:300px;overflow-y:auto"><table class="table table-sm small mb-0"><thead><tr><th>Tahun</th><th>Setoran</th><th>Bunga</th><th>Saldo</th></tr></thead><tbody id="yearlyTable"></tbody></table></div>
</div>
</div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Savings Calculator</h6><p class="small mb-1" style="line-height:1.6">Savings calculator online untuk menghitung proyeksi tabungan dengan bunga majemuk (compound interest). Alat ini membantu Anda merencanakan keuangan masa depan dengan menghitung berapa banyak uang yang akan terkumpul jika Anda menabung secara rutin dengan bunga berbunga. Sangat berguna untuk perencanaan dana darurat, dana pensiun, atau tujuan keuangan jangka panjang.</p><p class="small mb-0" style="line-height:1.6">Fitur kalkulator tabungan ini meliputi: input setoran awal, setoran bulanan, suku bunga per tahun (%), dan periode tabungan (tahun atau bulan), perhitungan compound interest dengan berbagai frekuensi (harian, bulanan, triwulanan, tahunan), grafik pertumbuhan tabungan dari waktu ke waktu yang membandingkan total setoran vs bunga yang diperoleh, tabel pertahun yang menampilkan detail saldo akhir, total setoran, dan total bunga, serta tombol untuk mendownload data ke CSV.</p><p class="small mb-0 mt-2" style="line-height:1.6">Kalkulator tabungan membantu Anda: memvisualisasikan kekuatan bunga majemuk dalam menumbuhkan tabungan, menentukan target tabungan bulanan untuk mencapai tujuan keuangan, membandingkan efek frekuensi compounding yang berbeda, merencanakan dana pensiun atau pendidikan anak, memahami pentingnya memulai investasi sedini mungkin, dan membuat keputusan keuangan yang lebih informasi. Semua perhitungan dilakukan di browser.</p></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Savings Calculator</h6><p class="small mb-1" style="line-height:1.6">Savings calculator online untuk menghitung proyeksi tabungan dengan bunga majemuk (compound interest). Alat ini membantu Anda merencanakan keuangan masa depan dengan menghitung berapa banyak uang yang akan terkumpul jika Anda menabung secara rutin dengan bunga berbunga. Sangat berguna untuk perencanaan dana darurat, dana pensiun, atau tujuan keuangan jangka panjang.</p><p class="small mb-0" style="line-height:1.6">Fitur kalkulator tabungan ini meliputi: input setoran awal, setoran bulanan, suku bunga per tahun (%), dan periode tabungan (tahun atau bulan), perhitungan compound interest dengan berbagai frekuensi (harian, bulanan, triwulanan, tahunan), grafik pertumbuhan tabungan dari waktu ke waktu yang membandingkan total setoran vs bunga yang diperoleh, tabel pertahun yang menampilkan detail saldo akhir, total setoran, dan total bunga, serta tombol untuk mendownload data ke CSV.</p><p class="small mb-0 mt-2" style="line-height:1.6">Kalkulator tabungan membantu Anda: memvisualisasikan kekuatan bunga majemuk dalam menumbuhkan tabungan, menentukan target tabungan bulanan untuk mencapai tujuan keuangan, membandingkan efek frekuensi compounding yang berbeda, merencanakan dana pensiun atau pendidikan anak, memahami pentingnya memulai investasi sedini mungkin, dan membuat keputusan keuangan yang lebih informasi. Semua perhitungan dilakukan di browser.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="calorie-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Calorie Calculator</a><a href="percentage-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Percentage Calculator</a><a href="tip-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Tip Calculator</a><a href="sleep-cycle" class="btn btn-outline-secondary btn-sm rounded-pill">Sleep Cycle</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var initial=document.getElementById('initialAmount'),monthly=document.getElementById('monthlyAmount'),rate=document.getElementById('interestRate'),years=document.getElementById('years'),freq=document.getElementById('compoundFreq');
function fmt(n){return 'Rp '+Math.round(n).toLocaleString('id-ID')}

document.getElementById('btnCalc').addEventListener('click',function(){
  var P=parseFloat(initial.value)||0,M=parseFloat(monthly.value)||0,r=parseFloat(rate.value)/100/100,y=parseInt(years.value)||1,n=parseInt(freq.value);
  var totalContrib=P+(M*12*y),balance=P,prevBalance=P,totalInterest=0;
  var rows='',monthsPerYear=12,months=y*12,monthlyRate=r/12;

  for(var year=1;year<=y;year++){
    var annualContrib=M*12;
    for(var m=1;m<=12;m++){
      balance=(balance+monthlyRate)*(1+monthlyRate);
      balance+=M;
    }
    var yearInterest=balance-prevBalance-annualContrib;
    totalInterest+=yearInterest;
    prevBalance=balance;
    rows+='<tr><td>'+year+'</td><td>'+fmt(totalContrib)+'</td><td>'+fmt(totalInterest)+'</td><td class="fw-bold">'+fmt(balance)+'</td></tr>';
  }

  document.getElementById('totalContrib').textContent=fmt(totalContrib);
  document.getElementById('totalInterest').textContent=fmt(totalInterest);
  document.getElementById('totalFinal').textContent=fmt(balance);
  document.getElementById('yearlyTable').innerHTML=rows;
});
document.getElementById('btnCalc').click();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>