---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Typing Speed Test';
const description = 'Tes kecepatan mengetik online. Ukur WPM (words per minute), akurasi, dan waktu. Latihan typing dengan teks acak.';
const keywords = 'typing speed test, tes kecepatan mengetik, wpm test, test typing, latihan ngetik';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#eff6ff;color:#2563eb;">WPM</div><div><h1 class="h3 mb-0">Typing Speed Test</h1><p class="text-muted small mb-0">Ukur kecepatan mengetik dan akurasi Anda dalam hitungan detik.</p></div></header><div class="row g-4"><div class="col-lg-8"><div class="card shadow-sm border-0 p-3"><div class="d-flex justify-content-between align-items-center mb-3"><select id="durationSelect" class="form-select form-select-sm w-auto"><option value="15">15 detik</option><option value="30" selected>30 detik</option><option value="60">60 detik</option></select><span class="small text-muted" id="timerDisplay">30s</span></div><div class="position-relative"><div class="typing-text" id="textDisplay"></div><textarea id="userInput" class="form-control mt-3 font-mono" rows="2" placeholder="Ketik di sini..." disabled></textarea></div><div class="d-flex gap-2 mt-3"><button id="btnStart" class="btn btn-primary">Mulai Tes</button><button id="btnReset" class="btn btn-outline-danger">Reset</button></div><div id="resultsArea" class="row g-2 mt-3" style="display:none"><div class="col-3"><div class="result-stat"><div class="value" id="wpmDisplay">0</div><div class="label">WPM</div></div></div><div class="col-3"><div class="result-stat"><div class="value" id="accDisplay">0%</div><div class="label">Akurasi</div></div></div><div class="col-3"><div class="result-stat"><div class="value" id="timeDisplay">0s</div><div class="label">Waktu</div></div></div><div class="col-3"><div class="result-stat"><div class="value" id="charDisplay">0/0</div><div class="label">Benar/Salah</div></div></div></div></div></div><div class="col-lg-4"><div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Skor WPM</h6><div class="small" style="line-height:2"><div>&lt; 30: <span class="text-danger">Lambat</span></div><div>30-40: <span class="text-warning">Rata-rata</span></div><div>40-60: <span class="text-info">Baik</span></div><div>60-80: <span class="text-success">Sangat Baik</span></div><div>80+: <span class="text-primary">Profesional</span></div></div></div></div></div><div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Typing Speed Test</h6><p class="small mb-1" style="line-height:1.6">Tes kecepatan mengetik online untuk mengukur WPM (Words Per Minute) dan akurasi mengetik Anda. Alat ini menampilkan teks acak berbahasa Indonesia yang harus Anda ketik secepat dan seakurat mungkin dalam durasi yang ditentukan (15, 30, atau 60 detik). Hasil pengukuran meliputi WPM, persentase akurasi, waktu tempuh, dan jumlah karakter benar dan salah.</p><p class="small mb-0" style="line-height:1.6">Cara penggunaan: pilih durasi tes, klik Mulai Tes, dan ketik teks yang ditampilkan di layar. Setiap karakter yang benar akan berwarna hijau, sedangkan yang salah berwarna merah dengan garis bawah. Setelah waktu habis atau teks selesai diketik, hasil akan ditampilkan lengkap dengan skor WPM dan akurasi. Terdapat juga panduan skor: di bawah 30 WPM (lambat), 30-40 (rata-rata), 40-60 (baik), 60-80 (sangat baik), dan 80+ (profesional).</p><p class="small mb-0 mt-2" style="line-height:1.6">Latihan mengetik secara rutin dapat meningkatkan produktivitas kerja secara signifikan. Typing speed test ini cocok untuk: mengevaluasi kemampuan mengetik saat ini, berlatih meningkatkan kecepatan dan akurasi, mempersiapkan tes kerja yang membutuhkan kemampuan mengetik, mengukur progres latihan dari waktu ke waktu, dan bersenang-senang dengan tantangan mengetik. Tes ini juga bisa digunakan di sekolah atau kursus komputer.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center"><span class="small text-muted me-2">Bagikan:</span><a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">&nearr;</a><a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">in</a><a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a></div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="stopwatch" class="btn btn-outline-secondary btn-sm rounded-pill">Stopwatch</a><a href="timer" class="btn btn-outline-secondary btn-sm rounded-pill">Timer</a><a href="char-counter" class="btn btn-outline-secondary btn-sm rounded-pill">Char Counter</a><a href="pomodoro" class="btn btn-outline-secondary btn-sm rounded-pill">Pomodoro</a></div>`;
const toolCss = `.typing-text{font-family:monospace;font-size:1.1rem;line-height:1.8;letter-spacing:0.5px;padding:1rem;border-radius:8px;background:var(--surface-soft);user-select:none;word-break:break-all}.typing-text .correct{color:#22c55e}.typing-text .wrong{color:#ef4444;text-decoration:underline}.typing-text .current{background:#3b82f6;color:#fff;border-radius:2px}.result-stat{text-align:center;padding:0.75rem;border-radius:8px;background:var(--surface-soft)}.result-stat .value{font-size:1.8rem;font-weight:700}.result-stat .label{font-size:0.75rem;text-transform:uppercase;color:var(--text-muted)}`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
{toolCss}
</style>
<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var TEXTS=["Kucing itu duduk di atas tikar sambil menikmati sinar matahari pagi yang hangat.","Belajar coding memang tidak mudah tapi sangat menyenangkan jika sudah terbiasa.","Internet menghubungkan miliaran orang di seluruh dunia dalam hitungan detik.","Kopi hitam tanpa gula adalah minuman favorit para programmer di pagi hari.","Musik klasik dapat membantu meningkatkan konsentrasi saat belajar atau bekerja.","Matahari terbit di timur dan tenggelam di barat setiap hari tanpa henti.","Teknologi blockchain mengubah cara kita bertransaksi dan menyimpan data.","Olahraga teratur baik untuk kesehatan jantung dan kebugaran tubuh secara umum.","Bahasa Indonesia adalah bahasa persatuan yang digunakan di seluruh Nusantara.","Gunung berapi terbentuk dari lelehan batuan panas yang naik ke permukaan bumi.","Pendidikan adalah kunci utama untuk membuka pintu kesempatan di masa depan.","Hewan langka dilindungi oleh undang-undang agar tidak punah dari alam.","Makanan bergizi seimbang penting untuk pertumbuhan dan perkembangan anak-anak.","Awan mendung menandakan bahwa hujan akan turun dalam waktu dekat.","Buku adalah jendela dunia yang membuka wawasan dan pengetahuan tanpa batas."];var dS=document.getElementById('durationSelect'),tD=document.getElementById('timerDisplay'),txD=document.getElementById('textDisplay'),uI=document.getElementById('userInput'),bS=document.getElementById('btnStart'),bR=document.getElementById('btnReset'),rA=document.getElementById('resultsArea'),wD=document.getElementById('wpmDisplay'),aD=document.getElementById('accDisplay'),tiD=document.getElementById('timeDisplay'),cD=document.getElementById('charDisplay');var curText='',pos=0,errors=0,total=0,started=false,finished=false,startTime=0,duration=30,timerInt=null,remaining=0;function pickText(){var i=Math.floor(Math.random()*TEXTS.length);curText=TEXTS[i];txD.innerHTML='';for(var j=0;j<curText.length;j++){var s=document.createElement('span');s.textContent=curText[j];if(j===0)s.className='current';txD.appendChild(s)}uI.value='';pos=0;errors=0;total=0;started=false;finished=false;rA.style.display='none';uI.disabled=true;uI.placeholder='Mulai tes dulu...'}function startTest(){duration=parseInt(dS.value);remaining=duration;tD.textContent=remaining+'s';started=true;finished=false;pos=0;errors=0;total=0;startTime=Date.now();uI.value='';uI.disabled=false;uI.focus();rA.style.display='none';bS.disabled=true;timerInt=setInterval(function(){remaining=Math.max(0,Math.ceil((duration*1000-(Date.now()-startTime))/1000));tD.textContent=remaining+'s';if(remaining<=0)endTest()},200)}function endTest(){clearInterval(timerInt);finished=true;started=false;uI.disabled=true;bS.disabled=false;tD.textContent='Selesai!';var timeUsed=Math.max((Date.now()-startTime)/1000,1);var words=total/5;var wpm=Math.round(words/(timeUsed/60));var acc=total>0?Math.round((total-errors)/total*100):0;wD.textContent=wpm;aD.textContent=acc+'%';tiD.textContent=Math.round(timeUsed)+'s';cD.textContent=pos+'/'+errors;rA.style.display='flex'}uI.addEventListener('input',function(e){if(!started)return;var val=uI.value;if(!started&&val.length===1){startTime=Date.now();started=true}var expected=curText.slice(0,val.length);for(var i=0;i<val.length;i++){if(i>=curText.length)break;var sp=txD.children[i];sp.className=val[i]===curText[i]?'correct':'wrong';if(i===val.length-1&&val.length<curText.length){sp.className=(sp.className||'')+' current';if(i>0)txD.children[i-1].className=txD.children[i-1].className.replace(' current','')}}total=val.length;errors=0;for(var i=0;i<val.length;i++)if(val[i]!==curText[i])errors++;if(val.length>=curText.length)endTest()});bS.addEventListener('click',startTest);bR.addEventListener('click',function(){clearInterval(timerInt);tD.textContent='30s';pickText();rA.style.display='none';bS.disabled=false;uI.disabled=true});pickText();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>