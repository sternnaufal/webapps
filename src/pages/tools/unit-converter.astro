---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Unit Converter';
const description = 'Konversi satuan panjang, berat, suhu, volume online gratis. Unit converter lengkap.';
const keywords = 'unit converter, konversi satuan, length converter, weight converter, temperature converter';
const bodyHtml = `<div class="card p-4 shadow-sm">
        <div class="row g-3 mb-3">
          <div class="col-md-4">
            <label class="form-label">Kategori</label>
            <select id="category" class="form-select">
              <option value="length">Length</option>
              <option value="weight">Weight</option>
              <option value="temperature">Temperature</option>
              <option value="volume">Volume</option>
              <option value="area">Area</option>
              <option value="speed">Speed</option>
              <option value="data">Data</option>
            </select>
          </div>
          <div class="col-md-4">
            <label for="fromVal" class="form-label">Nilai</label>
            <input type="number" id="fromVal" class="form-control" value="1" step="any">
          </div>
          <div class="col-md-2">
            <label for="fromUnit" class="form-label">Dari</label>
            <select id="fromUnit" class="form-select"></select>
          </div>
          <div class="col-md-2">
            <label for="toUnit" class="form-label">Ke</label>
            <select id="toUnit" class="form-select"></select>
          </div>
        </div>
        <div class="row g-3 align-items-end">
          <div class="col-md-8">
            <div class="p-3 bg-light rounded border">
              <div class="h4 mb-0" id="resultDisplay">1 = 1</div>
            </div>
          </div>
          <div class="col-md-4 d-grid">
            <button id="btnSwap" class="btn btn-outline-secondary">Swap Units</button>
          </div>
        </div>
      </div>
    <div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Unit Converter</h6><p class="small mb-1" style="line-height:1.6">Unit converter online lengkap untuk konversi satuan antar berbagai sistem pengukuran. Mendukung kategori: panjang (meter, cm, inch, feet, yard, mile, km), berat (kg, gram, pound, ounce), suhu (Celsius, Fahrenheit, Kelvin), volume (liter, gallon, ml, cup), luas (m, ft, acre, hectare), dan kecepatan (km/jam, mph, knot, m/s). Alat ini berguna bagi pelajar, profesional, traveler, dan siapa pun yang perlu konversi satuan cepat dan akurat.</p><p class="small mb-0" style="line-height:1.6">Cara penggunaan: pilih kategori satuan yang diinginkan, masukkan nilai pada satuan asal, dan hasil konversi akan ditampilkan secara real-time di semua satuan lainnya. Kalkulator unit ini mendukung konversi antar sistem metrik dan imperial, serta menampilkan faktor konversi dan rumus yang digunakan. Setiap hasil dapat disalin ke clipboard dengan sekali klik. Antarmuka yang bersih dan responsif memudahkan penggunaan di perangkat desktop maupun mobile.</p><p class="small mb-0 mt-2" style="line-height:1.6">Konverter satuan sangat berguna dalam berbagai situasi: memasak dengan resep dari luar negeri (konversi cup ke ml, Fahrenheit ke Celsius), perjalanan ke negara dengan sistem satuan berbeda (mil ke km, pound ke kg), pekerjaan teknis dan engineering (inch ke mm, feet ke meter), belajar fisika dan matematika, serta belanja online internasional. Semua konversi dilakukan di browser tanpa koneksi internet.</p></div>\`n`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="time-converter" class="btn btn-outline-secondary btn-sm rounded-pill">Time Converter</a><a href="css-unit" class="btn btn-outline-secondary btn-sm rounded-pill">CSS Unit Converter</a><a href="konverter-bilangan" class="btn btn-outline-secondary btn-sm rounded-pill">Konverter Bilangan</a><a href="date-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">Date Calculator</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent = new Date().getFullYear();
</script>

<script is:inline>
var UNITS = {
  length: {
    base: 'm',
    units: { mm: 0.001, cm: 0.01, m: 1, km: 1000, in: 0.0254, ft: 0.3048, yd: 0.9144, mi: 1609.344 }
  },
  weight: {
    base: 'kg',
    units: { mg: 0.000001, g: 0.001, kg: 1, ton: 1000, oz: 0.0283495, lb: 0.453592 }
  },
  volume: {
    base: 'L',
    units: { mL: 0.001, L: 1, 'm\\u00B3': 1000, gal: 3.78541, qt: 0.946353, pt: 0.473176, cup: 0.236588, floz: 0.0295735 }
  },
  area: {
    base: 'm\\u00B2',
    units: { 'mm\\u00B2': 0.000001, 'cm\\u00B2': 0.0001, 'm\\u00B2': 1, ha: 10000, 'km\\u00B2': 1000000, 'in\\u00B2': 0.00064516, 'ft\\u00B2': 0.092903, ac: 4046.86 }
  },
  speed: {
    base: 'm/s',
    units: { 'm/s': 1, 'km/h': 0.277778, 'mph': 0.44704, knot: 0.514444, 'ft/s': 0.3048 }
  },
  data: {
    base: 'B',
    units: { B: 1, KB: 1000, MB: 1000000, GB: 1000000000, TB: 1000000000000, KiB: 1024, MiB: 1048576, GiB: 1073741824 }
  }
};

// Temperature special case
UNITS.temperature = {
  base: 'C',
  units: { C: 'c', F: 'f', K: 'k' },
  convert: function(val, from, to) {
    var c;
    if (from === 'C') c = val;
    else if (from === 'F') c = (val - 32) * 5/9;
    else c = val - 273.15;

    if (to === 'C') return c;
    if (to === 'F') return c * 9/5 + 32;
    return c + 273.15;
  }
};

var category = document.getElementById('category');
var fromUnit = document.getElementById('fromUnit');
var toUnit = document.getElementById('toUnit');
var fromVal = document.getElementById('fromVal');
var resultDisplay = document.getElementById('resultDisplay');

function populateUnits(cat) {
  fromUnit.innerHTML = '';
  toUnit.innerHTML = '';
  var units = UNITS[cat];
  var keys;
  if (cat === 'temperature') {
    keys = ['C', 'F', 'K'];
  } else {
    keys = Object.keys(units.units);
  }
  keys.forEach(function(k, i) {
    var opt1 = document.createElement('option');
    opt1.value = k;
    opt1.textContent = k;
    fromUnit.appendChild(opt1);
    var opt2 = document.createElement('option');
    opt2.value = k;
    opt2.textContent = k;
    toUnit.appendChild(opt2);
  });
  if (keys.length > 1) toUnit.value = keys[1];
  convert();
}

function convert() {
  var cat = category.value;
  var val = parseFloat(fromVal.value) || 0;
  var from = fromUnit.value;
  var to = toUnit.value;

  var result;
  if (cat === 'temperature') {
    result = UNITS.temperature.convert(val, from, to);
  } else {
    var u = UNITS[cat].units;
    var baseVal = val * u[from];
    result = baseVal / u[to];
  }

  resultDisplay.textContent = val + ' ' + from + ' = ' + result.toPrecision(10).replace(/\\.?0+$/, '') + ' ' + to;
}

category.addEventListener('change', function() { populateUnits(this.value); });
fromUnit.addEventListener('change', convert);
toUnit.addEventListener('change', convert);
fromVal.addEventListener('input', convert);

document.getElementById('btnSwap').addEventListener('click', function() {
  var tmp = fromUnit.value;
  fromUnit.value = toUnit.value;
  toUnit.value = tmp;
  convert();
});

populateUnits('length');
</script>

