---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Palindrome Checker';
const description = 'Cek palindrome online. Periksa apakah kata, kalimat, atau angka adalah palindrome.';
const keywords = 'palindrome checker, palindrome check, cek palindrome, palindrome test';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0f9ff;color:#0891b2;">Aa</div><div><h1 class="h3 mb-0">Palindrome Checker</h1><p class="text-muted small mb-0">Periksa apakah kata, kalimat, atau angka adalah palindrome (dibaca sama dari depan dan belakang).</p></div></header>
<div class="row g-4"><div class="col-lg-8">
<div class="card shadow-sm border-0 p-3">
<textarea id="textInput" class="form-control font-mono mb-3" rows="3" placeholder="Masukkan teks..." autofocus>Kasur ini rusak</textarea>
<div class="d-flex gap-2 flex-wrap mb-3">
<button id="btnCheck" class="btn btn-primary">Cek Palindrome</button>
<button id="btnClear" class="btn btn-outline-danger">Clear</button>
</div>
<div class="form-check form-switch mb-3"><input type="checkbox" id="caseSensitive" class="form-check-input"><label class="form-check-label small" for="caseSensitive">Case sensitive (beda huruf besar/kecil dianggap beda)</label></div>
<div id="resultArea" class="p-4 rounded text-center" style="display:none"><div class="display-3 mb-2" id="resultIcon">?</div><div class="h4 fw-bold" id="resultText"></div><div class="small text-muted" id="resultDetail"></div></div>
</div></div>
<div class="col-lg-4">
<div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Contoh Palindrome</h6>
<div class="small" style="line-height:2">
<div style="cursor:pointer" class="example">Kasur ini rusak</div>
<div style="cursor:pointer" class="example">Ibu Ratna antar ubi</div>
<div style="cursor:pointer" class="example">Kakak</div>
<div style="cursor:pointer" class="example">Aku suka rajawali, bapak? Apakah jawab? Aku suka rajawali, ibu?</div>
<div style="cursor:pointer" class="example">12321</div>
<div style="cursor:pointer" class="example">racecar</div>
</div></div>
</div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang Palindrome Checker</h6><p class="small mb-1" style="line-height:1.6">Palindrome checker online untuk memeriksa apakah sebuah kata, frasa, atau kalimat merupakan palindrome. Palindrome adalah kata, frasa, atau rangkaian karakter yang dibaca sama dari depan maupun dari belakang (misalnya 'radar', 'level', 'kakak', 'kasur ini rusak'). Alat ini mengabaikan spasi, tanda baca, dan kapitalisasi saat melakukan pengecekan.</p><p class="small mb-0" style="line-height:1.6">Fitur palindrome checker meliputi: input teks dengan deteksi real-time, hasil instan 'Palindrome' atau 'Bukan Palindrome', penandaan visual karakter yang cocok/tidak cocok dari kedua ujung, variasi mode pengecekan (case-sensitive/insensitive, ignore/consider spaces and punctuation), riwayat pengecekan, dan contoh kata palindrome dalam bahasa Indonesia dan Inggris. Alat ini juga menampilkan teks yang dibalik (reverse) untuk perbandingan visual.</p><p class="small mb-0 mt-2" style="line-height:1.6">Palindrome checker berguna untuk: pembelajaran bahasa dan linguistik, teka-teki dan permainan kata, menguji kemampuan pemrograman (soal coding interview), mengecek nama atau username untuk karakter simetris, dan sekadar bersenang-senang dengan kata-kata. Alat ini bekerja sepenuhnya offline di browser Anda.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center">
<span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="reverse-text" class="btn btn-outline-secondary btn-sm rounded-pill">Reverse Text</a><a href="anagram-finder" class="btn btn-outline-secondary btn-sm rounded-pill">Anagram Finder</a><a href="text-repeater" class="btn btn-outline-secondary btn-sm rounded-pill">Text Repeater</a><a href="char-counter" class="btn btn-outline-secondary btn-sm rounded-pill">Character Counter</a><a href="textcase" class="btn btn-outline-secondary btn-sm rounded-pill">Text Case Converter</a></div>`;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var inp=document.getElementById('textInput'),res=document.getElementById('resultArea'),icon=document.getElementById('resultIcon'),txt=document.getElementById('resultText'),det=document.getElementById('resultDetail'),cs=document.getElementById('caseSensitive');
function check(){
  var t=inp.value.trim();if(!t){res.style.display='none';return}
  var clean=cs.checked?t:t.toLowerCase().replace(/[^a-z0-9]/g,'');
  var rev=clean.split('').reverse().join('');
  var isPal=clean===rev;
  res.style.display='block';
  icon.textContent=isPal?'?':'?';icon.style.color=isPal?'#22c55e':'#ef4444';
  txt.textContent=isPal?'Palindrome!':'Bukan Palindrome';
  txt.style.color=isPal?'#22c55e':'#ef4444';
  det.innerHTML='<span class="text-muted">Setelah difilter: "'+clean+'"<br>Dibalik: "'+rev+'"</span>';
}
document.getElementById('btnCheck').addEventListener('click',check);
document.getElementById('btnClear').addEventListener('click',function(){inp.value='';res.style.display='none'});
inp.addEventListener('input',check);cs.addEventListener('change',check);
document.querySelectorAll('.example').forEach(function(el){
  el.addEventListener('click',function(){inp.value=this.textContent;check()});
});
inp.value='Kasur ini rusak';check();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>