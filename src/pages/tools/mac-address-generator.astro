---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'MAC Address Generator';
const description = 'MAC address generator online. Generate alamat MAC acak dengan format colon, dash, atau dot. Batch generate, vendor prefix, dan OUI lookup.';
const keywords = 'MAC address generator, generate MAC, random MAC, MAC vendor lookup, OUI, alamat MAC';
const bodyHtml = `<header class="d-flex align-items-center gap-3 mb-4"><div class="tool-icon" style="background:#f0fdf4;color:#059669;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="6" width="20" height="12" rx="2"/><line x1="6" y1="6" x2="6" y2="18"/><line x1="10" y1="6" x2="10" y2="18"/><line x1="14" y1="6" x2="14" y2="18"/><line x1="18" y1="6" x2="18" y2="18"/></svg></div><div><h1 class="h3 mb-0">MAC Address Generator</h1><p class="text-muted small mb-0">Generate alamat MAC acak dengan berbagai format dan opsi.</p></div></header>

<div class="row g-4">
<div class="col-lg-7">
<div class="card shadow-sm border-0 p-3">
<div class="row g-2 mb-3">
<div class="col-md-4"><label class="form-label small fw-semibold">Jumlah</label><input type="number" id="macCount" class="form-control" value="5" min="1" max="50"></div>
<div class="col-md-4"><label class="form-label small fw-semibold">Format</label><select id="macFormat" class="form-select">
<option value="colon">AA:BB:CC:DD:EE:FF</option>
<option value="dash">AA-BB-CC-DD-EE-FF</option>
<option value="dot">AABB.CCDD.EEFF</option>
</select></div>
<div class="col-md-4"><label class="form-label small fw-semibold">Vendor Prefix</label><select id="macVendor" class="form-select">
<option value="">Random</option>
<option value="001A2A">Apple Inc.</option>
<option value="3C22FB">Apple Inc.</option>
<option value="A483E7">Apple Inc.</option>
<option value="001B21">Intel Corp.</option>
<option value="3C970E">Intel Corp.</option>
<option value="6805CA">Intel Corp.</option>
<option value="001AA1">Cisco Systems</option>
<option value="00260B">Cisco Systems</option>
<option value="005056">VMware</option>
<option value="001599">Samsung Elec.</option>
<option value="34C3AC">Samsung Elec.</option>
<option value="00188B">Dell Inc.</option>
<option value="3417EB">Dell Inc.</option>
<option value="B083FE">Dell Inc.</option>
<option value="0050B6">Dell Inc.</option>
<option value="001B63">Hewlett-Packard</option>
<option value="3C5282">Hewlett-Packard</option>
<option value="00155D">Microsoft Corp.</option>
<option value="3C0771">Lenovo</option>
<option value="9C5C8E">Lenovo</option>
<option value="00163E">Xerox Corp.</option>
<option value="08002B">DEC/Intel</option>
<option value="002590">Nokia</option>
<option value="08EA40">Huawei Tech.</option>
<option value="346F24">Huawei Tech.</option>
<option value="A4E731">TP-Link Tech.</option>
<option value="14CF92">TP-Link Tech.</option>
<option value="049226">Netgear Inc.</option>
<option value="002248">Sony Corp.</option>
<option value="00254B">ZTE Corp.</option>
<option value="9C28BF">Ubiquiti Inc.</option>
<option value="00D068">Ubiquiti Inc.</option>
</select></div>
</div>
<div class="row g-2 mb-3">
<div class="col-auto"><div class="form-check"><input type="radio" name="multicast" id="macUnicast" value="unicast" checked><label class="form-check-label small ms-1" for="macUnicast">Unicast</label></div></div>
<div class="col-auto"><div class="form-check"><input type="radio" name="multicast" id="macMulticast" value="multicast"><label class="form-check-label small ms-1" for="macMulticast">Multicast</label></div></div>
<div class="col-auto" style="border-left:1px solid var(--border);padding-left:12px"><div class="form-check"><input type="checkbox" id="macLocal" class="form-check-input"><label class="form-check-label small" for="macLocal">Locally Administered</label></div></div>
</div>
<button id="btnGenerate" class="btn btn-primary w-100">Generate MAC Address</button>
</div>
<div id="macOutput" class="card shadow-sm border-0 mt-3 p-3">
<div class="d-flex justify-content-between align-items-center mb-2"><span class="fw-semibold small">Hasil:</span><button id="btnCopyAll" class="btn btn-outline-secondary btn-sm">Copy Semua</button></div>
<table class="table table-sm mb-0"><tbody id="macTableBody"></tbody></table>
</div>
</div>
<div class="col-lg-5">
<div class="card shadow-sm border-0 p-3 mb-3"><h6 class="mb-3">Quick Presets</h6>
<div class="d-flex gap-2 flex-wrap">
<button class="btn btn-outline-primary btn-sm preset" data-count="3" data-fmt="colon">3 MAC</button>
<button class="btn btn-outline-primary btn-sm preset" data-count="10" data-fmt="dash">10 MAC Dash</button>
<button class="btn btn-outline-primary btn-sm preset" data-count="5" data-fmt="dot">5 MAC Dot</button>
<button class="btn btn-outline-primary btn-sm preset" data-count="5" data-local="1">Local Admin</button>
<button class="btn btn-outline-primary btn-sm preset" data-count="3" data-vendor="001A2A">Apple MACs</button>
</div>
</div>
<div class="card shadow-sm border-0 p-3"><h6 class="mb-3">Informasi MAC Address</h6>
<div class="small" style="line-height:1.7">
<p class="mb-1"><strong class="text-primary">Struktur:</strong> MAC 48-bit terdiri dari 6 octet (12 digit hex).</p>
<p class="mb-1"><strong class="text-primary">OUI:</strong> 3 octet pertama adalah <em>Organizationally Unique Identifier</em> — kode vendor pabrik.</p>
<p class="mb-1"><strong class="text-primary">Bit 0 (unicast/multicast):</strong> Bit terendah octet pertama. 0 = unicast, 1 = multicast.</p>
<p class="mb-0"><strong class="text-primary">Bit 1 (global/local):</strong> Bit kedua octet pertama. 0 = globally unique (pabrik), 1 = locally administered.</p>
</div>
</div>
</div></div>
<div class="mt-4 p-3 rounded" style="background:var(--surface-soft);border:1px solid var(--border)"><h6 class="fw-bold">Tentang MAC Address Generator</h6><p class="small mb-1" style="line-height:1.6">Generator alamat MAC acak dengan kontrol penuh atas format penulisan, prefix vendor, dan bit flags. Mendukung format colon (AA:BB:CC:DD:EE:FF), dash (AA-BB-CC-DD-EE-FF), dan dot notation (AABB.CCDD.EEFF). Batch generate hingga 50 MAC sekaligus.</p><p class="small mb-0" style="line-height:1.6">Fitur OUI (Organizationally Unique Identifier) memungkinkan penggunaan prefix dari vendor terkenal seperti Apple, Intel, Cisco, Dell, Samsung, dan lainnya. Juga tersedia opsi Unicast/Multicast dan Locally Administered bit untuk simulasi alamat yang realistis. Berguna untuk network engineer, pentester, testing, dan edukasi jaringan.</p></div>`;
const extraHtml = `
<div class="mt-3 pt-2 d-flex gap-2 justify-content-center align-items-center"><span class="small text-muted me-2">Bagikan:</span>
<a href="https://twitter.com/intent/tweet?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Twitter/X">&nearr;</a>
<a href="https://www.linkedin.com/sharing/share-offsite/?url=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="LinkedIn">in</a>
<a href="https://www.facebook.com/sharer/sharer.php?u=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="Facebook">f</a>
<a href="https://api.whatsapp.com/send?text=" onclick="this.href+=encodeURIComponent(location.href)" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm rounded-pill" title="WhatsApp">wa</a>
</div>
<div class="mt-4 pt-2"><div class="small fw-semibold mb-2 text-muted">Alat Terkait</div><div class="d-flex gap-2 flex-wrap"><a href="ip-calculator" class="btn btn-outline-secondary btn-sm rounded-pill">IP Calculator</a><a href="subnetting" class="btn btn-outline-secondary btn-sm rounded-pill">Kalkulator Subnet</a><a href="url-encode" class="btn btn-outline-secondary btn-sm rounded-pill">URL Encode</a><a href="cron-builder" class="btn btn-outline-secondary btn-sm rounded-pill">Cron Builder</a></div>`;
const toolCss = `
    .mac-cell { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.9rem; }
  `;
---

<ToolLayout
  title={title}
  description={description}
  keywords={keywords}
>

<Fragment set:html={bodyHtml} />
<Fragment set:html={extraHtml} />

</ToolLayout>

<style is:inline>
{toolCss}
</style>
<style is:inline>
.saweria-float { position: fixed; bottom: 24px; right: 24px; z-index: 9999; background: #ff6b6b; color: #fff; border-radius: 50px; padding: 10px 20px 10px 16px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(255,107,107,0.4); transition: all 0.3s ease; font-family: "Inter",sans-serif; }
.saweria-float:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(255,107,107,0.6); color: #fff; }
.saweria-float svg { animation: pulse 1.5s ease infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }
@media (max-width: 576px) { .saweria-float { bottom: 16px; right: 16px; padding: 8px 14px 8px 10px; font-size: 12px; } }
</style>

<script is:inline>
document.getElementById('year').textContent=new Date().getFullYear();
</script>

<script is:inline>
var cntInp=document.getElementById('macCount'),fmtInp=document.getElementById('macFormat'),venInp=document.getElementById('macVendor');
var chkLocal=document.getElementById('macLocal'),tblBody=document.getElementById('macTableBody');

function randomByte(){return Math.floor(Math.random()*256);}

function formatMAC(bytes,fmt){
  var parts=[];
  for(var i=0;i<6;i++)parts.push(bytes[i].toString(16).toUpperCase().padStart(2,'0'));
  if(fmt==='dash')return parts.join('-');
  if(fmt==='dot')return parts.slice(0,3).join('')+'.'+parts.slice(3,6).join('');
  return parts.join(':');
}

function generateMAC(){
  var bytes=[];
  var ven=venInp.value;
  if(ven){
    for(var i=0;i<3;i++)bytes.push(parseInt(ven.substr(i*2,2),16));
    for(var i=3;i<6;i++)bytes.push(randomByte());
  }else{
    for(var i=0;i<6;i++)bytes.push(randomByte());
  }
  var unicast=document.querySelector('input[name="multicast"]:checked').value==='unicast';
  if(unicast)bytes[0]=bytes[0]&0xFE;
  else bytes[0]=bytes[0]|0x01;
  if(chkLocal.checked)bytes[0]=bytes[0]|0x02;
  else bytes[0]=bytes[0]&0xFD;
  return bytes;
}

function generate(){
  var cnt=parseInt(cntInp.value)||5;if(cnt<1)cnt=1;if(cnt>50)cnt=50;
  var fmt=fmtInp.value;
  var rows='';
  for(var i=0;i<cnt;i++){
    var mac=formatMAC(generateMAC(),fmt);
    rows+='<tr><td class="mac-cell">'+(i+1)+'</td><td class="mac-cell fw-semibold">'+mac+'</td><td class="text-end"><button class="btn btn-sm btn-outline-secondary copy-single" data-mac="'+mac+'">Copy</button></td></tr>';
  }
  tblBody.innerHTML=rows;
}

document.getElementById('btnGenerate').addEventListener('click',generate);

document.getElementById('btnCopyAll').addEventListener('click',function(){
  var lines=[];tblBody.querySelectorAll('.mac-cell.fw-semibold').forEach(function(el){lines.push(el.textContent);});
  navigator.clipboard.writeText(lines.join('\\n')).then(function(){showToast(lines.length+' MAC copied');}).catch(function(){});
});

document.addEventListener('click',function(e){
  if(e.target.classList.contains('copy-single')){
    navigator.clipboard.writeText(e.target.dataset.mac).then(function(){showToast('MAC copied: '+e.target.dataset.mac);}).catch(function(){});
  }
});

document.querySelectorAll('.preset').forEach(function(el){el.addEventListener('click',function(){
  if(this.dataset.count)cntInp.value=this.dataset.count;
  if(this.dataset.fmt)fmtInp.value=this.dataset.fmt;
  if(this.dataset.vendor)venInp.value=this.dataset.vendor;
  if(this.dataset.local==='1')chkLocal.checked=true;else chkLocal.checked=false;
  generate();
})});

function showToast(m){
  var t=document.createElement('div');t.className='toast align-items-center text-bg-light border p-2';
  t.style.position='fixed';t.style.right='20px';t.style.bottom='20px';t.style.zIndex=9999;
  t.innerHTML='<div class="d-flex"><div class="toast-body">'+m+'</div><button type="button" class="btn-close btn-close-white me-2 m-auto" aria-label="Close"></button></div>';
  document.body.appendChild(t);
  t.querySelector('.btn-close').addEventListener('click',function(){t.remove();});
  setTimeout(function(){t.remove();},2500);
}

generate();
</script>

