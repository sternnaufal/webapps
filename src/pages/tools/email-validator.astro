---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Email Validator';
const desc = 'Validasi format email sesuai standar RFC 5322. Cek format, local part, domain, dan TLD.';
const keywords = 'email validator, email check, validasi email, format email, rfc 5322';
const bodyHtml = '<div class="row g-4">\n  <div class="col-12">\n    <div class="input-group input-group-lg"><input type="email" id="evIn" class="form-control" placeholder="Masukkan email..." value="user@example.com"><button id="evBtn" class="btn btn-warning">Check</button></div>\n  </div>\n  <div class="col-md-6">\n    <div class="card p-4 text-center">\n      <div class="text-muted small mb-2">Status</div>\n      <div id="evStatus" class="display-6 mb-2">---</div>\n      <div id="evMsg" class="small text-muted">Masukkan email dan klik Check</div>\n    </div>\n  </div>\n  <div class="col-md-6">\n    <div class="card p-3 small">\n      <h6 class="fw-semibold mb-2">Detail</h6>\n      <table class="table table-sm mb-0"><tbody>\n        <tr><td class="text-muted">Format</td><td id="evFormat" class="fw-semibold">---</td></tr>\n        <tr><td class="text-muted">Local part</td><td id="evLocal" class="fw-semibold">---</td></tr>\n        <tr><td class="text-muted">Domain</td><td id="evDomain" class="fw-semibold">---</td></tr>\n        <tr><td class="text-muted">TLD</td><td id="evTLD" class="fw-semibold">---</td></tr>\n        <tr><td class="text-muted">Panjang</td><td id="evLen" class="fw-semibold">---</td></tr>\n      </tbody></table>\n    </div>\n  </div>\n</div>';
---

<ToolLayout title={title} description={desc} keywords={keywords}>
<Fragment set:html={bodyHtml} />
</ToolLayout>

<style is:inline>
.saweria-float{position:fixed;bottom:24px;right:24px;z-index:9999;background:#ff6b6b;color:#fff;border-radius:50px;padding:10px 20px 10px 16px;text-decoration:none;font-size:14px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:0 4px 15px rgba(255,107,107,0.4);transition:all .3s ease;font-family:"Inter",sans-serif}
.saweria-float:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(255,107,107,0.6);color:#fff}
.saweria-float svg{animation:pulse 1.5s ease infinite}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
@media(max-width:576px){.saweria-float{bottom:16px;right:16px;padding:8px 14px 8px 10px;font-size:12px}}
</style>

<script is:inline>
document.getElementById("evBtn").onclick=ev;document.getElementById("evIn").onkeydown=e=>{if(e.key==="Enter")ev()};
function ev(){const e=document.getElementById("evIn").value.trim();const r=/^(([^<>()\[\]\\.,;:\s@"]+(\.[^<>()\[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;const s=document.getElementById("evStatus");const msg=document.getElementById("evMsg");const fmt=document.getElementById("evFormat");const loc=document.getElementById("evLocal");const dom=document.getElementById("evDomain");const tld=document.getElementById("evTLD");const len=document.getElementById("evLen");if(!e){s.textContent="---";msg.textContent="Masukkan email";fmt.textContent=loc.textContent=dom.textContent=tld.textContent=len.textContent="---";s.style.color="inherit";return}const ok=r.test(e);const at=e.lastIndexOf("@");s.innerHTML=ok?"✓ Valid":"✗ Invalid";s.style.color=ok?"#10b981":"#ef4444";msg.textContent=ok?"Format email valid.":"Format tidak valid RFC 5322.";fmt.textContent=ok?"Valid":"Invalid";fmt.style.color=ok?"#10b981":"#ef4444";loc.textContent=at>0?e.substring(0,at):"---";dom.textContent=at>0?e.substring(at+1):"---";const p=dom.textContent.split(".");tld.textContent=p.length>1?"."+p[p.length-1]:"---";len.textContent=e.length+" karakter"}ev();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all .3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>
