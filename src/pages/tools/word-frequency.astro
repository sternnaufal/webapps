---
import ToolLayout from "../../layouts/ToolLayout.astro";

const title = 'Word Frequency Counter';
const desc = 'Hitung frekuensi kata dalam teks. Analisis teks untuk SEO, content writing, dan riset kata kunci.';
const keywords = 'word frequency, counter, text analysis, seo, keyword density, frekuensi kata';
const bodyHtml = '<div class="row g-4">\n  <div class="col-12">\n    <textarea id="wfInput" class="form-control font-mono" rows="8" placeholder="Tempel teks di sini..."></textarea>\n  </div>\n  <div class="col-12">\n    <div class="d-flex gap-2 flex-wrap">\n      <button id="wfCountBtn" class="btn btn-warning">Hitung Frekuensi</button>\n      <button id="wfClearBtn" class="btn btn-outline-secondary">Clear</button>\n      <div class="form-check form-switch ms-auto d-flex align-items-center">\n        <input class="form-check-input" type="checkbox" id="wfIgnoreCase" checked>\n        <label class="form-check-label small" for="wfIgnoreCase">Ignore case</label>\n      </div>\n      <div class="form-check form-switch d-flex align-items-center">\n        <input class="form-check-input" type="checkbox" id="wfExcludeCommon">\n        <label class="form-check-label small" for="wfExcludeCommon">Exclude common words</label>\n      </div>\n    </div>\n  </div>\n  <div class="col-md-4">\n    <div class="card p-3">\n      <h6 class="fw-semibold mb-2">Statistik</h6>\n      <div class="small"><div class="d-flex justify-content-between"><span>Total kata</span><span id="wfTotalWords">0</span></div><div class="d-flex justify-content-between"><span>Kata unik</span><span id="wfUniqueWords">0</span></div><div class="d-flex justify-content-between"><span>Total karakter</span><span id="wfTotalChars">0</span></div><div class="d-flex justify-content-between"><span>Density tertinggi</span><span id="wfTopDensity">0%</span></div></div>\n    </div>\n  </div>\n  <div class="col-md-8">\n    <div class="table-responsive small">\n      <table class="table table-sm table-hover">\n        <thead><tr><th>#</th><th>Kata</th><th>Frekuensi</th><th>%</th><th>Bar</th></tr></thead>\n        <tbody id="wfTableBody"><tr><td colspan="5" class="text-muted text-center">Hasil akan muncul di sini</td></tr></tbody>\n      </table>\n    </div>\n  </div>\n</div>';
---

<ToolLayout title={title} description={desc} keywords={keywords}>
<Fragment set:html={bodyHtml} />
</ToolLayout>

<style is:inline>
.saweria-float{position:fixed;bottom:24px;right:24px;z-index:9999;background:#ff6b6b;color:#fff;border-radius:50px;padding:10px 20px 10px 16px;text-decoration:none;font-size:14px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:0 4px 15px rgba(255,107,107,0.4);transition:all .3s ease;font-family:"Inter",sans-serif}
.saweria-float:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(255,107,107,0.6);color:#fff}
.saweria-float svg{animation:pulse 1.5s ease infinite}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
@media(max-width:576px){.saweria-float{bottom:16px;right:16px;padding:8px 14px 8px 10px;font-size:12px}}
</style>

<script is:inline>
const SW=new Set(["the","a","an","and","or","but","in","on","at","to","for","of","by","with","from","is","are","was","were","be","been","has","had","have","do","does","did","will","would","can","could","its","this","that","these","those","i","you","he","she","we","they","me","him","her","us","them","my","your","his","her","its","our","their","not","no","nor","so","if","then","than","too","very","just","all","each","every","both","few","more","most","other","some","such","only","own","same","what","which","who","whom","when","where","why","how","yang","dan","di","ke","dari","dengan","untuk","pada","adalah","akan","tidak","sudah","dapat","bisa","telah","ini","itu","saya","kami","kita","anda","dia","mereka","dalam","ada","juga","atau","karena","sebagai","oleh","tentang","setelah","antara","seperti","tanpa","sampai","sebelum","sesudah","melalui","serta","namun","tetapi","sedangkan","meskipun","walaupun","sehingga","maka","agar","supaya","bahwa","apakah","bila","kalau","jika","saat"]);
document.getElementById("wfCountBtn").onclick=wf;document.getElementById("wfClearBtn").onclick=()=>{document.getElementById("wfInput").value="";wf()};
document.getElementById("wfInput").oninput=wf;document.getElementById("wfIgnoreCase").onchange=wf;document.getElementById("wfExcludeCommon").onchange=wf;
function wf(){const t=document.getElementById("wfInput").value;const ic=document.getElementById("wfIgnoreCase").checked;const ec=document.getElementById("wfExcludeCommon").checked;let p=ic?t.toLowerCase():t;p=p.replace(/[^\w\s\-\'\u00C0-\u024F]/g," ").replace(/\s+/g," ").trim();const w=p?p.split(/\s+/):[];const ttl=w.length;const v=w.filter(x=>x.length>0&&!/^\d+$/.test(x));const f={};v.forEach(x=>{if(ec&&SW.has(x))return;f[x]=(f[x]||0)+1});const s=Object.entries(f).sort((a,b)=>b[1]-a[1]);const u=s.length;document.getElementById("wfTotalWords").textContent=ttl;document.getElementById("wfUniqueWords").textContent=u;document.getElementById("wfTotalChars").textContent=t.length;document.getElementById("wfTopDensity").textContent=u>0&&s.length>0?((s[0][1]/ttl)*100).toFixed(1)+"%":"0%";const tb=document.getElementById("wfTableBody");if(s.length===0){tb.innerHTML='<tr><td colspan="5" class="text-muted text-center">Tidak ada kata</td></tr>';return}const mx=s[0][1];tb.innerHTML=s.map(([w,c],i)=>'<tr><td>'+(i+1)+'</td><td class="fw-semibold">'+w+'</td><td>'+c+'</td><td>'+((c/ttl)*100).toFixed(2)+'%</td><td style="width:150px"><div style="height:14px;background:#e9ecef;border-radius:4px;overflow:hidden"><div style="width:'+(c/mx*100)+'%;height:100%;background:#6366f1;border-radius:4px;transition:width .3s"></div></div></td></tr>').join("")}wf();
</script>

<a href="https://saweria.co/naufalrakha" target="_blank" rel="noopener" class="saweria-float" title="Donasi via Saweria">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  <span>Donasi</span>
</a>
<button class="dark-float btn btn-sm" title="Toggle dark mode" style="position:fixed;bottom:80px;right:24px;z-index:9998;width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:1.3rem;box-shadow:0 4px 15px rgba(99,102,241,0.4);transition:all .3s ease;display:flex;align-items:center;justify-content:center;line-height:1;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''"></button>
