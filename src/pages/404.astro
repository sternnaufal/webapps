---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout
  title="404 - Halaman Tidak Ditemukan"
  description="Halaman yang Anda cari tidak ditemukan. Kembali ke beranda WebApps."
  noindex={true}
>
  <div class="text-center py-5">
    <h1 class="display-1 text-muted fw-bold">404</h1>
    <h4 class="mb-3">Halaman Tidak Ditemukan</h4>
    <p class="text-muted mb-4">Maaf, halaman yang Anda cari tidak tersedia atau telah dipindahkan.</p>
    <a href="/" class="btn btn-warning rounded-pill px-4">Kembali ke Beranda</a>
  </div>
</ToolLayout>
