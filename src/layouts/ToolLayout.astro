---
// ToolLayout.astro — main layout for all pages
import Sidebar from '../components/Sidebar.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  keywords?: string;
  breadcrumbs?: { name: string; url: string }[];
  noindex?: boolean;
}

const { title, description, canonical, ogTitle, ogDescription, ogImage, keywords, breadcrumbs, noindex } = Astro.props;
const site = 'https://webapps.naufalrakha.my.id';
const pageUrl = canonical || Astro.url.pathname;
const fullUrl = pageUrl.startsWith('http') ? pageUrl : `${site}${pageUrl}`;
const img = ogImage || `${site}/og-image.png`;
const ogT = ogTitle || title;
const ogD = ogDescription || description;
const keyw = keywords || 'web tools, online tools, developer tools, web apps, naufal rakha';
const crumbs = breadcrumbs || [{ name: 'Beranda', url: '/tools' }, { name: title, url: pageUrl }];
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keyw} />
    <link rel="canonical" href={fullUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="/style.css" rel="stylesheet" />

    <!-- OG -->
    <meta property="og:title" content={ogT} />
    <meta property="og:description" content={ogD} />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={img} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="WebApps Naufal Rakha" />
    <meta property="og:logo" content={`${site}/logo-512.png`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogT} />
    <meta name="twitter:description" content={ogD} />
    <meta name="twitter:image" content={img} />

    <!-- JSON-LD BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": crumbs.map((c, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": c.name,
        "item": c.url.startsWith('http') ? c.url : `${site}${c.url}`
      }))
    })}></script>

    <!-- JSON-LD WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "WebApps Naufal Rakha",
      "url": site,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${site}/tools/?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    })}></script>

    <!-- JSON-LD Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Naufal Rakha Putra",
      "url": "https://naufalrakha.my.id",
      "description": "Full-Stack Developer, Game Developer & AI Builder. Creator of WebApps — koleksi 40+ online tools gratis.",
      "sameAs": [
        "https://github.com/sternnaufal",
        "https://www.linkedin.com/in/naufal-rakha-putra"
      ]
    })}></script>
  </head>

  <body>
    <div class="container-fluid">
      <div class="row">
        <!-- Desktop sidebar -->
        <div class="d-none d-md-block col-md-3 col-lg-2 ps-0">
          <Sidebar />
        </div>

        <!-- Main content -->
        <main id="main-content" class="col-md-9 col-lg-10 ms-sm-auto px-4 py-3">
          <!-- Mobile navbar -->
          <nav class="d-md-none navbar navbar-dark bg-dark mb-3 rounded">
            <div class="container-fluid">
              <span class="navbar-brand mb-0 h1">
                <img src="/favicon-48x48.png" alt="logo" width="28" height="28" class="d-inline-block align-text-top me-1" />
                WebApps
              </span>
              <button class="navbar-toggler border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar-mobile" aria-controls="sidebar-mobile">
                <span class="navbar-toggler-icon"></span>
              </button>
            </div>
          </nav>

          <slot />
        </main>
      </div>
    </div>

    <!-- Mobile sidebar (offcanvas) -->
    <div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="sidebar-mobile" aria-labelledby="sidebar-mobile-label">
      <div class="offcanvas-header bg-dark text-white">
        <h5 class="offcanvas-title" id="sidebar-mobile-label">WebApps Menu</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
      </div>
      <div class="offcanvas-body p-0">
        <Sidebar />
      </div>
    </div>

    <!-- Footer -->
    <SiteFooter />

    <!-- Scripts -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/sidebar.js"></script>
  </body>
</html>
